<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Zeitleiste - <%= project.name %> | Ticketsystem</title>
    <link rel="stylesheet" href="/style.css?v=2">
    <link rel="stylesheet" href="https://unpkg.com/vis-timeline@7.7.3/styles/vis-timeline-graph2d.min.css">
    <script src="https://unpkg.com/vis-timeline@7.7.3/standalone/umd/vis-timeline-graph2d.min.js"></script>
</head>
<body class="bg-gray-50 min-h-screen">
    <nav class="bg-white border-b border-gray-200 sticky top-0 z-50">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between h-16">
                <div class="flex items-center">
                    <div class="flex-shrink-0 flex items-center gap-2">
                        <div class="w-8 h-8 bg-primary-600 rounded-lg flex items-center justify-center">
                            <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 5v2m0 4v2m0 4v2M5 5a2 2 0 00-2 2v3a2 2 0 110 4v3a2 2 0 002 2h14a2 2 0 002-2v-3a2 2 0 110-4V7a2 2 0 00-2-2H5z"/>
                            </svg>
                        </div>
                        <a href="/" class="text-xl font-bold text-gray-900 hover:text-primary-600">Ticketsystem</a>
                    </div>
                    <div class="hidden md:ml-8 md:flex md:space-x-1">
                        <a href="/" class="nav-link">Dashboard</a>
                        <a href="/ticket/new" class="nav-link">Neues Ticket</a>
                        <a href="/projects" class="nav-link active">Projekte</a>
                        <% if (role === 'admin' || role === 'root') { %>
                        <a href="/stats" class="nav-link">Statistiken</a>
                        <a href="/admin/systems" class="nav-link">Systeme</a>
                        <a href="/admin/staff" class="nav-link">Mitarbeiter</a>
                        <% if (role === 'root') { %><a href="/admin/users" class="nav-link">Benutzer</a><% } %>
                        <% } %>
                    </div>
                </div>
                <div class="flex items-center gap-4">
                    <span class="text-sm text-gray-600"><%= user %> <span class="badge bg-gray-100 text-gray-700"><%= role %></span></span>
                    <a href="/account" class="btn-secondary text-sm">Account</a>
                    <a href="/logout" class="btn-secondary text-sm">Abmelden</a>
                </div>
            </div>
        </div>
    </nav>

    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        <nav class="flex mb-6" aria-label="Breadcrumb">
            <ol class="flex items-center space-x-4">
                <li><a href="/" class="text-gray-500 hover:text-gray-700">Dashboard</a></li>
                <li class="text-gray-400">/</li>
                <li><a href="/projects" class="text-gray-500 hover:text-gray-700">Projekte</a></li>
                <li class="text-gray-400">/</li>
                <li><a href="/project/<%= project.id %>" class="text-gray-500 hover:text-gray-700"><%= project.name %></a></li>
                <li class="text-gray-400">/</li>
                <li class="text-gray-900 font-medium">Zeitleiste</li>
            </ol>
        </nav>

        <div class="flex items-center justify-between mb-6">
            <h1 class="text-2xl font-bold text-gray-900">Zeitleiste: <%= project.name %></h1>
        </div>

        <% if (canManage && milestones.length > 0) { %>
        <div class="card mb-6 border-primary-200 bg-primary-50">
            <div class="card-body flex flex-col gap-3 md:flex-row md:items-center md:justify-between">
                <div>
                    <p class="text-sm font-semibold text-primary-900">Steps sind direkt im jeweiligen Meilenstein verankert.</p>
                    <p class="text-sm text-primary-800">Die roten Step-Links in der Leiste springen direkt zur Detailansicht mit Titel, Beschreibung und Dateien.</p>
                </div>
                <a href="/project/<%= project.id %>/milestones" class="btn-primary text-sm whitespace-nowrap">Steps verwalten</a>
            </div>
        </div>
        <% } %>

        <div class="flex flex-wrap gap-2 mb-6">
            <a href="/project/<%= project.id %>" class="btn-secondary text-sm">Dashboard</a>
            <a href="/project/<%= project.id %>/timeline" class="btn-secondary text-sm font-medium bg-primary-50 text-primary-700">Zeitleiste</a>
            <% if (canManage) { %><a href="/project/<%= project.id %>/milestones" class="btn-secondary text-sm">Meilensteine</a><% } %>
            <% if (canManage) { %><a href="/project/<%= project.id %>/keyusers" class="btn-secondary text-sm">Key-User</a><% } %>
            <a href="/project/<%= project.id %>/docs" class="btn-secondary text-sm">Wiki</a>
            <% if (canManage) { %><a href="/project/<%= project.id %>/github" class="btn-secondary text-sm">GitHub</a><% } %>
        </div>

        <%
            const datedMilestones = milestones.filter((m) => m.start_date && m.end_date);
            const timelineStart = project.start_date
                ? new Date(project.start_date)
                : datedMilestones.length
                    ? datedMilestones.reduce((min, milestone) => new Date(milestone.start_date) < min ? new Date(milestone.start_date) : min, new Date(datedMilestones[0].start_date))
                    : null;
            const fallbackEnd = datedMilestones.length
                ? datedMilestones.reduce((max, milestone) => new Date(milestone.end_date) > max ? new Date(milestone.end_date) : max, new Date(datedMilestones[0].end_date))
                : null;
            const timelineEnd = project.end_date ? new Date(project.end_date) : fallbackEnd;
            const formatDate = (value) => value ? new Date(value).toLocaleDateString('de-DE', { day: '2-digit', month: '2-digit', year: 'numeric' }) : 'Ohne Datum';
            const milestonesWithSteps = milestones.filter((milestone) => (milestone.steps || []).length > 0);
            const timelineItems = [];
            if (timelineStart && timelineEnd) {
                timelineItems.push({
                    id: 'project',
                    content: project.name,
                    start: project.start_date || timelineStart.toISOString().slice(0, 10),
                    end: project.end_date || timelineEnd.toISOString().slice(0, 10),
                    type: 'range',
                    className: 'vis-item-project',
                });
            }
            milestones.forEach((milestone) => {
                const anchor = milestone.end_date || milestone.start_date;
                if (!anchor) return;
                timelineItems.push({
                    id: 'milestone-' + milestone.id,
                    content: milestone.title,
                    start: anchor,
                    type: 'point',
                    className: 'vis-item-milestone',
                    title: 'Meilenstein: ' + milestone.title + ' (' + formatDate(milestone.start_date) + ' - ' + formatDate(milestone.end_date) + ')',
                });
                (milestone.steps || []).forEach((step) => {
                    if (!step.date) return;
                    timelineItems.push({
                        id: 'step-' + step.id,
                        content: step.title || ('Step ' + step.id),
                        start: step.date,
                        type: 'point',
                        className: 'vis-item-step',
                        title: (step.title || 'Step ' + step.id) + ' (' + formatDate(step.date) + ')',
                        link: '#timeline-step-' + step.id,
                    });
                });
            });
        %>

        <div class="card mb-6">
            <div class="card-body">
                <% if (milestones.length === 0) { %>
                <p class="text-sm text-gray-500">Keine Meilensteine definiert.</p>
                <% } else if (!timelineStart || !timelineEnd) { %>
                <div class="milestone-board__missing-dates">Fuer die Projektzeitleiste fehlen Start- oder Enddatum.</div>
                <% } else { %>
                <div id="visTimeline" class="vis-timeline-container"></div>
                <script>
                  (function () {
                    var container = document.getElementById('visTimeline');
                    if (!container || typeof vis === 'undefined') return;
                    var items = new vis.DataSet(<%- JSON.stringify(timelineItems) %>);
                    var projectStart = '<%= project.start_date || timelineStart.toISOString().slice(0,10) %>';
                    var projectEnd = '<%= project.end_date || timelineEnd.toISOString().slice(0,10) %>';
                    var options = {
                      stack: true,
                      stackSubgroups: true,
                      orientation: { axis: 'bottom', item: 'top' },
                      min: projectStart,
                      max: projectEnd,
                      start: projectStart,
                      end: projectEnd,
                      zoomMin: 1000 * 60 * 60 * 24 * 7,
                      zoomMax: 1000 * 60 * 60 * 24 * 365 * 5,
                      margin: { item: 10, axis: 10 },
                      locale: 'de',
                      showCurrentTime: true,
                      tooltip: { followMouse: true },
                      height: '320px'
                    };
                    var timeline = new vis.Timeline(container, items, options);
                    timeline.on('select', function (props) {
                      if (!props.items || !props.items.length) return;
                      var selected = items.get(props.items[0]);
                      if (selected && selected.link) {
                        var target = document.querySelector(selected.link);
                        if (target) target.scrollIntoView({ behavior: 'smooth', block: 'start' });
                      } else if (selected && /^milestone-/.test(selected.id)) {
                        var anchor = document.getElementById('timeline-' + selected.id);
                        if (anchor) anchor.scrollIntoView({ behavior: 'smooth', block: 'start' });
                      }
                    });
                  })();
                </script>

                <div class="milestone-board__milestone-summary mt-6">
                    <% milestones.forEach((milestone) => { %>
                    <article class="milestone-board__summary-card" id="timeline-milestone-<%= milestone.id %>">
                        <div>
                            <h2 class="milestone-board__summary-title"><%= milestone.title %></h2>
                            <p class="milestone-board__summary-meta"><%= formatDate(milestone.start_date) %> bis <%= formatDate(milestone.end_date) %></p>
                        </div>
                        <span class="badge text-xs <%= milestone.status === 'completed' ? 'bg-green-100 text-green-800' : milestone.status === 'in_progress' ? 'bg-blue-100 text-blue-800' : milestone.status === 'blocked' ? 'bg-red-100 text-red-800' : 'bg-gray-100 text-gray-600' %>"><%= {pending:'Offen',in_progress:'In Arbeit',completed:'Erledigt',blocked:'Blockiert'}[milestone.status] %></span>
                    </article>
                    <% }); %>
                </div>
                <% } %>
            </div>
        </div>

        <% if (milestonesWithSteps.length > 0) { %>
        <div class="card mb-6">
            <div class="card-header"><h2 class="text-lg font-semibold text-gray-900">Step-Details</h2></div>
            <div class="card-body">
                <div class="timeline-step-details">
                    <% milestonesWithSteps.forEach((milestone) => { %>
                    <% (milestone.steps || []).forEach((step) => { %>
                    <article id="timeline-step-<%= step.id %>" class="timeline-step-card">
                        <div class="timeline-step-card__header">
                            <div>
                                <p class="timeline-step-card__eyebrow"><%= milestone.title %></p>
                                <h3 class="timeline-step-card__title"><%= step.title || ('Step ' + step.id) %></h3>
                            </div>
                            <span class="timeline-step-card__date"><%= formatDate(step.date) %></span>
                        </div>
                        <p class="timeline-step-card__text"><%= step.text || 'Keine Beschreibung hinterlegt.' %></p>
                        <% if ((step.blobs || []).length > 0) { %>
                        <div class="timeline-step-card__attachments">
                            <h4 class="timeline-step-card__attachments-title">Dateien</h4>
                            <ul class="timeline-step-card__attachments-list">
                                <% step.blobs.forEach((blob) => { %>
                                <li>
                                    <a class="timeline-step-card__attachment-link" href="/api/milestones/<%= milestone.id %>/steps/<%= step.id %>/attachments/<%= blob.id %>"><%= blob.filename %></a>
                                    <span class="timeline-step-card__attachment-size"><%= blob.size || 0 %> Bytes</span>
                                </li>
                                <% }); %>
                            </ul>
                        </div>
                        <% } %>
                    </article>
                    <% }); %>
                    <% }); %>
                </div>
            </div>
        </div>
        <% } %>

        <div class="card">
            <div class="card-header"><h2 class="text-lg font-semibold text-gray-900">Meilensteine</h2></div>
            <div class="card-body p-0">
                <div class="overflow-x-auto">
                    <table class="min-w-full divide-y divide-gray-200">
                        <thead class="bg-gray-50">
                            <tr>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Titel</th>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Phase</th>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Start</th>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Ende</th>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Status</th>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Step-Links</th>
                                <% if (canManage) { %><th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Pflege</th><% } %>
                            </tr>
                        </thead>
                        <tbody class="bg-white divide-y divide-gray-200">
                            <% milestones.forEach((milestone) => { %>
                            <tr>
                                <td class="px-6 py-4 text-sm font-medium text-gray-900">
                                    <span class="w-3 h-3 rounded-full inline-block mr-2" style="background:<%= milestone.color || '#2563eb' %>"></span><%= milestone.title %>
                                </td>
                                <td class="px-6 py-4 text-sm text-gray-500"><%= milestone.phase ? 'Phase ' + milestone.phase : '-' %></td>
                                <td class="px-6 py-4 text-sm text-gray-500"><%= milestone.start_date ? new Date(milestone.start_date).toLocaleDateString('de-DE') : '-' %></td>
                                <td class="px-6 py-4 text-sm text-gray-500"><%= milestone.end_date ? new Date(milestone.end_date).toLocaleDateString('de-DE') : '-' %></td>
                                <td class="px-6 py-4"><span class="badge text-xs <%= milestone.status === 'completed' ? 'bg-green-100 text-green-800' : milestone.status === 'in_progress' ? 'bg-blue-100 text-blue-800' : milestone.status === 'blocked' ? 'bg-red-100 text-red-800' : 'bg-gray-100 text-gray-600' %>"><%= {pending:'Offen',in_progress:'In Arbeit',completed:'Erledigt',blocked:'Blockiert'}[milestone.status] %></span></td>
                                <td class="px-6 py-4 text-sm text-gray-700">
                                    <% if ((milestone.steps || []).length > 0) { %>
                                        <% milestone.steps.forEach((step, index) => { %>
                                            <a href="#timeline-step-<%= step.id %>" class="text-primary-700 hover:text-primary-900 hover:underline"><%= step.title || ('Step ' + step.id) %></a><%= index < milestone.steps.length - 1 ? ', ' : '' %>
                                        <% }); %>
                                    <% } else { %>
                                        <span class="text-gray-400">Keine Steps</span>
                                    <% } %>
                                </td>
                                <% if (canManage) { %>
                                <td class="px-6 py-4 text-sm">
                                    <a href="/project/<%= project.id %>/milestones#milestone-<%= milestone.id %>" class="text-primary-700 hover:text-primary-900 hover:underline">Steps verwalten</a>
                                </td>
                                <% } %>
                            </tr>
                            <% }); %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </main>
</body>
</html>
