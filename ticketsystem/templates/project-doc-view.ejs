<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= doc.title %> - <%= project.name %> | Ticketsystem</title>
    <link rel="stylesheet" href="/style.css?v=2">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/easymde/dist/easymde.min.css">
    <script src="https://cdn.jsdelivr.net/npm/mermaid@10/dist/mermaid.min.js"></script>
</head>
<body class="bg-gray-50 min-h-screen">
    <nav class="bg-white border-b border-gray-200 sticky top-0 z-50">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between h-16">
                <div class="flex items-center">
                    <div class="flex-shrink-0 flex items-center gap-2">
                        <div class="w-8 h-8 bg-primary-600 rounded-lg flex items-center justify-center">
                            <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 5v2m0 4v2m0 4v2M5 5a2 2 0 00-2 2v3a2 2 0 110 4v3a2 2 0 002 2h14a2 2 0 002-2v-3a2 2 0 110-4V7a2 2 0 00-2-2H5z"/>
                            </svg>
                        </div>
                        <a href="/" class="text-xl font-bold text-gray-900 hover:text-primary-600">Ticketsystem</a>
                    </div>
                    <div class="hidden md:ml-8 md:flex md:space-x-1">
                        <a href="/" class="nav-link">Dashboard</a>
                        <a href="/ticket/new" class="nav-link">Neues Ticket</a>
                        <a href="/projects" class="nav-link active">Projekte</a>
                        <% if (role === 'admin' || role === 'root') { %>
                        <a href="/stats" class="nav-link">Statistiken</a>
                        <a href="/admin/systems" class="nav-link">Systeme</a>
                        <a href="/admin/staff" class="nav-link">Mitarbeiter</a>
                        <% if (role === 'root') { %><a href="/admin/users" class="nav-link">Benutzer</a><% } %>
                        <% } %>
                    </div>
                </div>
                <div class="flex items-center gap-4">
                    <span class="text-sm text-gray-600"><%= user %> <span class="badge bg-gray-100 text-gray-700"><%= role %></span></span>
                    <a href="/account" class="btn-secondary text-sm">Account</a>
                    <a href="/logout" class="btn-secondary text-sm">Abmelden</a>
                </div>
            </div>
        </div>
    </nav>

    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        <nav class="flex mb-6" aria-label="Breadcrumb">
            <ol class="flex items-center space-x-4">
                <li><a href="/" class="text-gray-500 hover:text-gray-700">Dashboard</a></li>
                <li class="text-gray-400">/</li>
                <li><a href="/projects" class="text-gray-500 hover:text-gray-700">Projekte</a></li>
                <li class="text-gray-400">/</li>
                <li><a href="/project/<%= project.id %>" class="text-gray-500 hover:text-gray-700"><%= project.name %></a></li>
                <li class="text-gray-400">/</li>
                <li><a href="/project/<%= project.id %>/docs" class="text-gray-500 hover:text-gray-700">Wiki</a></li>
                <li class="text-gray-400">/</li>
                <li class="text-gray-900 font-medium"><%= doc.title %></li>
            </ol>
        </nav>

        <div class="flex items-center justify-between mb-6">
            <div>
                <h1 class="text-2xl font-bold text-gray-900"><%= doc.title %></h1>
                <p class="text-sm text-gray-500 mt-1">Zuletzt bearbeitet von <%= doc.updated_by || '-' %> am <%= doc.updated_at ? new Date(doc.updated_at).toLocaleString('de-DE') : '' %></p>
            </div>
            <% if (canManage) { %>
            <button onclick="toggleEdit()" class="btn-primary" id="editBtn">Bearbeiten</button>
            <% } %>
        </div>

        <div id="viewMode">
            <div class="card">
                <div class="card-body prose max-w-none">
                    <%- htmlContent %>
                </div>
            </div>
        </div>

        <% if (canManage) { %>
        <div id="editMode" class="hidden">
            <div class="card">
                <div class="card-body">
                    <div class="mb-4">
                        <label class="block text-sm font-medium text-gray-700 mb-1">Titel</label>
                        <input id="editTitle" class="form-input" value="<%= doc.title %>">
                    </div>
                    <div class="mb-4">
                        <label class="block text-sm font-medium text-gray-700 mb-1">Inhalt (Markdown)</label>
                        <textarea id="editContent" class="form-input font-mono" rows="20"><%- doc.content || '' %></textarea>
                    </div>
                    <div class="flex gap-2">
                        <button onclick="saveDoc()" class="btn-primary">Speichern</button>
                        <button onclick="toggleEdit()" class="btn-secondary">Abbrechen</button>
                    </div>
                </div>
            </div>
        </div>
        <% } %>
    </main>
    <script>
        var editing = false;
        function toggleEdit() {
            editing = !editing;
            document.getElementById('viewMode').classList.toggle('hidden', editing);
            document.getElementById('editMode').classList.toggle('hidden', !editing);
            document.getElementById('editBtn').textContent = editing ? 'Vorschau' : 'Bearbeiten';
        }
        async function saveDoc() {
            const title = document.getElementById('editTitle').value;
            const content = document.getElementById('editContent').value;
            const resp = await fetch('/api/docs/<%= doc.id %>', {
                method:'PATCH', headers:{'Content-Type':'application/json','X-CSRF-Token':'<%= csrfToken %>'},
                body:JSON.stringify({ title, content, slug: '<%= doc.slug %>' })
            });
            if (resp.ok) { location.reload(); }
            else { alert('Fehler: ' + (await resp.json()).error); }
        }
        mermaid.initialize({ startOnLoad: true, theme: 'default' });
    </script>
</body>
</html>
