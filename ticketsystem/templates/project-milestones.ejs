<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Meilensteine - <%= project.name %> | Ticketsystem</title>
    <link rel="stylesheet" href="/style.css?v=2">
</head>
<body class="bg-gray-50 min-h-screen">
    <nav class="bg-white border-b border-gray-200 sticky top-0 z-50">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between h-16">
                <div class="flex items-center">
                    <div class="flex-shrink-0 flex items-center gap-2">
                        <div class="w-8 h-8 bg-primary-600 rounded-lg flex items-center justify-center">
                            <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 5v2m0 4v2m0 4v2M5 5a2 2 0 00-2 2v3a2 2 0 110 4v3a2 2 0 002 2h14a2 2 0 002-2v-3a2 2 0 110-4V7a2 2 0 00-2-2H5z"/>
                            </svg>
                        </div>
                        <a href="/" class="text-xl font-bold text-gray-900 hover:text-primary-600">Ticketsystem</a>
                    </div>
                    <div class="hidden md:ml-8 md:flex md:space-x-1">
                        <a href="/" class="nav-link">Dashboard</a>
                        <a href="/ticket/new" class="nav-link">Neues Ticket</a>
                        <a href="/projects" class="nav-link active">Projekte</a>
                        <% if (role === 'admin' || role === 'root') { %>
                        <a href="/stats" class="nav-link">Statistiken</a>
                        <a href="/admin/systems" class="nav-link">Systeme</a>
                        <a href="/admin/staff" class="nav-link">Mitarbeiter</a>
                        <% if (role === 'root') { %><a href="/admin/users" class="nav-link">Benutzer</a><% } %>
                        <% } %>
                    </div>
                </div>
                <div class="flex items-center gap-4">
                    <span class="text-sm text-gray-600"><%= user %> <span class="badge bg-gray-100 text-gray-700"><%= role %></span></span>
                    <a href="/account" class="btn-secondary text-sm">Account</a>
                    <a href="/logout" class="btn-secondary text-sm">Abmelden</a>
                </div>
            </div>
        </div>
    </nav>

    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        <nav class="flex mb-6" aria-label="Breadcrumb">
            <ol class="flex items-center space-x-4">
                <li><a href="/" class="text-gray-500 hover:text-gray-700">Dashboard</a></li>
                <li class="text-gray-400">/</li>
                <li><a href="/projects" class="text-gray-500 hover:text-gray-700">Projekte</a></li>
                <li class="text-gray-400">/</li>
                <li><a href="/project/<%= project.id %>" class="text-gray-500 hover:text-gray-700"><%= project.name %></a></li>
                <li class="text-gray-400">/</li>
                <li class="text-gray-900 font-medium">Meilensteine</li>
            </ol>
        </nav>

        <div class="flex items-center justify-between mb-6">
            <h1 class="text-2xl font-bold text-gray-900">Meilensteine: <%= project.name %></h1>
            <% if (canManage) { %>
            <button onclick="toggleAddForm()" class="btn-primary">+ Meilenstein</button>
            <% } %>
        </div>

        <div class="flex flex-wrap gap-2 mb-6">
            <a href="/project/<%= project.id %>" class="btn-secondary text-sm">Dashboard</a>
            <a href="/project/<%= project.id %>/timeline" class="btn-secondary text-sm">Zeitleiste</a>
            <a href="/project/<%= project.id %>/milestones" class="btn-secondary text-sm font-medium bg-primary-50 text-primary-700">Meilensteine</a>
            <% if (canManage) { %><a href="/project/<%= project.id %>/keyusers" class="btn-secondary text-sm">Key-User</a><% } %>
            <a href="/project/<%= project.id %>/docs" class="btn-secondary text-sm">Wiki</a>
            <% if (canManage) { %><a href="/project/<%= project.id %>/github" class="btn-secondary text-sm">GitHub</a><% } %>
        </div>

        <% if (canManage) { %>
        <div id="addMilestoneForm" class="card mb-8 hidden">
            <div class="card-header"><h2 class="text-lg font-semibold text-gray-900">Neuer Meilenstein</h2></div>
            <div class="card-body">
                <form id="milestoneForm" onsubmit="createMilestone(event)" class="space-y-4">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div class="col-span-2">
                            <label class="block text-sm font-medium text-gray-700 mb-1">Titel *</label>
                            <input name="title" required class="form-input">
                        </div>
                        <div class="col-span-2">
                            <label class="block text-sm font-medium text-gray-700 mb-1">Beschreibung</label>
                            <textarea name="description" class="form-input" rows="2"></textarea>
                        </div>
                        <div><label class="block text-sm font-medium text-gray-700 mb-1">Phase</label>
                            <select name="phase" class="form-input"><option value="">Keine</option><option value="1">1</option><option value="2">2</option><option value="3">3</option></select></div>
                        <div><label class="block text-sm font-medium text-gray-700 mb-1">Status</label>
                            <select name="status" class="form-input"><option value="pending">Offen</option><option value="in_progress">In Arbeit</option><option value="completed">Erledigt</option><option value="blocked">Blockiert</option></select></div>
                        <div><label class="block text-sm font-medium text-gray-700 mb-1">Startdatum</label><input type="date" name="start_date" class="form-input"></div>
                        <div><label class="block text-sm font-medium text-gray-700 mb-1">Enddatum</label><input type="date" name="end_date" class="form-input"></div>
                        <div><label class="block text-sm font-medium text-gray-700 mb-1">Farbe</label><input type="color" name="color" value="#2563eb" class="form-input h-10"></div>
                    </div>
                    <button type="submit" class="btn-primary">Meilenstein hinzufügen</button>
                </form>
            </div>
        </div>
        <% } %>

        <div class="card">
            <div class="card-header"><h2 class="text-lg font-semibold text-gray-900">Alle Meilensteine</h2></div>
            <div class="card-body p-0">
                <div class="overflow-x-auto">
                    <table class="min-w-full divide-y divide-gray-200">
                        <thead class="bg-gray-50">
                            <tr>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Titel</th>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Phase</th>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Start</th>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Ende</th>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Status</th>
                                <% if (canManage) { %><th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Aktionen</th><% } %>
                            </tr>
                        </thead>
                        <tbody class="bg-white divide-y divide-gray-200">
                            <% milestones.forEach(m => { %>
                            <tr class="cursor-pointer hover:bg-gray-50" onclick="toggleMilestoneDetail(<%= m.id %>)" data-milestone='<%- JSON.stringify({id:m.id,title:m.title,description:m.description||"",phase:m.phase||"",start_date:m.start_date||"",end_date:m.end_date||"",status:m.status,color:m.color||"#2563eb"}) %>'>
                                <td class="px-6 py-4 text-sm font-medium text-gray-900">
                                    <span class="w-3 h-3 rounded-full inline-block mr-2" style="background:<%= m.color || '#2563eb' %>"></span><%= m.title %>
                                    <% if (m.description) { %><span class="text-xs text-gray-400 ml-1">ⓘ</span><% } %>
                                </td>
                                <td class="px-6 py-4 text-sm text-gray-500"><%= m.phase ? 'Phase ' + m.phase : '-' %></td>
                                <td class="px-6 py-4 text-sm text-gray-500"><%= m.start_date ? new Date(m.start_date).toLocaleDateString('de-DE') : '-' %></td>
                                <td class="px-6 py-4 text-sm text-gray-500"><%= m.end_date ? new Date(m.end_date).toLocaleDateString('de-DE') : '-' %></td>
                                <td class="px-6 py-4"><span class="badge text-xs <%= m.status === 'completed' ? 'bg-green-100 text-green-800' : m.status === 'in_progress' ? 'bg-blue-100 text-blue-800' : m.status === 'blocked' ? 'bg-red-100 text-red-800' : 'bg-gray-100 text-gray-600' %>"><%= {pending:'Offen',in_progress:'In Arbeit',completed:'Erledigt',blocked:'Blockiert'}[m.status] %></span></td>
                                <% if (canManage) { %>
                                <td class="px-6 py-4 text-sm" onclick="event.stopPropagation()">
                                    <select onchange="updateStatus(<%= m.id %>, this.value)" class="text-xs form-input py-1">
                                        <option value="pending" <%= m.status === 'pending' ? 'selected' : '' %>>Offen</option>
                                        <option value="in_progress" <%= m.status === 'in_progress' ? 'selected' : '' %>>In Arbeit</option>
                                        <option value="completed" <%= m.status === 'completed' ? 'selected' : '' %>>Erledigt</option>
                                        <option value="blocked" <%= m.status === 'blocked' ? 'selected' : '' %>>Blockiert</option>
                                    </select>
                                    <button onclick="editMilestoneFromData(this.closest('tr'))" class="text-primary-600 hover:text-primary-800 ml-2">Bearbeiten</button>
                                    <button onclick="deleteMilestone(<%= m.id %>)" class="text-red-600 hover:text-red-900 ml-2">Löschen</button>
                                </td>
                                <% } %>
                            </tr>
                            <tr id="detail-<%= m.id %>" class="hidden bg-gray-50">
                                <td colspan="<%= canManage ? 6 : 5 %>" class="px-6 py-4">
                                    <div class="text-sm text-gray-700 whitespace-pre-wrap"><%= m.description ? m.description : '' %><% if (!m.description) { %><span class="text-gray-400 italic">Keine Beschreibung</span><% } %></div>
                                </td>
                            </tr>
                            <% }); %>
                            <% if (milestones.length === 0) { %>
                            <tr><td colspan="<%= canManage ? 6 : 5 %>" class="px-6 py-8 text-center text-gray-500">Keine Meilensteine definiert.</td></tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
        
        <% if (canManage) { %>
        <!-- Edit Milestone Modal -->
        <div id="editModal" class="hidden fixed inset-0 bg-black bg-opacity-50 z-50 flex items-center justify-center">
            <div class="card max-w-lg w-full mx-4">
                <div class="card-header flex items-center justify-between">
                    <h2 class="text-lg font-semibold text-gray-900">Meilenstein bearbeiten</h2>
                    <button onclick="closeEditModal()" class="text-gray-400 hover:text-gray-600 text-xl">&times;</button>
                </div>
                <div class="card-body">
                    <form id="editForm" onsubmit="saveMilestone(event)" class="space-y-4">
                        <input type="hidden" id="editId">
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">Titel *</label>
                            <input id="editTitle" name="title" required class="form-input">
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">Beschreibung</label>
                            <textarea id="editDescription" name="description" class="form-input" rows="3"></textarea>
                        </div>
                        <div class="grid grid-cols-2 gap-4">
                            <div><label class="block text-sm font-medium text-gray-700 mb-1">Phase</label>
                                <select id="editPhase" name="phase" class="form-input"><option value="">Keine</option><option value="1">1</option><option value="2">2</option><option value="3">3</option></select></div>
                            <div><label class="block text-sm font-medium text-gray-700 mb-1">Status</label>
                                <select id="editStatus" name="status" class="form-input"><option value="pending">Offen</option><option value="in_progress">In Arbeit</option><option value="completed">Erledigt</option><option value="blocked">Blockiert</option></select></div>
                            <div><label class="block text-sm font-medium text-gray-700 mb-1">Startdatum</label><input type="date" id="editStartDate" name="start_date" class="form-input"></div>
                            <div><label class="block text-sm font-medium text-gray-700 mb-1">Enddatum</label><input type="date" id="editEndDate" name="end_date" class="form-input"></div>
                        </div>
                        <div><label class="block text-sm font-medium text-gray-700 mb-1">Farbe</label><input type="color" id="editColor" name="color" class="form-input h-10"></div>
                        <div class="flex gap-2">
                            <button type="submit" class="btn-primary">Speichern</button>
                            <button type="button" onclick="closeEditModal()" class="btn-secondary">Abbrechen</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
        <% } %>
    </main>
    <script>
        function toggleAddForm() { document.getElementById('addMilestoneForm').classList.toggle('hidden'); }
        function toggleMilestoneDetail(id) {
            document.getElementById('detail-' + id).classList.toggle('hidden');
        }
        function editMilestoneFromData(tr) {
            const data = JSON.parse(tr.dataset.milestone);
            editMilestone(data.id, data.title, data.description, data.phase, data.start_date, data.end_date, data.status, data.color);
        }
        function editMilestone(id, title, description, phase, startDate, endDate, status, color) {
            document.getElementById('editId').value = id;
            document.getElementById('editTitle').value = title;
            document.getElementById('editDescription').value = description;
            document.getElementById('editPhase').value = phase;
            document.getElementById('editStartDate').value = startDate;
            document.getElementById('editEndDate').value = endDate;
            document.getElementById('editStatus').value = status;
            document.getElementById('editColor').value = color;
            document.getElementById('editModal').classList.remove('hidden');
        }
        function closeEditModal() {
            document.getElementById('editModal').classList.add('hidden');
        }
        async function saveMilestone(e) {
            e.preventDefault();
            const id = document.getElementById('editId').value;
            const body = {
                title: document.getElementById('editTitle').value,
                description: document.getElementById('editDescription').value,
                phase: document.getElementById('editPhase').value ? parseInt(document.getElementById('editPhase').value) : null,
                start_date: document.getElementById('editStartDate').value || null,
                end_date: document.getElementById('editEndDate').value || null,
                status: document.getElementById('editStatus').value,
                color: document.getElementById('editColor').value
            };
            const resp = await fetch('/api/milestones/' + id, {
                method:'PATCH', headers:{'Content-Type':'application/json','X-CSRF-Token':'<%= csrfToken %>'}, body:JSON.stringify(body)
            });
            if (resp.ok) location.reload();
            else alert('Fehler: ' + (await resp.json()).error);
        }
        async function createMilestone(e) {
            e.preventDefault();
            const fd = new FormData(e.target);
            const body = Object.fromEntries(fd);
            body.phase = body.phase ? parseInt(body.phase) : null;
            const resp = await fetch('/api/projects/<%= project.id %>/milestones', {
                method:'POST', headers:{'Content-Type':'application/json','X-CSRF-Token':'<%= csrfToken %>'}, body:JSON.stringify(body)
            });
            if (resp.ok) location.reload();
            else alert('Fehler: ' + (await resp.json()).error);
        }
        async function updateStatus(id, status) {
            const resp = await fetch('/api/milestones/' + id, {
                method:'PATCH', headers:{'Content-Type':'application/json','X-CSRF-Token':'<%= csrfToken %>'}, body:JSON.stringify({status})
            });
            if (resp.ok) location.reload();
        }
        async function deleteMilestone(id) {
            if (!confirm('Meilenstein wirklich löschen?')) return;
            const resp = await fetch('/api/milestones/' + id, { method:'DELETE', headers:{'X-CSRF-Token':'<%= csrfToken %>'} });
            if (resp.ok) location.reload();
            else alert('Fehler beim Löschen');
        }
        // Close modal on background click
        document.getElementById('editModal').addEventListener('click', function(e) { if (e.target === this) closeEditModal(); });
    </script>
</body>
</html>
