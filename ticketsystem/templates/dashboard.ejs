<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Ticketsystem - Dashboard</title>
    <link rel="stylesheet" href="/style.css?v=2">
    <script src="/socket.io/socket.io.js"></script>
</head>
<body class="bg-gray-50 min-h-screen">
    <!-- Navigation -->
    <nav class="bg-white border-b border-gray-200 sticky top-0 z-50">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between h-16">
                <div class="flex items-center">
                    <div class="flex-shrink-0 flex items-center gap-2">
                        <div class="w-8 h-8 bg-primary-600 rounded-lg flex items-center justify-center">
                            <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 5v2m0 4v2m0 4v2M5 5a2 2 0 00-2 2v3a2 2 0 110 4v3a2 2 0 002 2h14a2 2 0 002-2v-3a2 2 0 110-4V7a2 2 0 00-2-2H5z"/>
                            </svg>
                        </div>
                        <span class="text-xl font-bold text-gray-900">Ticketsystem</span>
                    </div>
                    <div class="hidden md:ml-8 md:flex md:space-x-1">
                        <a href="/" class="nav-link active">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"/>
                            </svg>
                            Dashboard
                        </a>
                        <% if (role === 'admin' || role === 'root') { %>
                        <a href="/stats" class="nav-link">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 3.055A9.001 9.001 0 1020.945 13H11V3.055z"/>
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.488 9H15V3.512A9.025 9.025 0 0120.488 9z"/>
                            </svg>
                            Statistiken
                        </a>
                        <% } %>
                        <a href="/ticket/new" class="nav-link">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
                            </svg>
                            Neues Ticket
                        </a>
                        <a href="/admin/systems" class="nav-link">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/>
                            </svg>
                            Systeme
                        </a>
                        <a href="/admin/staff" class="nav-link">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/>
                            </svg>
                            Mitarbeiter
                        </a>
                        <% if (role === 'root') { %>
                        <a href="/admin/users" class="nav-link">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5.121 17.804A13.937 13.937 0 0112 16c2.5 0 4.847.655 6.879 1.804M15 10a3 3 0 11-6 0 3 3 0 016 0m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                            </svg>
                            Benutzer
                        </a>
                        <% } %>
                    </div>
                </div>
                <div class="flex items-center gap-4">
                    <span class="text-sm text-gray-600"><%= user %> <span class="badge bg-gray-100 text-gray-700"><%= role %></span></span>
                    <a href="/account" class="btn-secondary text-sm">Account</a>
                    <a href="/logout" class="btn-secondary text-sm">Abmelden</a>
                </div>
            </div>
        </div>
    </nav>

    <!-- Main Content -->
    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        <!-- Stats Grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
            <% const statColors = { offen: 'bg-amber-50 border-amber-200', in_bearbeitung: 'bg-blue-50 border-blue-200', wartend: 'bg-purple-50 border-purple-200', geschlossen: 'bg-green-50 border-green-200' }; %>
            <% const statIcons = { offen: '📋', in_bearbeitung: '🔧', wartend: '⏳', geschlossen: '✅' }; %>
            <% stats.forEach(s => { %>
            <div class="card <%= statColors[s.status] || 'bg-white' %> border">
                <div class="card-body">
                    <div class="flex items-center justify-between">
                        <div>
                            <p class="text-sm font-medium text-gray-600"><%= toTitle(s.status) %></p>
                            <p class="text-3xl font-bold text-gray-900 mt-1"><%= s.count %></p>
                        </div>
                        <div class="text-3xl"><%= statIcons[s.status] || '📊' %></div>
                    </div>
                </div>
            </div>
            <% }); %>
            
            <!-- SLA Stats -->
            <div class="card bg-red-50 border-red-200 border">
                <div class="card-body">
                    <div class="flex items-center justify-between">
                        <div>
                            <p class="text-sm font-medium text-red-600">SLA Verletzungen</p>
                            <p class="text-3xl font-bold text-red-900 mt-1"><%= (slaStats.fr_breached || 0) + (slaStats.res_breached || 0) %></p>
                        </div>
                        <div class="text-3xl">⚠️</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Alerts Section -->
        <% if (overdue.length > 0 || dueSoon.length > 0) { %>
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-8">
            <% if (overdue.length > 0) { %>
            <div class="card border-red-200">
                <div class="card-header bg-red-50 border-red-200">
                    <h3 class="text-lg font-semibold text-red-900 flex items-center gap-2">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                        </svg>
                        Frist überschritten (<%= overdue.length %>)
                    </h3>
                </div>
                <div class="card-body">
                    <ul class="space-y-3">
                        <% overdue.slice(0, 5).forEach(t => { %>
                        <li class="flex items-start gap-3">
                            <span class="flex-shrink-0 w-2 h-2 bg-red-500 rounded-full mt-2"></span>
                            <div class="flex-1 min-w-0">
                                <a href="/ticket/<%= t.id %>" class="text-sm font-medium text-gray-900 hover:text-primary-600 truncate block">
                                    #<%= t.id %> <%= t.title %>
                                </a>
                                <p class="text-xs text-red-600 mt-0.5"><%= t.reminder.message %></p>
                            </div>
                        </li>
                        <% }); %>
                    </ul>
                </div>
            </div>
            <% } %>

            <% if (dueSoon.length > 0) { %>
            <div class="card border-amber-200">
                <div class="card-header bg-amber-50 border-amber-200">
                    <h3 class="text-lg font-semibold text-amber-900 flex items-center gap-2">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/>
                        </svg>
                        Frist läuft bald ab (<%= dueSoon.length %>)
                    </h3>
                </div>
                <div class="card-body">
                    <ul class="space-y-3">
                        <% dueSoon.slice(0, 5).forEach(t => { %>
                        <li class="flex items-start gap-3">
                            <span class="flex-shrink-0 w-2 h-2 bg-amber-500 rounded-full mt-2"></span>
                            <div class="flex-1 min-w-0">
                                <a href="/ticket/<%= t.id %>" class="text-sm font-medium text-gray-900 hover:text-primary-600 truncate block">
                                    #<%= t.id %> <%= t.title %>
                                </a>
                                <p class="text-xs text-amber-600 mt-0.5"><%= t.reminder.message %></p>
                            </div>
                        </li>
                        <% }); %>
                    </ul>
                </div>
            </div>
            <% } %>
        </div>
        <% } %>

        <!-- Recent Activity -->
        <% if (recentActivity && recentActivity.length > 0) { %>
        <div class="card mb-8">
            <div class="card-header">
                <h3 class="text-lg font-semibold text-gray-900 flex items-center gap-2">
                    <svg class="w-5 h-5 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
                    </svg>
                    Aktuelle Aktivitäten
                </h3>
            </div>
            <div class="card-body">
                <div class="flow-root">
                    <ul class="-mb-8">
                        <% recentActivity.forEach((activity, index) => { %>
                        <li class="relative pb-8">
                            <div class="relative flex items-start space-x-3">
                                <div class="relative">
                                    <div class="h-8 w-8 rounded-full bg-primary-100 flex items-center justify-center ring-8 ring-white">
                                        <span class="text-xs font-medium text-primary-700"><%= activity.actor ? activity.actor.charAt(0).toUpperCase() : 'S' %></span>
                                    </div>
                                </div>
                                <div class="min-w-0 flex-1">
                                    <div>
                                        <div class="text-sm">
                                            <span class="font-medium text-gray-900"><%= activity.actor || 'System' %></span>
                                            <span class="text-gray-500"> - <%= activity.action_text %></span>
                                        </div>
                                        <p class="mt-0.5 text-xs text-gray-500">
                                            <%= formatDateTime(activity.created_at) %>
                                        </p>
                                    </div>
                                    <% if (activity.ticket_id) { %>
                                    <div class="mt-1">
                                        <a href="/ticket/<%= activity.ticket_id %>" class="text-xs text-primary-600 hover:text-primary-800">
                                            Ticket #<%= activity.ticket_id %> <%= activity.ticket_title ? '- ' + activity.ticket_title : '' %>
                                        </a>
                                    </div>
                                    <% } %>
                                </div>
                            </div>
                        </li>
                        <% }); %>
                    </ul>
                </div>
            </div>
        </div>
        <% } %>

        <!-- Quick Actions -->
        <div class="flex flex-wrap gap-4 mb-8">
            <a href="/ticket/new" class="btn-primary">
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
                </svg>
                Neues Ticket erstellen
            </a>
            <% if (staffId) { %>
            <% if (myTickets) { %>
            <a href="/" class="btn-secondary">
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 10h16M4 14h16M4 18h16"/>
                </svg>
                Alle Tickets anzeigen
            </a>
            <% } else { %>
            <a href="/?my_tickets=1" class="btn-secondary">
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                </svg>
                Meine Tickets
            </a>
            <% } %>
            <% } %>
            <a href="/admin/systems" class="btn-secondary">
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/>
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                </svg>
                Systeme verwalten
            </a>
        </div>
        <% if (myTickets) { %>
        <div class="mb-4 p-3 bg-blue-50 border border-blue-200 rounded-lg text-sm text-blue-700 flex items-center gap-2">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            Persönliche Ansicht: Nur Ihre zugewiesenen Tickets werden angezeigt.
        </div>
        <% } %>

        <!-- Tickets Table -->
        <% if (tickets && tickets.length > 0) { %>
        <div class="card mb-8">
            <div class="card-header">
                <h3 class="text-lg font-semibold text-gray-900">Alle Tickets (<%= tickets.length %>)</h3>
            </div>
            <div class="card-body p-0">
                <div class="overflow-x-auto">
                    <table class="min-w-full divide-y divide-gray-200">
                        <thead class="bg-gray-50">
                            <tr>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">ID</th>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Typ</th>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Titel</th>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Priorität</th>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Zugewiesen</th>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Erstellt</th>
                            </tr>
                        </thead>
                        <tbody class="bg-white divide-y divide-gray-200">
                            <% tickets.forEach(t => { %>
                            <tr class="hover:bg-gray-50">
                                <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-primary-600">
                                    <a href="/ticket/<%= t.id %>">#<%= t.id %></a>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <span class="badge badge-type-<%= t.type %>"><%= (t.type||'').toUpperCase() %></span>
                                </td>
                                <td class="px-6 py-4 text-sm text-gray-900">
                                    <a href="/ticket/<%= t.id %>" class="hover:text-primary-600"><%= t.title %></a>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <span class="badge badge-status-<%= t.status %>"><%= toTitle(t.status) %></span>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <span class="badge badge-priority-<%= t.priority %>"><%= toTitle(t.priority) %></span>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                                    <%= t.assigned_name || 'Nicht zugewiesen' %>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                                    <%= formatDateTime(t.created_at) %>
                                </td>
                            </tr>
                            <% }); %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
        <% } else { %>
        <div class="card mb-8">
            <div class="card-body text-center py-12">
                <svg class="w-12 h-12 text-gray-300 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
                </svg>
                <h3 class="text-lg font-medium text-gray-900 mb-2">Keine Tickets vorhanden</h3>
                <p class="text-gray-500 mb-4">Erstellen Sie Ihr erstes Ticket, um zu beginnen.</p>
                <a href="/ticket/new" class="btn-primary">Neues Ticket erstellen</a>
            </div>
        </div>
        <% } %>

        <!-- Feedback Stats -->
        <% if (feedbackStats && feedbackStats.count > 0) { %>
        <div class="card">
            <div class="card-header">
                <h3 class="text-lg font-semibold text-gray-900">Feedback Übersicht</h3>
            </div>
            <div class="card-body">
                <div class="flex items-center gap-4">
                    <div class="flex items-center">
                        <% const avgRating = Math.round(feedbackStats.avg_rating || 0); %>
                        <% for(let i = 1; i <= 5; i++) { %>
                        <svg class="w-6 h-6 <%= i <= avgRating ? 'text-yellow-400' : 'text-gray-300' %>" fill="currentColor" viewBox="0 0 20 20">
                            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                        </svg>
                        <% } %>
                    </div>
                    <div class="text-sm text-gray-600">
                        <span class="font-medium text-gray-900"><%= feedbackStats.avg_rating ? feedbackStats.avg_rating.toFixed(1) : '0.0' %></span> / 5.0 
                        <span class="text-gray-400">(<%= feedbackStats.count %> Bewertungen)</span>
                    </div>
                </div>
            </div>
        </div>
        <% } %>
    </main>

    <script>
        // Socket.io für Echtzeit-Updates
        const socket = io();
        
        socket.on('activity', (data) => {
            // Seite neu laden bei neuer Aktivität
            location.reload();
        });
    </script>
</body>
</html>
