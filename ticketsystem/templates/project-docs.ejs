<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Wiki - <%= project.name %> | Ticketsystem</title>
    <link rel="stylesheet" href="/style.css?v=2">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/easymde/dist/easymde.min.css">
</head>
<body class="bg-gray-50 min-h-screen">
    <nav class="bg-white border-b border-gray-200 sticky top-0 z-50">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between h-16">
                <div class="flex items-center">
                    <div class="flex-shrink-0 flex items-center gap-2">
                        <div class="w-8 h-8 bg-primary-600 rounded-lg flex items-center justify-center">
                            <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 5v2m0 4v2m0 4v2M5 5a2 2 0 00-2 2v3a2 2 0 110 4v3a2 2 0 002 2h14a2 2 0 002-2v-3a2 2 0 110-4V7a2 2 0 00-2-2H5z"/>
                            </svg>
                        </div>
                        <a href="/" class="text-xl font-bold text-gray-900 hover:text-primary-600">Ticketsystem</a>
                    </div>
                    <div class="hidden md:ml-8 md:flex md:space-x-1">
                        <a href="/" class="nav-link">Dashboard</a>
                        <a href="/ticket/new" class="nav-link">Neues Ticket</a>
                        <a href="/projects" class="nav-link active">Projekte</a>
                        <% if (role === 'admin' || role === 'root') { %>
                        <a href="/stats" class="nav-link">Statistiken</a>
                        <a href="/admin/systems" class="nav-link">Systeme</a>
                        <a href="/admin/staff" class="nav-link">Mitarbeiter</a>
                        <% if (role === 'root') { %><a href="/admin/users" class="nav-link">Benutzer</a><% } %>
                        <% } %>
                    </div>
                </div>
                <div class="flex items-center gap-4">
                    <span class="text-sm text-gray-600"><%= user %> <span class="badge bg-gray-100 text-gray-700"><%= role %></span></span>
                    <a href="/account" class="btn-secondary text-sm">Account</a>
                    <a href="/logout" class="btn-secondary text-sm">Abmelden</a>
                </div>
            </div>
        </div>
    </nav>

    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        <nav class="flex mb-6" aria-label="Breadcrumb">
            <ol class="flex items-center space-x-4">
                <li><a href="/" class="text-gray-500 hover:text-gray-700">Dashboard</a></li>
                <li class="text-gray-400">/</li>
                <li><a href="/projects" class="text-gray-500 hover:text-gray-700">Projekte</a></li>
                <li class="text-gray-400">/</li>
                <li><a href="/project/<%= project.id %>" class="text-gray-500 hover:text-gray-700"><%= project.name %></a></li>
                <li class="text-gray-400">/</li>
                <li class="text-gray-900 font-medium">Wiki</li>
            </ol>
        </nav>

        <div class="flex items-center justify-between mb-6">
            <h1 class="text-2xl font-bold text-gray-900">Wiki: <%= project.name %></h1>
            <% if (canManage) { %><button onclick="toggleNewDoc()" class="btn-primary">+ Neue Seite</button><% } %>
        </div>

        <div class="flex flex-wrap gap-2 mb-6">
            <a href="/project/<%= project.id %>" class="btn-secondary text-sm">Dashboard</a>
            <a href="/project/<%= project.id %>/timeline" class="btn-secondary text-sm">Zeitleiste</a>
            <% if (canManage) { %><a href="/project/<%= project.id %>/milestones" class="btn-secondary text-sm">Meilensteine</a><% } %>
            <% if (canManage) { %><a href="/project/<%= project.id %>/keyusers" class="btn-secondary text-sm">Key-User</a><% } %>
            <a href="/project/<%= project.id %>/docs" class="btn-secondary text-sm font-medium bg-primary-50 text-primary-700">Wiki</a>
            <% if (canManage) { %><a href="/project/<%= project.id %>/github" class="btn-secondary text-sm">GitHub</a><% } %>
        </div>

        <% if (canManage) { %>
        <div id="newDocForm" class="card mb-8 hidden">
            <div class="card-header"><h2 class="text-lg font-semibold text-gray-900">Neue Wiki-Seite</h2></div>
            <div class="card-body">
                <form id="docForm" onsubmit="createDoc(event)" class="space-y-4">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div><label class="block text-sm font-medium text-gray-700 mb-1">Titel *</label><input name="title" required class="form-input"></div>
                        <div><label class="block text-sm font-medium text-gray-700 mb-1">Slug *</label><input name="slug" required class="form-input" placeholder="einleitung, setup, etc."></div>
                    </div>
                    <button type="submit" class="btn-primary">Seite erstellen & bearbeiten</button>
                </form>
            </div>
        </div>
        <% } %>

        <div class="card">
            <div class="card-header"><h2 class="text-lg font-semibold text-gray-900">Wiki-Seiten</h2></div>
            <div class="card-body">
                <% if (docs.length === 0) { %><p class="text-gray-500">Keine Wiki-Seiten vorhanden.</p><% } %>
                <div class="space-y-2">
                    <% docs.forEach(d => { %>
                    <div class="flex items-center justify-between py-2 border-b border-gray-100 last:border-0">
                        <a href="/project/<%= project.id %>/docs/<%= d.slug %>" class="text-primary-600 hover:text-primary-800"><%= d.title %></a>
                        <div class="flex items-center gap-4 text-xs text-gray-500">
                            <span><%= d.updated_by || '-' %></span>
                            <span><%= d.updated_at ? new Date(d.updated_at).toLocaleDateString('de-DE') : '' %></span>
                            <% if (canManage) { %>
                            <button onclick="deleteDoc(<%= d.id %>)" class="text-red-600 hover:text-red-900">Löschen</button>
                            <% } %>
                        </div>
                    </div>
                    <% }); %>
                </div>
            </div>
        </div>
    </main>
    <script>
        function toggleNewDoc() { document.getElementById('newDocForm').classList.toggle('hidden'); }
        async function createDoc(e) {
            e.preventDefault();
            const fd = new FormData(e.target);
            const body = Object.fromEntries(fd);
            body.content = '# ' + body.title + '\n\nInhalt hier...';
            const resp = await fetch('/api/projects/<%= project.id %>/docs', {
                method:'POST', headers:{'Content-Type':'application/json','X-CSRF-Token':'<%= csrfToken %>'}, body:JSON.stringify(body)
            });
            if (resp.ok) location.reload();
            else alert('Fehler: ' + (await resp.json()).error);
        }
        async function deleteDoc(id) {
            if (!confirm('Wiki-Seite löschen?')) return;
            const resp = await fetch('/api/docs/' + id, { method:'DELETE', headers:{'X-CSRF-Token':'<%= csrfToken %>'} });
            if (resp.ok) location.reload();
            else alert('Fehler beim Löschen');
        }
    </script>
</body>
</html>
