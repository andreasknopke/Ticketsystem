<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Projekte | Ticketsystem</title>
    <link rel="stylesheet" href="/style.css?v=2">
    <script src="https://cdn.jsdelivr.net/npm/mermaid@10/dist/mermaid.min.js"></script>
</head>
<body class="bg-gray-50 min-h-screen">
    <nav class="bg-white border-b border-gray-200 sticky top-0 z-50">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between h-16">
                <div class="flex items-center">
                    <div class="flex-shrink-0 flex items-center gap-2">
                        <div class="w-8 h-8 bg-primary-600 rounded-lg flex items-center justify-center">
                            <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 5v2m0 4v2m0 4v2M5 5a2 2 0 00-2 2v3a2 2 0 110 4v3a2 2 0 002 2h14a2 2 0 002-2v-3a2 2 0 110-4V7a2 2 0 00-2-2H5z"/>
                            </svg>
                        </div>
                        <a href="/" class="text-xl font-bold text-gray-900 hover:text-primary-600">Ticketsystem</a>
                    </div>
                    <div class="hidden md:ml-8 md:flex md:space-x-1">
                        <a href="/" class="nav-link">Dashboard</a>
                        <a href="/ticket/new" class="nav-link">Neues Ticket</a>
                        <a href="/projects" class="nav-link active">Projekte</a>
                        <% if (role === 'admin' || role === 'root') { %>
                        <a href="/stats" class="nav-link">Statistiken</a>
                        <a href="/admin/systems" class="nav-link">Systeme</a>
                        <a href="/admin/staff" class="nav-link">Mitarbeiter</a>
                        <% if (role === 'root') { %><a href="/admin/users" class="nav-link">Benutzer</a><% } %>
                        <% } %>
                    </div>
                </div>
                <div class="flex items-center gap-4">
                    <span class="text-sm text-gray-600"><%= user %> <span class="badge bg-gray-100 text-gray-700"><%= role %></span></span>
                    <a href="/account" class="btn-secondary text-sm">Account</a>
                    <a href="/logout" class="btn-secondary text-sm">Abmelden</a>
                </div>
            </div>
        </div>
    </nav>

    <main class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        <nav class="flex mb-6" aria-label="Breadcrumb">
            <ol class="flex items-center space-x-4">
                <li><a href="/" class="text-gray-500 hover:text-gray-700">Dashboard</a></li>
                <li class="text-gray-400">/</li>
                <li class="text-gray-900 font-medium">Projekte</li>
            </ol>
        </nav>

        <div class="flex items-center justify-between mb-6">
            <h1 class="text-2xl font-bold text-gray-900">Projekte</h1>
            <% if (canManage) { %>
            <button onclick="toggleNewProject()" class="btn-primary">+ Neues Projekt</button>
            <% } %>
        </div>

        <% if (canManage) { %>
        <div id="newProjectForm" class="card mb-8 hidden">
            <div class="card-header"><h2 class="text-lg font-semibold text-gray-900">Neues Projekt</h2></div>
            <div class="card-body">
                <form method="post" action="/api/projects" id="createProjectForm" class="space-y-4">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div class="col-span-2">
                            <label class="block text-sm font-medium text-gray-700 mb-1">Name *</label>
                            <input name="name" placeholder="z.B. CuraFlow" required class="form-input">
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">Verknüpftes System</label>
                            <select name="system_id" class="form-input">
                                <option value="">Kein System</option>
                                <% systems.forEach(sys => { %><option value="<%= sys.id %>"><%= sys.name %></option><% }); %>
                            </select>
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">Status</label>
                            <select name="status" class="form-input">
                                <option value="proposed">Vorgeschlagen</option>
                                <option value="planning">Planung</option>
                                <option value="active">Aktiv</option>
                                <option value="maintenance">Wartung</option>
                                <option value="completed">Abgeschlossen</option>
                            </select>
                        </div>
                        <div class="col-span-2">
                            <label class="block text-sm font-medium text-gray-700 mb-1">Beschreibung</label>
                            <textarea name="description" class="form-input" rows="3"></textarea>
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">Startdatum</label>
                            <input type="date" name="start_date" class="form-input">
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">Enddatum</label>
                            <input type="date" name="end_date" class="form-input">
                        </div>
                        <div class="col-span-2">
                            <label class="block text-sm font-medium text-gray-700 mb-1">Dokumente anhängen</label>
                            <div class="flex items-center gap-2">
                                <input type="file" name="attachments" multiple class="block w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-md file:border-0 file:text-sm file:font-semibold file:bg-primary-50 file:text-primary-700 hover:file:bg-primary-100" accept=".pdf,.png,.jpg,.jpeg,.gif,.webp,.doc,.docx,.xls,.xlsx,.txt">
                            </div>
                            <p class="text-xs text-gray-400 mt-1">PDF, Bilder, Office-Dokumente – max. 20 MB pro Datei</p>
                        </div>
                    </div>
                    <button type="submit" class="btn-primary">Projekt erstellen</button>
                </form>
            </div>
        </div>
        <% } %>

        <% // Aktive Projekte (nicht vorgeschlagen) %>
        <% const activeProjects = projects.filter(p => p.status !== 'proposed'); %>
        <% const proposedProjects = projects.filter(p => p.status === 'proposed'); %>

        <% if (activeProjects.length > 0) { %>
        <div class="mb-8">
            <div class="flex items-center gap-2 mb-4">
                <svg class="w-5 h-5 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/>
                </svg>
                <h2 class="text-lg font-semibold text-gray-900">Aktive Projekte <span class="text-gray-400 font-normal">(<%= activeProjects.length %>)</span></h2>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <% activeProjects.forEach(p => { %>
                <a href="/project/<%= p.id %>" class="card hover:shadow-lg transition-shadow no-underline block <%= p.github_integration_id ? 'border-l-4 border-l-green-500' : '' %>">
                    <div class="card-body">
                        <div class="flex items-center justify-between mb-3">
                            <div class="flex items-center gap-2">
                                <h3 class="text-lg font-semibold text-gray-900"><%= p.name %></h3>
                                <% if (p.github_integration_id) { %>
                                <span class="badge bg-green-100 text-green-700 text-xs flex items-center gap-1" title="GitHub-Repository verbunden">
                                    <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
                                    GitHub
                                </span>
                                <% } %>
                            </div>
                            <span class="badge <%= p.status === 'active' ? 'bg-green-100 text-green-800' : p.status === 'planning' ? 'bg-blue-100 text-blue-800' : p.status === 'maintenance' ? 'bg-yellow-100 text-yellow-800' : p.status === 'completed' ? 'bg-gray-100 text-gray-800' : 'bg-gray-100 text-gray-800' %>">
                                <%= {planning:'Planung',active:'Aktiv',maintenance:'Wartung',completed:'Abgeschlossen'}[p.status] || p.status %>
                            </span>
                        </div>
                        <% if (p.system_name) { %><p class="text-sm text-primary-600 mb-2"><%= p.system_name %></p><% } %>
                        <p class="text-sm text-gray-600 mb-4"><%= p.description || 'Keine Beschreibung' %></p>
                        <div class="flex gap-4 text-sm text-gray-500">
                            <span title="Meilensteine"><svg class="w-4 h-4 inline mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg><%= p.completed_milestones || 0 %>/<%= p.milestone_count || 0 %></span>
                            <span title="Key-User"><svg class="w-4 h-4 inline mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg><%= p.key_user_count || 0 %></span>
                            <% if (p.attachment_count > 0) { %>
                            <span title="Anhänge"><svg class="w-4 h-4 inline mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.172 7l-6.586 6.586a2 2 0 102.828 2.828l6.414-6.586a4 4 0 00-5.656-5.656l-6.415 6.585a6 6 0 108.486 8.486L20.5 13"/></svg><%= p.attachment_count %></span>
                            <% } %>
                        </div>
                        <% if (p.milestone_count > 0) { %>
                        <div class="mt-3 bg-gray-200 rounded-full h-2">
                            <div class="bg-primary-600 rounded-full h-2" style="width:<%= Math.round((p.completed_milestones||0)/(p.milestone_count||1)*100) %>%"></div>
                        </div>
                        <% } %>
                    </div>
                </a>
                <% }); %>
            </div>
        </div>
        <% } %>

        <% if (proposedProjects.length > 0) { %>
        <div class="mb-8">
            <div class="flex items-center gap-2 mb-4">
                <svg class="w-5 h-5 text-amber-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/>
                </svg>
                <h2 class="text-lg font-semibold text-gray-900">Vorgeschlagene Projekte <span class="text-gray-400 font-normal">(<%= proposedProjects.length %>)</span></h2>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <% proposedProjects.forEach(p => { %>
                <a href="/project/<%= p.id %>" class="card hover:shadow-lg transition-shadow no-underline block border-2 border-dashed border-amber-200 bg-amber-50/40">
                    <div class="card-body">
                        <div class="flex items-center justify-between mb-3">
                            <h3 class="text-lg font-semibold text-gray-900"><%= p.name %></h3>
                            <span class="badge bg-amber-100 text-amber-800">Vorgeschlagen</span>
                        </div>
                        <% if (p.system_name) { %><p class="text-sm text-primary-600 mb-2"><%= p.system_name %></p><% } %>
                        <p class="text-sm text-gray-600 mb-4"><%= p.description || 'Keine Beschreibung' %></p>
                        <div class="flex gap-4 text-sm text-gray-500">
                            <% if (p.attachment_count > 0) { %>
                            <span title="Anhänge"><svg class="w-4 h-4 inline mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.172 7l-6.586 6.586a2 2 0 102.828 2.828l6.414-6.586a4 4 0 00-5.656-5.656l-6.415 6.585a6 6 0 108.486 8.486L20.5 13"/></svg><%= p.attachment_count %></span>
                            <% } %>
                        </div>
                    </div>
                </a>
                <% }); %>
            </div>
        </div>
        <% } %>
        <% if (projects.length === 0) { %>
        <div class="text-center py-12 text-gray-500">Keine Projekte vorhanden.</div>
        <% } %>
    </main>
    <script>
        function toggleNewProject() { document.getElementById('newProjectForm').classList.toggle('hidden'); }
        document.getElementById('createProjectForm')?.addEventListener('submit', async function(e) {
            e.preventDefault();
            const fd = new FormData(this);
            const body = Object.fromEntries(fd.entries());
            // Dateien separat hochladen
            const fileInput = this.querySelector('input[name="attachments"]');
            const files = fileInput ? Array.from(fileInput.files) : [];
            delete body.attachments;
            const resp = await fetch('/api/projects', { method:'POST', headers:{'Content-Type':'application/json','X-CSRF-Token':'<%= csrfToken %>'}, body:JSON.stringify(body) });
            if (!resp.ok) { alert('Fehler: ' + ((await resp.json().catch(() => ({}))).error || resp.statusText)); return; }
            const project = await resp.json();
            // Dateien hochladen falls vorhanden
            if (files.length > 0 && project.id) {
                const uploadFd = new FormData();
                files.forEach(f => uploadFd.append('attachments', f));
                await fetch('/api/projects/' + project.id + '/attachments', {
                    method:'POST', headers:{'X-CSRF-Token':'<%= csrfToken %>'}, body:uploadFd
                });
            }
            location.reload();
        });
    </script>
</body>
</html>
