<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Statistiken | Ticketsystem</title>
    <link rel="stylesheet" href="/style.css?v=2">
</head>
<body class="bg-gray-50 min-h-screen">
    <nav class="bg-white border-b border-gray-200 sticky top-0 z-50">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between h-16">
                <div class="flex items-center">
                    <div class="flex-shrink-0 flex items-center gap-2">
                        <div class="w-8 h-8 bg-primary-600 rounded-lg flex items-center justify-center">
                            <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 5v2m0 4v2m0 4v2M5 5a2 2 0 00-2 2v3a2 2 0 110 4v3a2 2 0 002 2h14a2 2 0 002-2v-3a2 2 0 110-4V7a2 2 0 00-2-2H5z"/>
                            </svg>
                        </div>
                        <a href="/" class="text-xl font-bold text-gray-900 hover:text-primary-600">Ticketsystem</a>
                    </div>
                    <div class="hidden md:ml-8 md:flex md:space-x-1">
                        <a href="/" class="nav-link">Dashboard</a>
                        <a href="/stats" class="nav-link active">Statistiken</a>
                        <a href="/ticket/new" class="nav-link">Neues Ticket</a>
                        <a href="/admin/systems" class="nav-link">Systeme</a>
                        <a href="/admin/staff" class="nav-link">Mitarbeiter</a>
                        <% if (role === 'root') { %>
                        <a href="/admin/users" class="nav-link">Benutzer</a>
                        <% } %>
                    </div>
                </div>
                <div class="flex items-center gap-4">
                    <span class="text-sm text-gray-600"><%= user %> <span class="badge bg-gray-100 text-gray-700"><%= role %></span></span>
                    <a href="/account" class="btn-secondary text-sm">Account</a>
                    <a href="/logout" class="btn-secondary text-sm">Abmelden</a>
                </div>
            </div>
        </div>
    </nav>

    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        <div class="mb-8 flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
            <div>
                <p class="text-sm font-semibold uppercase tracking-[0.2em] text-primary-600">Reporting</p>
                <h1 class="mt-1 text-3xl font-bold text-gray-900">Statistikbereich</h1>
                <p class="mt-2 max-w-3xl text-sm text-gray-500">Überblick über Ticketvolumen, Auslastung, SLA-Erfüllung, Reaktionszeiten, Lösungszeiten und Backlog-Risiken.</p>
            </div>
            <a href="/" class="btn-secondary text-sm">Zurück zum Dashboard</a>
        </div>

        <div class="grid grid-cols-1 gap-6 md:grid-cols-2 xl:grid-cols-4">
            <div class="card border border-slate-200 bg-white">
                <div class="card-body">
                    <p class="text-sm font-medium text-slate-500">Tickets gesamt</p>
                    <p class="mt-2 text-3xl font-bold text-slate-900"><%= totals.total || 0 %></p>
                    <p class="mt-2 text-xs text-slate-500"><%= totals.open_total || 0 %> offen · <%= totals.closed_total || 0 %> geschlossen</p>
                </div>
            </div>
            <div class="card border border-emerald-200 bg-emerald-50">
                <div class="card-body">
                    <p class="text-sm font-medium text-emerald-700">Abschlussquote</p>
                    <p class="mt-2 text-3xl font-bold text-emerald-900"><%= closedRate %>%</p>
                    <p class="mt-2 text-xs text-emerald-700">Anteil geschlossener Tickets</p>
                </div>
            </div>
            <div class="card border border-blue-200 bg-blue-50">
                <div class="card-body">
                    <p class="text-sm font-medium text-blue-700">Ø Reaktionszeit</p>
                    <p class="mt-2 text-3xl font-bold text-blue-900"><%= formatMinutes(responseStats.avg_response_minutes) %></p>
                    <p class="mt-2 text-xs text-blue-700">Erste dokumentierte Antwort</p>
                </div>
            </div>
            <div class="card border border-purple-200 bg-purple-50">
                <div class="card-body">
                    <p class="text-sm font-medium text-purple-700">Ø Resolvezeit</p>
                    <p class="mt-2 text-3xl font-bold text-purple-900"><%= formatMinutes(responseStats.avg_resolution_minutes) %></p>
                    <p class="mt-2 text-xs text-purple-700">Von Erstellung bis Lösung</p>
                </div>
            </div>
        </div>

        <div class="mt-6 grid grid-cols-1 gap-6 md:grid-cols-2 xl:grid-cols-4">
            <div class="card">
                <div class="card-body">
                    <p class="text-sm font-medium text-slate-500">SLA Reaktion erfüllt</p>
                    <p class="mt-2 text-3xl font-bold text-slate-900"><%= slaOverview.responseRate %>%</p>
                    <div class="mt-3 h-2 rounded-full bg-slate-100"><div class="h-2 rounded-full bg-blue-500" style="width: <%= Math.min(100, slaOverview.responseRate || 0) %>%"></div></div>
                    <p class="mt-2 text-xs text-slate-500"><%= slaOverview.responses_done || 0 %> beantwortete Tickets</p>
                </div>
            </div>
            <div class="card">
                <div class="card-body">
                    <p class="text-sm font-medium text-slate-500">SLA Lösung erfüllt</p>
                    <p class="mt-2 text-3xl font-bold text-slate-900"><%= slaOverview.resolutionRate %>%</p>
                    <div class="mt-3 h-2 rounded-full bg-slate-100"><div class="h-2 rounded-full bg-emerald-500" style="width: <%= Math.min(100, slaOverview.resolutionRate || 0) %>%"></div></div>
                    <p class="mt-2 text-xs text-slate-500"><%= slaOverview.resolutions_done || 0 %> gelöste Tickets</p>
                </div>
            </div>
            <div class="card">
                <div class="card-body">
                    <p class="text-sm font-medium text-slate-500">Offene Altlasten</p>
                    <p class="mt-2 text-3xl font-bold text-slate-900"><%= formatMinutes(responseStats.avg_open_age_minutes) %></p>
                    <p class="mt-2 text-xs text-slate-500">Ø Alter offener Tickets</p>
                </div>
            </div>
            <div class="card">
                <div class="card-body">
                    <p class="text-sm font-medium text-slate-500">Feedback</p>
                    <p class="mt-2 text-3xl font-bold text-slate-900"><%= feedbackStats.avg_rating ? Number(feedbackStats.avg_rating).toFixed(2) : '-' %> ★</p>
                    <p class="mt-2 text-xs text-slate-500"><%= feedbackStats.count || 0 %> Bewertungen</p>
                </div>
            </div>
        </div>

        <div class="mt-8 grid grid-cols-1 gap-8 xl:grid-cols-2">
            <section class="card">
                <div class="card-header"><h2 class="text-lg font-semibold text-gray-900">Tickets pro System</h2></div>
                <div class="card-body p-0">
                    <div class="overflow-x-auto">
                        <table class="min-w-full divide-y divide-gray-200">
                            <thead class="bg-gray-50">
                                <tr>
                                    <th class="px-4 py-3 text-left text-xs font-medium uppercase text-gray-500">System</th>
                                    <th class="px-4 py-3 text-right text-xs font-medium uppercase text-gray-500">Gesamt</th>
                                    <th class="px-4 py-3 text-right text-xs font-medium uppercase text-gray-500">Offen</th>
                                    <th class="px-4 py-3 text-right text-xs font-medium uppercase text-gray-500">Geschlossen</th>
                                    <th class="px-4 py-3 text-right text-xs font-medium uppercase text-gray-500">Ø Reaktion</th>
                                    <th class="px-4 py-3 text-right text-xs font-medium uppercase text-gray-500">Ø Resolve</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-gray-100 bg-white">
                                <% bySystem.forEach(row => { %>
                                <tr>
                                    <td class="px-4 py-3 text-sm font-medium text-gray-900"><%= row.name %></td>
                                    <td class="px-4 py-3 text-right text-sm text-gray-700"><%= row.total || 0 %></td>
                                    <td class="px-4 py-3 text-right text-sm text-amber-700"><%= row.open_total || 0 %></td>
                                    <td class="px-4 py-3 text-right text-sm text-emerald-700"><%= row.closed_total || 0 %></td>
                                    <td class="px-4 py-3 text-right text-sm text-gray-600"><%= formatMinutes(row.avg_response_minutes) %></td>
                                    <td class="px-4 py-3 text-right text-sm text-gray-600"><%= formatMinutes(row.avg_resolution_minutes) %></td>
                                </tr>
                                <% }); %>
                                <% if (!bySystem.length) { %><tr><td colspan="6" class="px-4 py-6 text-center text-sm text-gray-500">Keine Daten vorhanden.</td></tr><% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </section>

            <section class="card">
                <div class="card-header"><h2 class="text-lg font-semibold text-gray-900">Tickets pro Mitarbeiter</h2></div>
                <div class="card-body p-0">
                    <div class="overflow-x-auto">
                        <table class="min-w-full divide-y divide-gray-200">
                            <thead class="bg-gray-50">
                                <tr>
                                    <th class="px-4 py-3 text-left text-xs font-medium uppercase text-gray-500">Mitarbeiter</th>
                                    <th class="px-4 py-3 text-right text-xs font-medium uppercase text-gray-500">Gesamt</th>
                                    <th class="px-4 py-3 text-right text-xs font-medium uppercase text-gray-500">Offen</th>
                                    <th class="px-4 py-3 text-right text-xs font-medium uppercase text-gray-500">Überfällig</th>
                                    <th class="px-4 py-3 text-right text-xs font-medium uppercase text-gray-500">Ø Reaktion</th>
                                    <th class="px-4 py-3 text-right text-xs font-medium uppercase text-gray-500">Ø Resolve</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-gray-100 bg-white">
                                <% byStaff.forEach(row => { %>
                                <tr>
                                    <td class="px-4 py-3 text-sm font-medium text-gray-900"><%= row.name %></td>
                                    <td class="px-4 py-3 text-right text-sm text-gray-700"><%= row.total || 0 %></td>
                                    <td class="px-4 py-3 text-right text-sm text-amber-700"><%= row.open_total || 0 %></td>
                                    <td class="px-4 py-3 text-right text-sm text-red-700"><%= row.overdue_total || 0 %></td>
                                    <td class="px-4 py-3 text-right text-sm text-gray-600"><%= formatMinutes(row.avg_response_minutes) %></td>
                                    <td class="px-4 py-3 text-right text-sm text-gray-600"><%= formatMinutes(row.avg_resolution_minutes) %></td>
                                </tr>
                                <% }); %>
                                <% if (!byStaff.length) { %><tr><td colspan="6" class="px-4 py-6 text-center text-sm text-gray-500">Keine Daten vorhanden.</td></tr><% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </section>
        </div>

        <div class="mt-8 grid grid-cols-1 gap-8 xl:grid-cols-3">
            <section class="card xl:col-span-2">
                <div class="card-header"><h2 class="text-lg font-semibold text-gray-900">Wochenübersicht</h2></div>
                <div class="card-body space-y-4">
                    <% const maxWeekly = Math.max(1, ...weeklyTrend.map(row => row.created || 0)); %>
                    <% weeklyTrend.forEach(row => { %>
                    <div>
                        <div class="mb-1 flex items-center justify-between text-sm"><span class="font-medium text-slate-700"><%= row.period %></span><span class="text-slate-500"><%= row.created || 0 %> erstellt · <%= row.closed || 0 %> geschlossen</span></div>
                        <div class="h-3 rounded-full bg-slate-100"><div class="h-3 rounded-full bg-primary-500" style="width: <%= Math.max(4, Math.round((row.created || 0) / maxWeekly * 100)) %>%"></div></div>
                    </div>
                    <% }); %>
                    <% if (!weeklyTrend.length) { %><p class="text-sm text-gray-500">Keine Wochendaten vorhanden.</p><% } %>
                </div>
            </section>

            <section class="card">
                <div class="card-header"><h2 class="text-lg font-semibold text-gray-900">Backlog-Alter</h2></div>
                <div class="card-body space-y-4">
                    <% const maxAging = Math.max(1, ...agingBuckets.map(row => row.count || 0)); %>
                    <% agingBuckets.forEach(row => { %>
                    <div>
                        <div class="mb-1 flex justify-between text-sm"><span class="font-medium text-slate-700"><%= row.bucket %></span><span class="text-slate-500"><%= row.count %></span></div>
                        <div class="h-2 rounded-full bg-slate-100"><div class="h-2 rounded-full bg-amber-500" style="width: <%= Math.max(4, Math.round((row.count || 0) / maxAging * 100)) %>%"></div></div>
                    </div>
                    <% }); %>
                    <% if (!agingBuckets.length) { %><p class="text-sm text-gray-500">Keine offenen Tickets.</p><% } %>
                </div>
            </section>
        </div>

        <div class="mt-8 grid grid-cols-1 gap-8 xl:grid-cols-2">
            <section class="card">
                <div class="card-header"><h2 class="text-lg font-semibold text-gray-900">Monatsübersicht</h2></div>
                <div class="card-body p-0">
                    <table class="min-w-full divide-y divide-gray-200">
                        <thead class="bg-gray-50"><tr><th class="px-4 py-3 text-left text-xs font-medium uppercase text-gray-500">Monat</th><th class="px-4 py-3 text-right text-xs font-medium uppercase text-gray-500">Erstellt</th><th class="px-4 py-3 text-right text-xs font-medium uppercase text-gray-500">Geschlossen</th><th class="px-4 py-3 text-right text-xs font-medium uppercase text-gray-500">Ø Resolve</th></tr></thead>
                        <tbody class="divide-y divide-gray-100 bg-white">
                            <% monthlyTrend.forEach(row => { %>
                            <tr><td class="px-4 py-3 text-sm font-medium text-gray-900"><%= row.period %></td><td class="px-4 py-3 text-right text-sm text-gray-700"><%= row.created || 0 %></td><td class="px-4 py-3 text-right text-sm text-emerald-700"><%= row.closed || 0 %></td><td class="px-4 py-3 text-right text-sm text-gray-600"><%= formatMinutes(row.avg_resolution_minutes) %></td></tr>
                            <% }); %>
                            <% if (!monthlyTrend.length) { %><tr><td colspan="4" class="px-4 py-6 text-center text-sm text-gray-500">Keine Monatsdaten vorhanden.</td></tr><% } %>
                        </tbody>
                    </table>
                </div>
            </section>

            <section class="card">
                <div class="card-header"><h2 class="text-lg font-semibold text-gray-900">Jahresübersicht</h2></div>
                <div class="card-body p-0">
                    <table class="min-w-full divide-y divide-gray-200">
                        <thead class="bg-gray-50"><tr><th class="px-4 py-3 text-left text-xs font-medium uppercase text-gray-500">Jahr</th><th class="px-4 py-3 text-right text-xs font-medium uppercase text-gray-500">Erstellt</th><th class="px-4 py-3 text-right text-xs font-medium uppercase text-gray-500">Geschlossen</th><th class="px-4 py-3 text-right text-xs font-medium uppercase text-gray-500">Ø Resolve</th></tr></thead>
                        <tbody class="divide-y divide-gray-100 bg-white">
                            <% yearlyTrend.forEach(row => { %>
                            <tr><td class="px-4 py-3 text-sm font-medium text-gray-900"><%= row.period %></td><td class="px-4 py-3 text-right text-sm text-gray-700"><%= row.created || 0 %></td><td class="px-4 py-3 text-right text-sm text-emerald-700"><%= row.closed || 0 %></td><td class="px-4 py-3 text-right text-sm text-gray-600"><%= formatMinutes(row.avg_resolution_minutes) %></td></tr>
                            <% }); %>
                            <% if (!yearlyTrend.length) { %><tr><td colspan="4" class="px-4 py-6 text-center text-sm text-gray-500">Keine Jahresdaten vorhanden.</td></tr><% } %>
                        </tbody>
                    </table>
                </div>
            </section>
        </div>

        <div class="mt-8 grid grid-cols-1 gap-8 xl:grid-cols-3">
            <section class="card">
                <div class="card-header"><h2 class="text-lg font-semibold text-gray-900">Statusverteilung</h2></div>
                <div class="card-body space-y-4">
                    <% const maxStatus = Math.max(1, ...byStatus.map(row => row.count || 0)); %>
                    <% byStatus.forEach(row => { %>
                    <div><div class="mb-1 flex justify-between text-sm"><span class="font-medium text-slate-700"><%= toTitle(row.status) %></span><span class="text-slate-500"><%= row.count %></span></div><div class="h-2 rounded-full bg-slate-100"><div class="h-2 rounded-full bg-slate-600" style="width: <%= Math.max(4, Math.round((row.count || 0) / maxStatus * 100)) %>%"></div></div></div>
                    <% }); %>
                </div>
            </section>
            <section class="card">
                <div class="card-header"><h2 class="text-lg font-semibold text-gray-900">Prioritäten</h2></div>
                <div class="card-body space-y-4">
                    <% const maxPriority = Math.max(1, ...byPriority.map(row => row.count || 0)); %>
                    <% byPriority.forEach(row => { %>
                    <div><div class="mb-1 flex justify-between text-sm"><span class="font-medium text-slate-700"><%= toTitle(row.priority) %></span><span class="text-slate-500"><%= row.count %></span></div><div class="h-2 rounded-full bg-slate-100"><div class="h-2 rounded-full bg-red-500" style="width: <%= Math.max(4, Math.round((row.count || 0) / maxPriority * 100)) %>%"></div></div></div>
                    <% }); %>
                </div>
            </section>
            <section class="card">
                <div class="card-header"><h2 class="text-lg font-semibold text-gray-900">Häufigste Melder</h2></div>
                <div class="card-body space-y-3">
                    <% busiestCreators.forEach(row => { %>
                    <div class="flex items-center justify-between rounded-xl bg-slate-50 px-3 py-2 text-sm"><span class="font-medium text-slate-700"><%= row.name %></span><span class="badge bg-slate-100 text-slate-700"><%= row.total %></span></div>
                    <% }); %>
                    <% if (!busiestCreators.length) { %><p class="text-sm text-gray-500">Keine Daten vorhanden.</p><% } %>
                </div>
            </section>
        </div>

        <div class="mt-8 grid grid-cols-1 gap-8 xl:grid-cols-2">
            <section class="card">
                <div class="card-header"><h2 class="text-lg font-semibold text-gray-900">SLA- und Frist-Risiken</h2></div>
                <div class="card-body space-y-3">
                    <% overdueSlaTickets.forEach(ticket => { %>
                    <a href="/ticket/<%= ticket.id %>" class="block rounded-xl border border-red-100 bg-red-50 p-3 transition hover:border-red-300">
                        <div class="flex items-start justify-between gap-3"><div><p class="text-sm font-semibold text-red-950">#<%= ticket.id %> · <%= ticket.title %></p><p class="mt-1 text-xs text-red-700"><%= ticket.system_name || 'Ohne System' %> · <%= ticket.assigned_name || 'Nicht zugewiesen' %></p></div><span class="badge bg-red-100 text-red-700"><%= toTitle(ticket.priority) %></span></div>
                    </a>
                    <% }); %>
                    <% if (!overdueSlaTickets.length) { %><p class="text-sm text-gray-500">Keine akuten SLA- oder Frist-Risiken.</p><% } %>
                </div>
            </section>
            <section class="card">
                <div class="card-header"><h2 class="text-lg font-semibold text-gray-900">Älteste offene Tickets</h2></div>
                <div class="card-body space-y-3">
                    <% longestOpenTickets.forEach(ticket => { %>
                    <a href="/ticket/<%= ticket.id %>" class="block rounded-xl border border-slate-200 bg-white p-3 transition hover:border-primary-300">
                        <div class="flex items-start justify-between gap-3"><div><p class="text-sm font-semibold text-slate-900">#<%= ticket.id %> · <%= ticket.title %></p><p class="mt-1 text-xs text-slate-500"><%= ticket.system_name || 'Ohne System' %> · <%= ticket.assigned_name || 'Nicht zugewiesen' %></p></div><span class="badge bg-amber-100 text-amber-700"><%= formatMinutes(ticket.age_minutes) %></span></div>
                    </a>
                    <% }); %>
                    <% if (!longestOpenTickets.length) { %><p class="text-sm text-gray-500">Keine offenen Tickets.</p><% } %>
                </div>
            </section>
        </div>

        <% if (unassignedTickets.length) { %>
        <section class="card mt-8 border-amber-200">
            <div class="card-header bg-amber-50"><h2 class="text-lg font-semibold text-amber-950">Unzugewiesene offene Tickets</h2></div>
            <div class="card-body grid gap-3 md:grid-cols-2 xl:grid-cols-3">
                <% unassignedTickets.forEach(ticket => { %>
                <a href="/ticket/<%= ticket.id %>" class="rounded-xl border border-amber-100 bg-white p-3 text-sm transition hover:border-amber-300"><span class="font-semibold text-slate-900">#<%= ticket.id %></span> <%= ticket.title %><p class="mt-1 text-xs text-slate-500"><%= ticket.system_name || 'Ohne System' %> · <%= toTitle(ticket.priority) %></p></a>
                <% }); %>
            </div>
        </section>
        <% } %>
    </main>
</body>
</html>
