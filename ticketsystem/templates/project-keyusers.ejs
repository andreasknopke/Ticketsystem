<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Key-User - <%= project.name %> | Ticketsystem</title>
    <link rel="stylesheet" href="/style.css?v=2">
</head>
<body class="bg-gray-50 min-h-screen">
    <nav class="bg-white border-b border-gray-200 sticky top-0 z-50">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between h-16">
                <div class="flex items-center">
                    <div class="flex-shrink-0 flex items-center gap-2">
                        <div class="w-8 h-8 bg-primary-600 rounded-lg flex items-center justify-center">
                            <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 5v2m0 4v2m0 4v2M5 5a2 2 0 00-2 2v3a2 2 0 110 4v3a2 2 0 002 2h14a2 2 0 002-2v-3a2 2 0 110-4V7a2 2 0 00-2-2H5z"/>
                            </svg>
                        </div>
                        <a href="/" class="text-xl font-bold text-gray-900 hover:text-primary-600">Ticketsystem</a>
                    </div>
                    <div class="hidden md:ml-8 md:flex md:space-x-1">
                        <a href="/" class="nav-link">Dashboard</a>
                        <a href="/ticket/new" class="nav-link">Neues Ticket</a>
                        <a href="/projects" class="nav-link active">Projekte</a>
                        <% if (role === 'admin' || role === 'root') { %>
                        <a href="/stats" class="nav-link">Statistiken</a>
                        <a href="/admin/systems" class="nav-link">Systeme</a>
                        <a href="/admin/staff" class="nav-link">Mitarbeiter</a>
                        <% if (role === 'root') { %><a href="/admin/users" class="nav-link">Benutzer</a><% } %>
                        <% } %>
                    </div>
                </div>
                <div class="flex items-center gap-4">
                    <span class="text-sm text-gray-600"><%= user %> <span class="badge bg-gray-100 text-gray-700"><%= role %></span></span>
                    <a href="/account" class="btn-secondary text-sm">Account</a>
                    <a href="/logout" class="btn-secondary text-sm">Abmelden</a>
                </div>
            </div>
        </div>
    </nav>

    <main class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        <nav class="flex mb-6" aria-label="Breadcrumb">
            <ol class="flex items-center space-x-4">
                <li><a href="/" class="text-gray-500 hover:text-gray-700">Dashboard</a></li>
                <li class="text-gray-400">/</li>
                <li><a href="/projects" class="text-gray-500 hover:text-gray-700">Projekte</a></li>
                <li class="text-gray-400">/</li>
                <li><a href="/project/<%= project.id %>" class="text-gray-500 hover:text-gray-700"><%= project.name %></a></li>
                <li class="text-gray-400">/</li>
                <li class="text-gray-900 font-medium">Key-User</li>
            </ol>
        </nav>

        <div class="flex items-center justify-between mb-6">
            <h1 class="text-2xl font-bold text-gray-900">Key-User: <%= project.name %></h1>
            <div class="flex items-center gap-2">
                <% if (canManage) { %>
                <button onclick="toggleGoalsConfig()" class="btn-secondary" title="Schulungsziele konfigurieren" aria-label="Schulungsziele konfigurieren">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/>
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                    </svg>
                </button>
                <button onclick="toggleAddForm()" class="btn-primary">+ Key-User</button>
                <% } %>
            </div>
        </div>

        <div class="flex flex-wrap gap-2 mb-6">
            <a href="/project/<%= project.id %>" class="btn-secondary text-sm">Dashboard</a>
            <a href="/project/<%= project.id %>/timeline" class="btn-secondary text-sm">Zeitleiste</a>
            <% if (canManage) { %><a href="/project/<%= project.id %>/milestones" class="btn-secondary text-sm">Meilensteine</a><% } %>
            <a href="/project/<%= project.id %>/keyusers" class="btn-secondary text-sm font-medium bg-primary-50 text-primary-700">Key-User</a>
            <a href="/project/<%= project.id %>/docs" class="btn-secondary text-sm">Wiki</a>
            <% if (canManage) { %><a href="/project/<%= project.id %>/github" class="btn-secondary text-sm">GitHub</a><% } %>
        </div>

        <% if (canManage) { %>
        <div id="trainingGoalsConfig" class="card mb-8 hidden">
            <div class="card-header flex items-center justify-between">
                <h2 class="text-lg font-semibold text-gray-900">Schulungsziele konfigurieren</h2>
                <button onclick="toggleGoalsConfig()" class="text-gray-400 hover:text-gray-600" aria-label="Schliessen">&times;</button>
            </div>
            <div class="card-body space-y-4">
                <p class="text-sm text-gray-500">Definieren Sie die Checkbox-Optionen, die fuer jeden Key-User dieses Projekts angezeigt werden.</p>
                <ul id="goalsList" class="space-y-2">
                    <% trainingGoals.forEach(g => { %>
                    <li class="flex items-center gap-2" data-goal-id="<%= g.id %>">
                        <input type="text" class="form-input flex-1 goal-label-input" value="<%= g.label %>">
                        <button type="button" onclick="saveGoal(<%= g.id %>, this)" class="btn-secondary text-sm">Speichern</button>
                        <button type="button" onclick="deleteGoal(<%= g.id %>)" class="text-red-600 hover:text-red-800 text-sm">Loeschen</button>
                    </li>
                    <% }); %>
                    <% if (trainingGoals.length === 0) { %>
                    <li id="goalsEmpty" class="text-sm text-gray-400">Noch keine Schulungsziele definiert.</li>
                    <% } %>
                </ul>
                <form onsubmit="addGoal(event)" class="flex items-center gap-2 pt-2 border-t border-gray-100">
                    <input id="newGoalLabel" name="label" required class="form-input flex-1" placeholder="z. B. Intro-Mail versendet">
                    <button type="submit" class="btn-primary text-sm">+ Hinzufuegen</button>
                </form>
            </div>
        </div>
        <% } %>

        <% if (canManage) { %>
        <div id="addKeyUserForm" class="card mb-8 hidden">
            <div class="card-header">
                <h2 id="keyUserFormTitle" class="text-lg font-semibold text-gray-900">Externen Key-User hinzufügen</h2>
            </div>
            <div class="card-body">
                <form id="keyUserForm" onsubmit="addKeyUser(event)" class="space-y-4">
                    <input type="hidden" name="id" value="">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">Name *</label>
                            <input name="name" required class="form-input" placeholder="z. B. Max Mustermann">
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">E-Mail</label>
                            <input name="email" type="email" class="form-input" placeholder="optional@projekt.de">
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">Telefon</label>
                            <input name="phone" class="form-input" placeholder="Optional">
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">Rolle</label>
                            <select name="role" class="form-input">
                                <option value="key_user">Key-User</option>
                                <option value="evaluator">Evaluator</option>
                                <option value="decision_maker">Entscheider</option>
                            </select>
                        </div>
                        <div class="col-span-2">
                            <label class="block text-sm font-medium text-gray-700 mb-1">Notizen</label>
                            <textarea name="notes" class="form-input" rows="2" placeholder="Evaluierungsnotizen, Besonderheiten..."></textarea>
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">Schulungsstatus</label>
                            <textarea name="training_status" class="form-input" rows="3" placeholder="z. B. Basisschulung absolviert, Rollout offen"></textarea>
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">Test-Protokoll</label>
                            <textarea name="test_protocol" class="form-input" rows="3" placeholder="z. B. Ersten Test durchgeführt, offene Findings..."></textarea>
                        </div>
                        <div class="col-span-2">
                            <label class="block text-sm font-medium text-gray-700 mb-1">Schulungsziele</label>
                            <% if (trainingGoals.length === 0) { %>
                            <p class="text-sm text-gray-400">Keine Ziele definiert. Konfigurieren Sie diese ueber das Zahnrad oben.</p>
                            <% } else { %>
                            <div id="keyUserGoalsCheckboxes" class="grid grid-cols-1 sm:grid-cols-2 gap-2">
                                <% trainingGoals.forEach(g => { %>
                                <label class="flex items-center gap-2 text-sm text-gray-700">
                                    <input type="checkbox" name="training_goal_ids" value="<%= g.id %>" class="rounded border-gray-300">
                                    <span><%= g.label %></span>
                                </label>
                                <% }); %>
                            </div>
                            <% } %>
                        </div>
                    </div>
                    <div class="flex items-center gap-3">
                        <button type="submit" id="keyUserSubmitButton" class="btn-primary">Key-User speichern</button>
                        <button type="button" id="keyUserCancelButton" class="btn-secondary hidden" onclick="resetKeyUserForm()">Abbrechen</button>
                    </div>
                </form>
            </div>
        </div>
        <% } %>

        <div class="card">
            <div class="card-header"><h2 class="text-lg font-semibold text-gray-900">Zugewiesene Key-User</h2></div>
            <div class="card-body p-0">
                <div class="overflow-x-auto">
                    <table id="keyUsersTable" class="min-w-full divide-y divide-gray-200">
                        <thead class="bg-gray-50">
                            <tr>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider cursor-pointer select-none hover:text-gray-700 sort-header" data-sort="name" data-sort-type="text" onclick="sortKeyUsersTable('name', 'text')">Name <span class="sort-indicator"></span></th>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider cursor-pointer select-none hover:text-gray-700 sort-header" data-sort="email" data-sort-type="text" onclick="sortKeyUsersTable('email', 'text')">Kontakt <span class="sort-indicator"></span></th>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider cursor-pointer select-none hover:text-gray-700 sort-header" data-sort="role" data-sort-type="role" onclick="sortKeyUsersTable('role', 'role')">Rolle <span class="sort-indicator"></span></th>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider cursor-pointer select-none hover:text-gray-700 sort-header" data-sort="training_status" data-sort-type="text" onclick="sortKeyUsersTable('training_status', 'text')">Schulungsstatus <span class="sort-indicator"></span></th>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider cursor-pointer select-none hover:text-gray-700 sort-header" data-sort="goals_text" data-sort-type="text" onclick="sortKeyUsersTable('goals_text', 'text')">Schulungsziele <span class="sort-indicator"></span></th>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider cursor-pointer select-none hover:text-gray-700 sort-header" data-sort="goal_count" data-sort-type="number" onclick="sortKeyUsersTable('goal_count', 'number')"># Ziele <span class="sort-indicator"></span></th>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider cursor-pointer select-none hover:text-gray-700 sort-header" data-sort="test_protocol" data-sort-type="text" onclick="sortKeyUsersTable('test_protocol', 'text')">Test-Protokoll <span class="sort-indicator"></span></th>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider cursor-pointer select-none hover:text-gray-700 sort-header" data-sort="notes" data-sort-type="text" onclick="sortKeyUsersTable('notes', 'text')">Notizen <span class="sort-indicator"></span></th>
                                <% if (canManage) { %><th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Aktionen</th><% } %>
                            </tr>
                        </thead>
                        <tbody class="bg-white divide-y divide-gray-200">
                            <% keyUsers.forEach(k => { %>
                            <%
                                const kuGoalIds = (goalIdsByKeyUser && goalIdsByKeyUser[k.id]) ? goalIdsByKeyUser[k.id] : [];
                                const kuGoalIdSet = new Set(kuGoalIds);
                                const kuGoalLabels = trainingGoals.filter(g => kuGoalIdSet.has(g.id)).map(g => g.label);
                                const totalGoals = trainingGoals.length;
                                const enrichedKeyUser = Object.assign({}, k, { training_goal_ids: kuGoalIds });
                            %>
                            <tr data-goal-count="<%= kuGoalLabels.length %>" data-sort-name="<%= (k.name || '').toLowerCase() %>" data-sort-email="<%= (k.email || '').toLowerCase() %>" data-sort-role="<%= ({key_user:0,evaluator:1,decision_maker:2}[k.role] ?? 99) %>" data-sort-training_status="<%= (k.training_status || '').toLowerCase() %>" data-sort-goals_text="<%= (kuGoalLabels.join(' ')).toLowerCase() %>" data-sort-goal_count="<%= kuGoalLabels.length %>" data-sort-test_protocol="<%= (k.test_protocol || '').toLowerCase() %>" data-sort-notes="<%= (k.notes || '').toLowerCase() %>">
                                <td class="px-6 py-4 text-sm font-medium text-gray-900"><%= k.name %></td>
                                <td class="px-6 py-4 text-sm text-gray-500">
                                    <div><%= k.email || '-' %></div>
                                    <div class="text-xs text-gray-400 mt-1"><%= k.phone || 'Kein Telefon' %></div>
                                </td>
                                <td class="px-6 py-4"><span class="badge text-xs <%= k.role === 'key_user' ? 'bg-blue-100 text-blue-800' : k.role === 'evaluator' ? 'bg-purple-100 text-purple-800' : 'bg-orange-100 text-orange-800' %>"><%= {key_user:'Key-User',evaluator:'Evaluator',decision_maker:'Entscheider'}[k.role] %></span></td>
                                <td class="px-6 py-4 text-sm text-gray-500 whitespace-pre-wrap"><%= k.training_status || '-' %></td>
                                <td class="px-6 py-4 text-sm text-gray-600">
                                    <% if (totalGoals === 0) { %>
                                        <span class="text-gray-400">-</span>
                                    <% } else if (kuGoalLabels.length === 0) { %>
                                        <span class="text-gray-400">keine</span>
                                    <% } else { %>
                                        <ul class="space-y-1">
                                            <% kuGoalLabels.forEach(label => { %>
                                            <li class="flex items-center gap-1">
                                                <svg class="w-4 h-4 text-green-600 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                                                <span><%= label %></span>
                                            </li>
                                            <% }); %>
                                        </ul>
                                    <% } %>
                                </td>
                                <td class="px-6 py-4 text-sm text-gray-700">
                                    <% if (totalGoals === 0) { %>
                                        <span class="text-gray-400">-</span>
                                    <% } else { %>
                                        <span class="font-medium"><%= kuGoalLabels.length %></span><span class="text-gray-400"> / <%= totalGoals %></span>
                                    <% } %>
                                </td>
                                <td class="px-6 py-4 text-sm text-gray-500 whitespace-pre-wrap"><%= k.test_protocol || '-' %></td>
                                <td class="px-6 py-4 text-sm text-gray-500 whitespace-pre-wrap"><%= k.notes || '-' %></td>
                                <% if (canManage) { %>
                                <td class="px-6 py-4 text-sm">
                                    <button
                                        class="mr-3 text-primary-600 hover:text-primary-800"
                                        data-key-user='<%- JSON.stringify(enrichedKeyUser).replace(/'/g, "&#39;") %>'
                                        onclick='editKeyUser(this.dataset.keyUser)'>Bearbeiten</button>
                                    <button onclick="deleteKeyUser(<%= k.id %>)" class="text-red-600 hover:text-red-900">Entfernen</button>
                                </td>
                                <% } %>
                            </tr>
                            <% }); %>
                            <% if (keyUsers.length === 0) { %>
                            <tr><td colspan="<%= canManage ? 9 : 8 %>" class="px-6 py-8 text-center text-gray-500">Keine Key-User zugewiesen.</td></tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </main>
    <script>
        const CSRF_TOKEN = '<%= csrfToken %>';
        const PROJECT_ID = <%= project.id %>;
        const HAS_GOALS = <%= trainingGoals.length %> > 0;

        function toggleAddForm() { document.getElementById('addKeyUserForm').classList.toggle('hidden'); }
        function toggleGoalsConfig() {
            const el = document.getElementById('trainingGoalsConfig');
            if (el) el.classList.toggle('hidden');
        }
        function getGoalCheckboxes() {
            return document.querySelectorAll('#keyUserGoalsCheckboxes input[name="training_goal_ids"]');
        }
        function setGoalSelection(ids) {
            const set = new Set((ids || []).map(Number));
            getGoalCheckboxes().forEach(cb => { cb.checked = set.has(Number(cb.value)); });
        }
        function resetKeyUserForm() {
            const form = document.getElementById('keyUserForm');
            form.reset();
            form.elements.id.value = '';
            setGoalSelection([]);
            document.getElementById('keyUserFormTitle').textContent = 'Externen Key-User hinzufügen';
            document.getElementById('keyUserSubmitButton').textContent = 'Key-User speichern';
            document.getElementById('keyUserCancelButton').classList.add('hidden');
        }
        function editKeyUser(rawKeyUser) {
            const keyUser = JSON.parse(rawKeyUser);
            const form = document.getElementById('keyUserForm');
            document.getElementById('addKeyUserForm').classList.remove('hidden');
            form.elements.id.value = keyUser.id || '';
            form.elements.name.value = keyUser.name || '';
            form.elements.email.value = keyUser.email || '';
            form.elements.phone.value = keyUser.phone || '';
            form.elements.role.value = keyUser.role || 'key_user';
            form.elements.notes.value = keyUser.notes || '';
            form.elements.training_status.value = keyUser.training_status || '';
            form.elements.test_protocol.value = keyUser.test_protocol || '';
            setGoalSelection(keyUser.training_goal_ids || []);
            document.getElementById('keyUserFormTitle').textContent = 'Key-User bearbeiten';
            document.getElementById('keyUserSubmitButton').textContent = 'Änderungen speichern';
            document.getElementById('keyUserCancelButton').classList.remove('hidden');
            // Zum Bearbeiten-Container scrollen
            document.getElementById('addKeyUserForm').scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
        async function addKeyUser(e) {
            e.preventDefault();
            const fd = new FormData(e.target);
            const body = {};
            for (const [k, v] of fd.entries()) {
                if (k === 'training_goal_ids') continue;
                body[k] = v;
            }
            if (HAS_GOALS) {
                body.training_goal_ids = Array.from(getGoalCheckboxes()).filter(cb => cb.checked).map(cb => Number(cb.value));
            }
            const resp = await fetch('/api/projects/' + PROJECT_ID + '/keyusers', {
                method:'POST', headers:{'Content-Type':'application/json','X-CSRF-Token':CSRF_TOKEN}, body:JSON.stringify(body)
            });
            if (resp.ok) {
                resetKeyUserForm();
                location.reload();
            }
            else alert('Fehler: ' + (await resp.json()).error);
        }
        async function deleteKeyUser(id) {
            if (!confirm('Key-User entfernen?')) return;
            const resp = await fetch('/api/keyusers/' + id, { method:'DELETE', headers:{'X-CSRF-Token':CSRF_TOKEN} });
            if (resp.ok) location.reload();
            else alert('Fehler beim Löschen');
        }

        // --- Training goals admin ---
        async function addGoal(e) {
            e.preventDefault();
            const input = document.getElementById('newGoalLabel');
            const label = (input.value || '').trim();
            if (!label) return;
            const resp = await fetch('/api/projects/' + PROJECT_ID + '/training-goals', {
                method:'POST', headers:{'Content-Type':'application/json','X-CSRF-Token':CSRF_TOKEN},
                body: JSON.stringify({ label })
            });
            if (resp.ok) location.reload();
            else alert('Fehler: ' + (await resp.json()).error);
        }
        async function saveGoal(goalId, btn) {
            const li = btn.closest('li[data-goal-id]');
            const label = (li.querySelector('.goal-label-input').value || '').trim();
            if (!label) { alert('Label darf nicht leer sein.'); return; }
            const resp = await fetch('/api/projects/' + PROJECT_ID + '/training-goals/' + goalId, {
                method:'PUT', headers:{'Content-Type':'application/json','X-CSRF-Token':CSRF_TOKEN},
                body: JSON.stringify({ label })
            });
            if (resp.ok) location.reload();
            else alert('Fehler: ' + (await resp.json()).error);
        }
        async function deleteGoal(goalId) {
            if (!confirm('Schulungsziel loeschen?')) return;
            const resp = await fetch('/api/projects/' + PROJECT_ID + '/training-goals/' + goalId, {
                method:'DELETE', headers:{'X-CSRF-Token':CSRF_TOKEN}
            });
            if (resp.ok) { location.reload(); return; }
            const err = await resp.json().catch(() => ({}));
            alert('Fehler: ' + (err.error || resp.statusText));
        }

        // --- Tabellen-Sortierung ---
        const keyUserSortOrders = {
            role: { key_user: 0, evaluator: 1, decision_maker: 2 }
        };
        let keyUserCurrentSort = { col: null, asc: true };

        function sortKeyUsersTable(col, type) {
            const table = document.getElementById('keyUsersTable');
            if (!table) return;
            const tbody = table.tBodies[0];
            const rows = Array.from(tbody.querySelectorAll('tr[data-sort-name]'));
            if (rows.length === 0) return;

            // Toggle direction wenn gleiche Spalte
            if (keyUserCurrentSort.col === col) {
                keyUserCurrentSort.asc = !keyUserCurrentSort.asc;
            } else {
                keyUserCurrentSort.col = col;
                keyUserCurrentSort.asc = true;
            }

            rows.sort((a, b) => {
                let va = (a.getAttribute('data-sort-' + col) || '').trim();
                let vb = (b.getAttribute('data-sort-' + col) || '').trim();
                let cmp = 0;

                if (type === 'number') {
                    cmp = (Number(va) || 0) - (Number(vb) || 0);
                } else if (type === 'role') {
                    const oa = Number(va);
                    const ob = Number(vb);
                    cmp = oa - ob;
                } else {
                    cmp = va.localeCompare(vb, 'de');
                }

                return keyUserCurrentSort.asc ? cmp : -cmp;
            });

            rows.forEach(row => tbody.appendChild(row));

            // Sort-Indikatoren aktualisieren
            document.querySelectorAll('.sort-header .sort-indicator').forEach(el => {
                el.textContent = '';
            });
            const activeHeaders = document.querySelectorAll('.sort-header[data-sort="' + col + '"]');
            activeHeaders.forEach(el => {
                const indicator = el.querySelector('.sort-indicator');
                if (indicator) indicator.textContent = keyUserCurrentSort.asc ? ' ▲' : ' ▼';
            });
        }
    </script>
</body>
</html>
