<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Key-User - <%= project.name %> | Ticketsystem</title>
    <link rel="stylesheet" href="/style.css?v=2">
</head>
<body class="bg-gray-50 min-h-screen">
    <nav class="bg-white border-b border-gray-200 sticky top-0 z-50">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between h-16">
                <div class="flex items-center">
                    <div class="flex-shrink-0 flex items-center gap-2">
                        <div class="w-8 h-8 bg-primary-600 rounded-lg flex items-center justify-center">
                            <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 5v2m0 4v2m0 4v2M5 5a2 2 0 00-2 2v3a2 2 0 110 4v3a2 2 0 002 2h14a2 2 0 002-2v-3a2 2 0 110-4V7a2 2 0 00-2-2H5z"/>
                            </svg>
                        </div>
                        <a href="/" class="text-xl font-bold text-gray-900 hover:text-primary-600">Ticketsystem</a>
                    </div>
                    <div class="hidden md:ml-8 md:flex md:space-x-1">
                        <a href="/" class="nav-link">Dashboard</a>
                        <a href="/ticket/new" class="nav-link">Neues Ticket</a>
                        <a href="/projects" class="nav-link active">Projekte</a>
                        <% if (role === 'admin' || role === 'root') { %>
                        <a href="/stats" class="nav-link">Statistiken</a>
                        <a href="/admin/systems" class="nav-link">Systeme</a>
                        <a href="/admin/staff" class="nav-link">Mitarbeiter</a>
                        <% if (role === 'root') { %><a href="/admin/users" class="nav-link">Benutzer</a><% } %>
                        <% } %>
                    </div>
                </div>
                <div class="flex items-center gap-4">
                    <span class="text-sm text-gray-600"><%= user %> <span class="badge bg-gray-100 text-gray-700"><%= role %></span></span>
                    <a href="/account" class="btn-secondary text-sm">Account</a>
                    <a href="/logout" class="btn-secondary text-sm">Abmelden</a>
                </div>
            </div>
        </div>
    </nav>

    <main class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        <nav class="flex mb-6" aria-label="Breadcrumb">
            <ol class="flex items-center space-x-4">
                <li><a href="/" class="text-gray-500 hover:text-gray-700">Dashboard</a></li>
                <li class="text-gray-400">/</li>
                <li><a href="/projects" class="text-gray-500 hover:text-gray-700">Projekte</a></li>
                <li class="text-gray-400">/</li>
                <li><a href="/project/<%= project.id %>" class="text-gray-500 hover:text-gray-700"><%= project.name %></a></li>
                <li class="text-gray-400">/</li>
                <li class="text-gray-900 font-medium">Key-User</li>
            </ol>
        </nav>

        <div class="flex items-center justify-between mb-6">
            <h1 class="text-2xl font-bold text-gray-900">Key-User: <%= project.name %></h1>
            <% if (canManage) { %><button onclick="toggleAddForm()" class="btn-primary">+ Key-User</button><% } %>
        </div>

        <div class="flex flex-wrap gap-2 mb-6">
            <a href="/project/<%= project.id %>" class="btn-secondary text-sm">Dashboard</a>
            <a href="/project/<%= project.id %>/timeline" class="btn-secondary text-sm">Zeitleiste</a>
            <% if (canManage) { %><a href="/project/<%= project.id %>/milestones" class="btn-secondary text-sm">Meilensteine</a><% } %>
            <a href="/project/<%= project.id %>/keyusers" class="btn-secondary text-sm font-medium bg-primary-50 text-primary-700">Key-User</a>
            <a href="/project/<%= project.id %>/docs" class="btn-secondary text-sm">Wiki</a>
            <% if (canManage) { %><a href="/project/<%= project.id %>/github" class="btn-secondary text-sm">GitHub</a><% } %>
        </div>

        <% if (canManage) { %>
        <div id="addKeyUserForm" class="card mb-8 hidden">
            <div class="card-header">
                <h2 id="keyUserFormTitle" class="text-lg font-semibold text-gray-900">Externen Key-User hinzufügen</h2>
            </div>
            <div class="card-body">
                <form id="keyUserForm" onsubmit="addKeyUser(event)" class="space-y-4">
                    <input type="hidden" name="id" value="">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">Name *</label>
                            <input name="name" required class="form-input" placeholder="z. B. Max Mustermann">
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">E-Mail</label>
                            <input name="email" type="email" class="form-input" placeholder="optional@projekt.de">
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">Telefon</label>
                            <input name="phone" class="form-input" placeholder="Optional">
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">Rolle</label>
                            <select name="role" class="form-input">
                                <option value="key_user">Key-User</option>
                                <option value="evaluator">Evaluator</option>
                                <option value="decision_maker">Entscheider</option>
                            </select>
                        </div>
                        <div class="col-span-2">
                            <label class="block text-sm font-medium text-gray-700 mb-1">Notizen</label>
                            <textarea name="notes" class="form-input" rows="2" placeholder="Evaluierungsnotizen, Besonderheiten..."></textarea>
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">Schulungsstatus</label>
                            <textarea name="training_status" class="form-input" rows="3" placeholder="z. B. Basisschulung absolviert, Rollout offen"></textarea>
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">Test-Protokoll</label>
                            <textarea name="test_protocol" class="form-input" rows="3" placeholder="z. B. Ersten Test durchgeführt, offene Findings..."></textarea>
                        </div>
                    </div>
                    <div class="flex items-center gap-3">
                        <button type="submit" id="keyUserSubmitButton" class="btn-primary">Key-User speichern</button>
                        <button type="button" id="keyUserCancelButton" class="btn-secondary hidden" onclick="resetKeyUserForm()">Abbrechen</button>
                    </div>
                </form>
            </div>
        </div>
        <% } %>

        <div class="card">
            <div class="card-header"><h2 class="text-lg font-semibold text-gray-900">Zugewiesene Key-User</h2></div>
            <div class="card-body p-0">
                <div class="overflow-x-auto">
                    <table class="min-w-full divide-y divide-gray-200">
                        <thead class="bg-gray-50">
                            <tr>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Name</th>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Kontakt</th>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Rolle</th>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Schulungsstatus</th>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Test-Protokoll</th>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Notizen</th>
                                <% if (canManage) { %><th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Aktionen</th><% } %>
                            </tr>
                        </thead>
                        <tbody class="bg-white divide-y divide-gray-200">
                            <% keyUsers.forEach(k => { %>
                            <tr>
                                <td class="px-6 py-4 text-sm font-medium text-gray-900"><%= k.name %></td>
                                <td class="px-6 py-4 text-sm text-gray-500">
                                    <div><%= k.email || '-' %></div>
                                    <div class="text-xs text-gray-400 mt-1"><%= k.phone || 'Kein Telefon' %></div>
                                </td>
                                <td class="px-6 py-4"><span class="badge text-xs <%= k.role === 'key_user' ? 'bg-blue-100 text-blue-800' : k.role === 'evaluator' ? 'bg-purple-100 text-purple-800' : 'bg-orange-100 text-orange-800' %>"><%= {key_user:'Key-User',evaluator:'Evaluator',decision_maker:'Entscheider'}[k.role] %></span></td>
                                <td class="px-6 py-4 text-sm text-gray-500 whitespace-pre-wrap"><%= k.training_status || '-' %></td>
                                <td class="px-6 py-4 text-sm text-gray-500 whitespace-pre-wrap"><%= k.test_protocol || '-' %></td>
                                <td class="px-6 py-4 text-sm text-gray-500 whitespace-pre-wrap"><%= k.notes || '-' %></td>
                                <% if (canManage) { %>
                                <td class="px-6 py-4 text-sm">
                                    <button
                                        class="mr-3 text-primary-600 hover:text-primary-800"
                                        data-key-user='<%- JSON.stringify(k).replace(/'/g, "&#39;") %>'
                                        onclick='editKeyUser(this.dataset.keyUser)'>Bearbeiten</button>
                                    <button onclick="deleteKeyUser(<%= k.id %>)" class="text-red-600 hover:text-red-900">Entfernen</button>
                                </td>
                                <% } %>
                            </tr>
                            <% }); %>
                            <% if (keyUsers.length === 0) { %>
                            <tr><td colspan="<%= canManage ? 7 : 6 %>" class="px-6 py-8 text-center text-gray-500">Keine Key-User zugewiesen.</td></tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </main>
    <script>
        function toggleAddForm() { document.getElementById('addKeyUserForm').classList.toggle('hidden'); }
        function resetKeyUserForm() {
            const form = document.getElementById('keyUserForm');
            form.reset();
            form.elements.id.value = '';
            document.getElementById('keyUserFormTitle').textContent = 'Externen Key-User hinzufügen';
            document.getElementById('keyUserSubmitButton').textContent = 'Key-User speichern';
            document.getElementById('keyUserCancelButton').classList.add('hidden');
        }
        function editKeyUser(rawKeyUser) {
            const keyUser = JSON.parse(rawKeyUser);
            const form = document.getElementById('keyUserForm');
            document.getElementById('addKeyUserForm').classList.remove('hidden');
            form.elements.id.value = keyUser.id || '';
            form.elements.name.value = keyUser.name || '';
            form.elements.email.value = keyUser.email || '';
            form.elements.phone.value = keyUser.phone || '';
            form.elements.role.value = keyUser.role || 'key_user';
            form.elements.notes.value = keyUser.notes || '';
            form.elements.training_status.value = keyUser.training_status || '';
            form.elements.test_protocol.value = keyUser.test_protocol || '';
            document.getElementById('keyUserFormTitle').textContent = 'Key-User bearbeiten';
            document.getElementById('keyUserSubmitButton').textContent = 'Änderungen speichern';
            document.getElementById('keyUserCancelButton').classList.remove('hidden');
        }
        async function addKeyUser(e) {
            e.preventDefault();
            const fd = new FormData(e.target);
            const body = Object.fromEntries(fd);
            const resp = await fetch('/api/projects/<%= project.id %>/keyusers', {
                method:'POST', headers:{'Content-Type':'application/json','X-CSRF-Token':'<%= csrfToken %>'}, body:JSON.stringify(body)
            });
            if (resp.ok) {
                resetKeyUserForm();
                location.reload();
            }
            else alert('Fehler: ' + (await resp.json()).error);
        }
        async function deleteKeyUser(id) {
            if (!confirm('Key-User entfernen?')) return;
            const resp = await fetch('/api/keyusers/' + id, { method:'DELETE', headers:{'X-CSRF-Token':'<%= csrfToken %>'} });
            if (resp.ok) location.reload();
            else alert('Fehler beim Löschen');
        }
    </script>
</body>
</html>
