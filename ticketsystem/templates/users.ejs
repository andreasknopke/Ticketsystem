<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Benutzerverwaltung | Ticketsystem</title>
    <link rel="stylesheet" href="/style.css?v=2">
</head>
<body class="bg-gray-50 min-h-screen">
    <!-- Navigation -->
    <nav class="bg-white border-b border-gray-200 sticky top-0 z-50">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between h-16">
                <div class="flex items-center">
                    <div class="flex-shrink-0 flex items-center gap-2">
                        <div class="w-8 h-8 bg-primary-600 rounded-lg flex items-center justify-center">
                            <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 5v2m0 4v2m0 4v2M5 5a2 2 0 00-2 2v3a2 2 0 110 4v3a2 2 0 002 2h14a2 2 0 002-2v-3a2 2 0 110-4V7a2 2 0 00-2-2H5z"/>
                            </svg>
                        </div>
                        <a href="/" class="text-xl font-bold text-gray-900 hover:text-primary-600">Ticketsystem</a>
                    </div>
                    <div class="hidden md:ml-8 md:flex md:space-x-1">
                        <a href="/" class="nav-link">Dashboard</a>
                        <a href="/stats" class="nav-link">Statistiken</a>
                        <a href="/ticket/new" class="nav-link">Neues Ticket</a>
                        <a href="/admin/systems" class="nav-link">Systeme</a>
                        <a href="/admin/staff" class="nav-link">Mitarbeiter</a>
                        <a href="/admin/users" class="nav-link active">Benutzer</a>
                    </div>
                </div>
                <div class="flex items-center gap-4">
                    <span class="text-sm text-gray-600"><%= user %> <span class="badge bg-purple-100 text-purple-800"><%= role %></span></span>
                    <a href="/account" class="btn-secondary text-sm">Account</a>
                    <a href="/logout" class="btn-secondary text-sm">Abmelden</a>
                </div>
            </div>
        </div>
    </nav>

    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        <div class="flex items-center justify-between mb-8">
            <div>
                <h1 class="text-2xl font-bold text-gray-900">Benutzerverwaltung</h1>
                <p class="text-sm text-gray-500 mt-1">Benutzer anlegen, Rollen vergeben und mit Mitarbeitern verknüpfen</p>
            </div>
        </div>

        <% if (locals.error) { %>
        <div class="mb-6 p-4 bg-red-50 border border-red-200 rounded-lg">
            <p class="text-sm text-red-700"><%= error %></p>
        </div>
        <% } %>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
            <!-- Neuen Benutzer anlegen -->
            <div class="lg:col-span-1">
                <div class="card">
                    <div class="card-header">
                        <h2 class="text-lg font-semibold text-gray-900">Neuen Benutzer anlegen</h2>
                    </div>
                    <div class="card-body">
                        <form method="post" action="/admin/users" class="space-y-4">
                            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                            <div>
                                <label class="block text-sm font-medium text-gray-700 mb-1">Benutzername *</label>
                                <input type="text" name="username" required class="form-input" placeholder="z.B. akn">
                            </div>
                            <div>
                                <label class="block text-sm font-medium text-gray-700 mb-1">Passwort *</label>
                                <input type="password" name="password" required class="form-input" placeholder="Sicheres Passwort">
                            </div>
                            <div>
                                <label class="block text-sm font-medium text-gray-700 mb-1">Rolle</label>
                                <select name="role" class="form-input">
                                    <option value="user">Benutzer</option>
                                    <option value="admin">Admin</option>
                                </select>
                            </div>
                            <div>
                                <label class="block text-sm font-medium text-gray-700 mb-1">Verknüpfter Mitarbeiter</label>
                                <select name="staff_id" class="form-input">
                                    <option value="">— Kein Mitarbeiter —</option>
                                    <% staffList.forEach(s => { %>
                                    <option value="<%= s.id %>"><%= s.name %></option>
                                    <% }); %>
                                </select>
                            </div>
                            <div>
                                <label class="block text-sm font-medium text-gray-700 mb-1">Hauptsystem</label>
                                <select name="default_system_id" class="form-input">
                                    <option value="">— Kein System —</option>
                                    <% systems.forEach(s => { %>
                                    <option value="<%= s.id %>"><%= s.name %></option>
                                    <% }); %>
                                </select>
                            </div>
                            <div class="rounded-xl border border-slate-200 bg-slate-50 p-4">
                                <p class="text-sm font-semibold text-slate-900">Mail-Benachrichtigungen</p>
                                <p class="mt-1 text-xs text-slate-500">Die Benachrichtigungen gehen an die E-Mail-Adresse des verknüpften Mitarbeiters.</p>
                                <div class="mt-4 space-y-3">
                                    <label class="flex items-start gap-3 text-sm text-slate-700">
                                        <input type="checkbox" name="notify_new_tickets" class="mt-1 h-4 w-4 rounded border-slate-300 text-primary-600 focus:ring-primary-500">
                                        <span>Neue Tickets melden, die zum Hauptsystem des Benutzers passen.</span>
                                    </label>
                                    <label class="flex items-start gap-3 text-sm text-slate-700">
                                        <input type="checkbox" name="notify_assigned_tickets" checked class="mt-1 h-4 w-4 rounded border-slate-300 text-primary-600 focus:ring-primary-500">
                                        <span>Benachrichtigen, wenn dem Benutzer ein Ticket zugewiesen wird.</span>
                                    </label>
                                    <label class="flex items-start gap-3 text-sm text-slate-700">
                                        <input type="checkbox" name="notify_status_changes" checked class="mt-1 h-4 w-4 rounded border-slate-300 text-primary-600 focus:ring-primary-500">
                                        <span>Benachrichtigen, wenn sich der Status eines zugewiesenen Tickets ändert.</span>
                                    </label>
                                </div>
                            </div>
                            <button type="submit" class="btn-primary w-full">Benutzer anlegen</button>
                        </form>
                    </div>
                </div>
            </div>

            <!-- Benutzerliste -->
            <div class="lg:col-span-2">
                <div class="card">
                    <div class="card-header">
                        <h2 class="text-lg font-semibold text-gray-900">Aktive Benutzer (<%= users.length %>)</h2>
                    </div>
                    <div class="card-body p-0">
                        <% if (users.length === 0) { %>
                        <div class="p-8 text-center text-gray-500">
                            <p>Noch keine Benutzer angelegt.</p>
                        </div>
                        <% } else { %>
                        <table class="min-w-full divide-y divide-gray-200">
                            <thead class="bg-gray-50">
                                <tr>
                                    <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Benutzer</th>
                                    <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Rolle</th>
                                    <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Mitarbeiter</th>
                                    <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Hauptsystem</th>
                                    <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Mail</th>
                                    <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Aktionen</th>
                                </tr>
                            </thead>
                            <tbody class="bg-white divide-y divide-gray-200">
                                <% users.forEach(u => { %>
                                <tr>
                                    <td class="px-4 py-3 text-sm font-medium text-gray-900"><%= u.username %></td>
                                    <td class="px-4 py-3">
                                        <span class="badge <%= u.role === 'admin' ? 'bg-blue-100 text-blue-800' : 'bg-gray-100 text-gray-800' %>">
                                            <%= u.role %>
                                        </span>
                                    </td>
                                    <td class="px-4 py-3 text-sm text-gray-600"><%= u.staff_name || '—' %></td>
                                    <td class="px-4 py-3 text-sm text-gray-600"><%= u.system_name || '—' %></td>
                                    <td class="px-4 py-3 text-sm text-gray-600">
                                        <div class="flex flex-wrap gap-1">
                                            <% if (u.notify_new_tickets) { %><span class="badge bg-slate-100 text-slate-700">Neu</span><% } %>
                                            <% if (u.notify_assigned_tickets) { %><span class="badge bg-blue-100 text-blue-700">Zuweisung</span><% } %>
                                            <% if (u.notify_status_changes) { %><span class="badge bg-emerald-100 text-emerald-700">Status</span><% } %>
                                            <% if (!u.notify_new_tickets && !u.notify_assigned_tickets && !u.notify_status_changes) { %>
                                            <span class="text-xs text-slate-400">Keine</span>
                                            <% } %>
                                        </div>
                                    </td>
                                    <td class="px-4 py-3">
                                        <div class="flex gap-2 items-center">
                                            <button type="button" class="rounded-full border border-slate-200 px-3 py-1 text-xs font-medium text-slate-700 transition hover:border-primary-300 hover:text-primary-700"
                                                onclick='openEditModal(<%- JSON.stringify(u) %>)'>Bearbeiten</button>
                                            <form method="post" action="/admin/users/<%= u.id %>/delete"
                                                onsubmit="return confirm('Benutzer <%= u.username %> wirklich löschen?')">
                                                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                                <button type="submit" class="rounded-full border border-red-200 px-3 py-1 text-xs font-medium text-red-600 transition hover:bg-red-50">Löschen</button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                                <% }); %>
                            </tbody>
                        </table>
                        <% } %>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <!-- Edit Modal -->
    <div id="editModal" class="fixed inset-0 z-50 hidden items-center justify-center bg-slate-950/55 p-4 backdrop-blur-sm">
        <div class="w-full max-w-2xl overflow-hidden rounded-3xl bg-white shadow-2xl ring-1 ring-slate-200">
            <div class="border-b border-slate-200 bg-gradient-to-r from-slate-50 to-white px-6 py-5">
                <div class="flex items-start justify-between gap-4">
                    <div>
                        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-primary-600">Benutzerverwaltung</p>
                        <h3 class="mt-1 text-2xl font-semibold text-slate-900">Benutzer bearbeiten</h3>
                        <p class="mt-1 text-sm text-slate-500">Rolle, Verknüpfungen und Mail-Benachrichtigungen an einer Stelle verwalten.</p>
                    </div>
                    <button type="button" class="rounded-full p-2 text-slate-400 transition hover:bg-slate-100 hover:text-slate-700" onclick="closeEditModal()" aria-label="Dialog schließen">
                        <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                        </svg>
                    </button>
                </div>
            </div>
            <form method="post" id="editForm" class="space-y-6 px-6 py-6">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <div class="rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3">
                    <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">Benutzer</p>
                    <p id="edit_username_display" class="mt-1 text-lg font-semibold text-slate-900"></p>
                </div>
                <div class="grid gap-6 lg:grid-cols-2">
                    <div class="space-y-4">
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">Neues Passwort</label>
                            <input type="password" name="password" class="form-input" placeholder="Leer lassen, um es nicht zu ändern">
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">Rolle</label>
                            <select name="role" id="edit_role" class="form-input">
                                <option value="user">Benutzer</option>
                                <option value="admin">Admin</option>
                            </select>
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">Verknüpfter Mitarbeiter</label>
                            <select name="staff_id" id="edit_staff_id" class="form-input">
                                <option value="">— Kein Mitarbeiter —</option>
                                <% staffList.forEach(s => { %>
                                <option value="<%= s.id %>"><%= s.name %></option>
                                <% }); %>
                            </select>
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">Hauptsystem</label>
                            <select name="default_system_id" id="edit_system_id" class="form-input">
                                <option value="">— Kein System —</option>
                                <% systems.forEach(s => { %>
                                <option value="<%= s.id %>"><%= s.name %></option>
                                <% }); %>
                            </select>
                        </div>
                    </div>
                    <div>
                        <div class="rounded-2xl border border-slate-200 bg-slate-50 p-4">
                            <p class="text-sm font-semibold text-slate-900">Mail-Benachrichtigungen</p>
                            <p class="mt-1 text-xs text-slate-500">Benachrichtigungen werden nur versendet, wenn ein Mitarbeiter mit E-Mail hinterlegt ist.</p>
                            <div class="mt-4 space-y-3">
                                <label class="flex items-start gap-3 text-sm text-slate-700">
                                    <input id="edit_notify_new_tickets" type="checkbox" name="notify_new_tickets" class="mt-1 h-4 w-4 rounded border-slate-300 text-primary-600 focus:ring-primary-500">
                                    <span>Neue Tickets zum Hauptsystem melden</span>
                                </label>
                                <label class="flex items-start gap-3 text-sm text-slate-700">
                                    <input id="edit_notify_assigned_tickets" type="checkbox" name="notify_assigned_tickets" class="mt-1 h-4 w-4 rounded border-slate-300 text-primary-600 focus:ring-primary-500">
                                    <span>Bei neuer Zuweisung informieren</span>
                                </label>
                                <label class="flex items-start gap-3 text-sm text-slate-700">
                                    <input id="edit_notify_status_changes" type="checkbox" name="notify_status_changes" class="mt-1 h-4 w-4 rounded border-slate-300 text-primary-600 focus:ring-primary-500">
                                    <span>Bei Statusänderungen informieren</span>
                                </label>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="flex justify-end gap-3 border-t border-slate-200 pt-5">
                    <button type="button" onclick="closeEditModal()" class="btn-secondary">Abbrechen</button>
                    <button type="submit" class="btn-primary">Speichern</button>
                </div>
            </form>
        </div>
    </div>

    <script>
    const editModal = document.getElementById('editModal');

    function openEditModal(u) {
        document.getElementById('edit_username_display').textContent = u.username;
        document.getElementById('edit_role').value = u.role;
        document.getElementById('edit_staff_id').value = u.staff_id || '';
        document.getElementById('edit_system_id').value = u.default_system_id || '';
        document.getElementById('edit_notify_new_tickets').checked = !!u.notify_new_tickets;
        document.getElementById('edit_notify_assigned_tickets').checked = !!u.notify_assigned_tickets;
        document.getElementById('edit_notify_status_changes').checked = !!u.notify_status_changes;
        document.getElementById('editForm').action = '/admin/users/' + u.id + '/update';
        editModal.classList.remove('hidden');
        editModal.classList.add('flex');
        document.body.classList.add('overflow-hidden');
    }

    function closeEditModal() {
        editModal.classList.add('hidden');
        editModal.classList.remove('flex');
        document.body.classList.remove('overflow-hidden');
    }

    editModal.addEventListener('click', function(e) {
        if (e.target === editModal) closeEditModal();
    });

    document.addEventListener('keydown', function(event) {
        if (event.key === 'Escape' && !editModal.classList.contains('hidden')) {
            closeEditModal();
        }
    });
    </script>
</body>
</html>
