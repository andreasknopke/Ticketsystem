<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= project.name %> | Ticketsystem</title>
    <link rel="stylesheet" href="/style.css?v=2">
</head>
<body class="bg-gray-50 min-h-screen">
    <nav class="bg-white border-b border-gray-200 sticky top-0 z-50">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between h-16">
                <div class="flex items-center">
                    <div class="flex-shrink-0 flex items-center gap-2">
                        <div class="w-8 h-8 bg-primary-600 rounded-lg flex items-center justify-center">
                            <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 5v2m0 4v2m0 4v2M5 5a2 2 0 00-2 2v3a2 2 0 110 4v3a2 2 0 002 2h14a2 2 0 002-2v-3a2 2 0 110-4V7a2 2 0 00-2-2H5z"/>
                            </svg>
                        </div>
                        <a href="/" class="text-xl font-bold text-gray-900 hover:text-primary-600">Ticketsystem</a>
                    </div>
                    <div class="hidden md:ml-8 md:flex md:space-x-1">
                        <a href="/" class="nav-link">Dashboard</a>
                        <a href="/ticket/new" class="nav-link">Neues Ticket</a>
                        <a href="/projects" class="nav-link active">Projekte</a>
                        <% if (role === 'admin' || role === 'root') { %>
                        <a href="/stats" class="nav-link">Statistiken</a>
                        <a href="/admin/systems" class="nav-link">Systeme</a>
                        <a href="/admin/staff" class="nav-link">Mitarbeiter</a>
                        <% if (role === 'root') { %><a href="/admin/users" class="nav-link">Benutzer</a><% } %>
                        <% } %>
                    </div>
                </div>
                <div class="flex items-center gap-4">
                    <span class="text-sm text-gray-600"><%= user %> <span class="badge bg-gray-100 text-gray-700"><%= role %></span></span>
                    <a href="/account" class="btn-secondary text-sm">Account</a>
                    <a href="/logout" class="btn-secondary text-sm">Abmelden</a>
                </div>
            </div>
        </div>
    </nav>

    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        <nav class="flex mb-6" aria-label="Breadcrumb">
            <ol class="flex items-center space-x-4">
                <li><a href="/" class="text-gray-500 hover:text-gray-700">Dashboard</a></li>
                <li class="text-gray-400">/</li>
                <li><a href="/projects" class="text-gray-500 hover:text-gray-700">Projekte</a></li>
                <li class="text-gray-400">/</li>
                <li class="text-gray-900 font-medium"><%= project.name %></li>
            </ol>
        </nav>

        <div class="flex items-center justify-between mb-6">
            <div>
                <h1 class="text-2xl font-bold text-gray-900"><%= project.name %></h1>
                <% if (project.system_name) { %><p class="text-sm text-primary-600 mt-1"><%= project.system_name %></p><% } %>
            </div>
            <span class="badge text-lg px-4 py-1 <%= project.status === 'active' ? 'bg-green-100 text-green-800' : project.status === 'planning' ? 'bg-blue-100 text-blue-800' : project.status === 'maintenance' ? 'bg-yellow-100 text-yellow-800' : 'bg-gray-100 text-gray-800' %>">
                <%= {planning:'Planung',active:'Aktiv',maintenance:'Wartung',completed:'Abgeschlossen'}[project.status] || project.status %>
            </span>
        </div>

        <div class="flex flex-wrap gap-2 mb-6">
            <a href="/project/<%= project.id %>" class="btn-secondary text-sm font-medium bg-primary-50 text-primary-700">Dashboard</a>
            <a href="/project/<%= project.id %>/timeline" class="btn-secondary text-sm">Zeitleiste</a>
            <% if (canManage) { %><a href="/project/<%= project.id %>/milestones" class="btn-secondary text-sm">Meilensteine</a><% } %>
            <% if (canManage) { %><a href="/project/<%= project.id %>/keyusers" class="btn-secondary text-sm">Key-User</a><% } %>
            <a href="/project/<%= project.id %>/docs" class="btn-secondary text-sm">Wiki</a>
            <% if (canManage) { %><a href="/project/<%= project.id %>/github" class="btn-secondary text-sm">GitHub</a><% } %>
        </div>

        <p class="text-gray-600 mb-6"><%= project.description || 'Keine Beschreibung' %></p>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-8">
            <div class="card">
                <div class="card-body text-center">
                    <div class="text-3xl font-bold text-primary-600"><%= milestones.filter(m => m.status === 'completed').length %>/<%= milestones.length %></div>
                    <div class="text-sm text-gray-500 mt-1">Meilensteine erreicht</div>
                    <div class="mt-2 bg-gray-200 rounded-full h-2.5">
                        <div class="bg-primary-600 rounded-full h-2.5" style="width:<%= milestones.length > 0 ? Math.round(milestones.filter(m=>m.status==='completed').length/milestones.length*100) : 0 %>%"></div>
                    </div>
                </div>
            </div>
            <div class="card">
                <div class="card-body text-center">
                    <div class="text-3xl font-bold text-green-600"><%= keyUsers.length %></div>
                    <div class="text-sm text-gray-500 mt-1">Key-User</div>
                </div>
            </div>
            <div class="card">
                <div class="card-body text-center">
                    <div class="text-3xl font-bold text-orange-600"><%= tickets.length %></div>
                    <div class="text-sm text-gray-500 mt-1">Offene Tickets</div>
                </div>
            </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
            <div class="card">
                <div class="card-header"><h2 class="text-lg font-semibold text-gray-900">Meilensteine</h2></div>
                <div class="card-body">
                    <% if (milestones.length === 0) { %><p class="text-gray-500 text-sm">Keine Meilensteine definiert.</p><% } %>
                    <% milestones.slice(0, 5).forEach(m => { %>
                    <div class="flex items-center justify-between py-2 border-b border-gray-100 last:border-0">
                        <div class="flex items-center gap-2">
                            <span class="w-3 h-3 rounded-full flex-shrink-0" style="background:<%= m.color || '#2563eb' %>"></span>
                            <span class="text-sm <%= m.status === 'completed' ? 'line-through text-gray-400' : 'text-gray-900' %>"><%= m.title %></span>
                            <% if (m.phase) { %><span class="badge bg-gray-100 text-gray-600 text-xs">Phase <%= m.phase %></span><% } %>
                        </div>
                        <span class="badge text-xs <%= m.status === 'completed' ? 'bg-green-100 text-green-800' : m.status === 'in_progress' ? 'bg-blue-100 text-blue-800' : m.status === 'blocked' ? 'bg-red-100 text-red-800' : 'bg-gray-100 text-gray-600' %>"><%= {pending:'Offen',in_progress:'In Arbeit',completed:'Erledigt',blocked:'Blockiert'}[m.status] %></span>
                    </div>
                    <% }); %>
                </div>
            </div>

            <div class="card">
                <div class="card-header"><h2 class="text-lg font-semibold text-gray-900">Key-User</h2></div>
                <div class="card-body">
                    <% if (keyUsers.length === 0) { %><p class="text-gray-500 text-sm">Keine Key-User zugewiesen.</p><% } %>
                    <% keyUsers.forEach(k => { %>
                    <div class="flex items-center justify-between py-2 border-b border-gray-100 last:border-0">
                        <div>
                            <div class="text-sm font-medium text-gray-900"><%= k.staff_name %></div>
                            <div class="text-xs text-gray-500"><%= k.staff_email %></div>
                        </div>
                        <span class="badge text-xs <%= k.role === 'key_user' ? 'bg-blue-100 text-blue-800' : k.role === 'evaluator' ? 'bg-purple-100 text-purple-800' : 'bg-orange-100 text-orange-800' %>"><%= {key_user:'Key-User',evaluator:'Evaluator',decision_maker:'Entscheider'}[k.role] %></span>
                    </div>
                    <% }); %>
                </div>
            </div>
        </div>

        <% if (tickets.length > 0) { %>
        <div class="card mt-6">
            <div class="card-header"><h2 class="text-lg font-semibold text-gray-900">Offene Tickets</h2></div>
            <div class="card-body p-0">
                <div class="overflow-x-auto">
                    <table class="min-w-full divide-y divide-gray-200">
                        <thead class="bg-gray-50">
                            <tr>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">ID</th>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Titel</th>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Status</th>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Zugewiesen</th>
                            </tr>
                        </thead>
                        <tbody class="bg-white divide-y divide-gray-200">
                            <% tickets.forEach(t => { %>
                            <tr>
                                <td class="px-6 py-4 text-sm"><a href="/ticket/<%= t.id %>" class="text-primary-600">#<%= t.id %></a></td>
                                <td class="px-6 py-4 text-sm"><a href="/ticket/<%= t.id %>" class="text-gray-900"><%= t.title %></a></td>
                                <td class="px-6 py-4"><span class="badge <%= t.status === 'offen' ? 'bg-yellow-100 text-yellow-800' : t.status === 'in_bearbeitung' ? 'bg-blue-100 text-blue-800' : t.status === 'wartend' ? 'bg-purple-100 text-purple-800' : 'bg-green-100 text-green-800' %> text-xs"><%= t.status %></span></td>
                                <td class="px-6 py-4 text-sm text-gray-500"><%= t.assigned_name || 'Nicht zugewiesen' %></td>
                            </tr>
                            <% }); %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
        <% } %>

        <% if (docs.length > 0) { %>
        <div class="card mt-6">
            <div class="card-header"><h2 class="text-lg font-semibold text-gray-900">Letzte Wiki-Änderungen</h2></div>
            <div class="card-body">
                <% docs.forEach(d => { %>
                <div class="flex items-center justify-between py-2 border-b border-gray-100 last:border-0">
                    <a href="/project/<%= project.id %>/docs/<%= d.slug %>" class="text-primary-600 text-sm"><%= d.title %></a>
                    <span class="text-xs text-gray-500"><%= d.updated_at ? new Date(d.updated_at).toLocaleDateString('de-DE') : '' %></span>
                </div>
                <% }); %>
            </div>
        </div>
        <% } %>

        <% if (github) { %>
        <div class="card mt-6">
            <div class="card-header"><h2 class="text-lg font-semibold text-gray-900">GitHub Integration</h2></div>
            <div class="card-body">
                <p class="text-sm text-gray-600"><%= github.repo_owner %>/<%= github.repo_name %></p>
                <p class="text-xs text-gray-400 mt-1">Letzter Sync: <%= github.last_synced_at || 'Nie' %></p>
            </div>
        </div>
        <% } %>
    </main>
</body>
</html>
