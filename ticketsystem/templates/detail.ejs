<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Ticket #<%= ticket.id %> | Ticketsystem</title>
    <link rel="stylesheet" href="/style.css?v=2">
    <script src="/socket.io/socket.io.js"></script>
</head>
<body class="bg-gray-50 min-h-screen">
    <!-- Navigation -->
    <nav class="bg-white border-b border-gray-200 sticky top-0 z-50">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between h-16">
                <div class="flex items-center">
                    <div class="flex-shrink-0 flex items-center gap-2">
                        <div class="w-8 h-8 bg-primary-600 rounded-lg flex items-center justify-center">
                            <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 5v2m0 4v2m0 4v2M5 5a2 2 0 00-2 2v3a2 2 0 110 4v3a2 2 0 002 2h14a2 2 0 002-2v-3a2 2 0 110-4V7a2 2 0 00-2-2H5z"/>
                            </svg>
                        </div>
                        <a href="/" class="text-xl font-bold text-gray-900 hover:text-primary-600">Ticketsystem</a>
                    </div>
                    <div class="hidden md:ml-8 md:flex md:space-x-1">
                        <a href="/" class="nav-link">Dashboard</a>
                        <% if (role === 'admin' || role === 'root') { %>
                        <a href="/stats" class="nav-link">Statistiken</a>
                        <% } %>
                        <a href="/ticket/new" class="nav-link">Neues Ticket</a>
                        <a href="/projects" class="nav-link">Projekte</a>
                        <% if (role === 'admin' || role === 'root') { %>
                        <a href="/admin/systems" class="nav-link">Systeme</a>
                        <a href="/admin/staff" class="nav-link">Mitarbeiter</a>
                        <% } %>
                        <% if (role === 'root') { %>
                        <a href="/admin/users" class="nav-link">Benutzer</a>
                        <% } %>
                    </div>
                </div>
                <div class="flex items-center gap-4">
                    <span class="text-sm text-gray-600"><%= user %> <span class="badge bg-gray-100 text-gray-700"><%= role %></span></span>
                    <a href="/account" class="btn-secondary text-sm">Account</a>
                    <a href="/logout" class="btn-secondary text-sm">Abmelden</a>
                </div>
            </div>
        </div>
    </nav>

    <!-- Main Content -->
    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        <!-- Breadcrumbs -->
        <nav class="flex mb-6" aria-label="Breadcrumb">
            <ol class="flex items-center space-x-4">
                <li>
                    <a href="/" class="text-gray-500 hover:text-gray-700">Dashboard</a>
                </li>
                <li class="text-gray-400">/</li>
                <li class="text-gray-900 font-medium">Ticket #<%= ticket.id %></li>
            </ol>
        </nav>

        <!-- Header with Status -->
        <div class="mb-8">
            <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4">
                <div>
                    <h1 class="text-2xl font-bold text-gray-900"><%= ticket.title %></h1>
                    <p class="text-sm text-gray-500 mt-1">Erstellt am <%= formatDateTime(ticket.created_at) %></p>
                </div>
                <div class="flex items-center gap-3">
                    <span class="badge badge-status-<%= ticket.status %>"><%= toTitle(ticket.status) %></span>
                    <span class="badge badge-priority-<%= ticket.priority %>"><%= toTitle(ticket.priority) %></span>
                    <span class="badge badge-type-<%= ticket.type %>"><%= ticket.type.toUpperCase() %></span>
                    <% if (role === 'admin' || role === 'root') { %>
                    <form method="post" action="/ticket/<%= ticket.id %>/delete"
                        onsubmit="return confirm('Ticket #<%= ticket.id %> wirklich endgültig löschen? Dies kann nicht rückgängig gemacht werden.')">
                        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                        <button type="submit" class="btn-secondary text-sm text-red-600 border-red-200 hover:bg-red-50">
                            <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                            </svg>
                            Ticket löschen
                        </button>
                    </form>
                    <% } %>
                </div>
            </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
            <!-- Left Column: Main Content -->
            <div class="lg:col-span-2 space-y-6">
                <!-- SLA Status -->
                <% if (sla && sla.firstResponseDue) { %>
                <div class="card">
                    <div class="card-header">
                        <h3 class="text-lg font-semibold text-gray-900 flex items-center gap-2">
                            <svg class="w-5 h-5 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                            </svg>
                            SLA Status
                        </h3>
                    </div>
                    <div class="card-body">
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                            <div class="p-4 rounded-lg <%= sla.firstResponseStatus === 'fulfilled' ? 'bg-green-50 border border-green-200' : sla.firstResponseStatus === 'breached' ? 'bg-red-50 border border-red-200' : 'bg-amber-50 border border-amber-200' %>">
                                <div class="flex items-center gap-2 mb-2">
                                    <span class="text-sm font-medium text-gray-700">First Response</span>
                                    <% if (sla.firstResponseStatus === 'fulfilled') { %>
                                        <span class="badge bg-green-100 text-green-800">Erfüllt</span>
                                    <% } else if (sla.firstResponseStatus === 'breached') { %>
                                        <span class="badge bg-red-100 text-red-800">Verletzt</span>
                                    <% } else { %>
                                        <span class="badge bg-amber-100 text-amber-800">Ausstehend</span>
                                    <% } %>
                                </div>
                                <p class="text-xs text-gray-500">Fällig bis: <%= formatDateTime(sla.firstResponseDue) %></p>
                                <% if (sla.firstResponseAt) { %>
                                    <p class="text-xs text-gray-500">Erledigt: <%= formatDateTime(sla.firstResponseAt) %></p>
                                <% } %>
                            </div>
                            <div class="p-4 rounded-lg <%= sla.resolutionStatus === 'fulfilled' ? 'bg-green-50 border border-green-200' : sla.resolutionStatus === 'breached' ? 'bg-red-50 border border-red-200' : 'bg-amber-50 border border-amber-200' %>">
                                <div class="flex items-center gap-2 mb-2">
                                    <span class="text-sm font-medium text-gray-700">Resolution</span>
                                    <% if (sla.resolutionStatus === 'fulfilled') { %>
                                        <span class="badge bg-green-100 text-green-800">Erfüllt</span>
                                    <% } else if (sla.resolutionStatus === 'breached') { %>
                                        <span class="badge bg-red-100 text-red-800">Verletzt</span>
                                    <% } else { %>
                                        <span class="badge bg-amber-100 text-amber-800">Ausstehend</span>
                                    <% } %>
                                </div>
                                <p class="text-xs text-gray-500">Fällig bis: <%= formatDateTime(sla.resolutionDue) %></p>
                                <% if (sla.resolutionAt) { %>
                                    <p class="text-xs text-gray-500">Erledigt: <%= formatDateTime(sla.resolutionAt) %></p>
                                <% } %>
                            </div>
                        </div>
                    </div>
                </div>
                <% } %>

                <!-- Description -->
                <div class="card">
                    <div class="card-header">
                        <h3 class="text-lg font-semibold text-gray-900">Beschreibung</h3>
                    </div>
                    <div class="card-body">
                        <p class="text-gray-700 whitespace-pre-wrap"><%= ticket.description || 'Keine Beschreibung vorhanden.' %></p>
                    </div>
                </div>

                <!-- Comments -->
                <div class="card" id="comments-section">
                    <div class="card-header">
                        <h3 class="text-lg font-semibold text-gray-900">Kommentare (<%= notes.length %>)</h3>
                    </div>
                    <div class="card-body">
                        <div id="notes-container" class="space-y-4 mb-6">
                            <% notes.forEach(n => { %>
                            <div class="flex gap-4 <%= n.is_internal ? 'bg-yellow-50 p-4 rounded-lg border border-yellow-200' : '' %>">
                                <div class="flex-shrink-0">
                                    <div class="h-10 w-10 rounded-full bg-primary-100 flex items-center justify-center">
                                        <span class="text-sm font-medium text-primary-700"><%= n.author ? n.author.charAt(0).toUpperCase() : 'S' %></span>
                                    </div>
                                </div>
                                <div class="flex-1 min-w-0">
                                    <div class="flex items-center gap-2 mb-1">
                                        <span class="text-sm font-medium text-gray-900"><%= n.author %></span>
                                        <span class="text-xs text-gray-500"><%= formatDateTime(n.created_at) %></span>
                                        <% if (n.is_internal) { %>
                                            <span class="badge bg-yellow-100 text-yellow-800">Intern</span>
                                        <% } %>
                                    </div>
                                    <p class="text-sm text-gray-700 whitespace-pre-wrap"><%= n.text %></p>
                                </div>
                            </div>
                            <% }); %>
                            <% if (notes.length === 0) { %>
                                <p class="text-gray-500 text-center py-4">Noch keine Kommentare vorhanden.</p>
                            <% } %>
                        </div>

                        <!-- Add Comment Form -->
                        <form method="post" action="/ticket/<%= ticket.id %>/notes" class="border-t border-gray-200 pt-6">
                            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                            <div class="mb-4">
                                <label class="block text-sm font-medium text-gray-700 mb-2">Neuer Kommentar</label>
                                <textarea name="text" rows="4" class="form-textarea" placeholder="Ihre Nachricht..." required></textarea>
                            </div>
                            <div class="flex items-center justify-between">
                                <% if (canManageTickets) { %>
                                <label class="flex items-center">
                                    <input type="checkbox" name="is_internal" value="1" checked class="rounded border-gray-300 text-primary-600 focus:ring-primary-500">
                                    <span class="ml-2 text-sm text-gray-600">Intern (nur für Mitarbeiter sichtbar)</span>
                                </label>
                                <% } else { %>
                                <span class="text-sm text-gray-500">Öffentlicher Kommentar</span>
                                <% } %>
                                <button type="submit" class="btn-primary">Kommentar hinzufügen</button>
                            </div>
                        </form>
                    </div>
                </div>

                <!-- Activity Stream -->
                <% if (activities && activities.length > 0) { %>
                <div class="card">
                    <div class="card-header">
                        <h3 class="text-lg font-semibold text-gray-900">Aktivitäten</h3>
                    </div>
                    <div class="card-body">
                        <div class="flow-root">
                            <ul class="-mb-8">
                                <% activities.forEach((activity, index) => { %>
                                <li class="relative pb-8 <%= index === activities.length - 1 ? '' : '' %>">
                                    <div class="relative flex items-start space-x-3">
                                        <div class="relative">
                                            <div class="h-8 w-8 rounded-full bg-gray-100 flex items-center justify-center ring-8 ring-white">
                                                <span class="text-xs font-medium text-gray-600"><%= activity.actor ? activity.actor.charAt(0).toUpperCase() : 'S' %></span>
                                            </div>
                                        </div>
                                        <div class="min-w-0 flex-1">
                                            <div>
                                                <div class="text-sm">
                                                    <span class="font-medium text-gray-900"><%= activity.actor || 'System' %></span>
                                                    <span class="text-gray-500"> - <%= activity.action_text %></span>
                                                </div>
                                                <p class="mt-0.5 text-xs text-gray-500"><%= formatDateTime(activity.created_at) %></p>
                                            </div>
                                        </div>
                                    </div>
                                </li>
                                <% }); %>
                            </ul>
                        </div>
                    </div>
                </div>
                <% } %>

                <!-- KI-Workflow -->
                <div class="card" id="workflowCard">
                    <div class="card-header flex items-center justify-between">
                        <h3 class="text-lg font-semibold text-gray-900">KI-Workflow</h3>
                        <% if (canManageTickets) { %>
                        <button type="button" id="restartWorkflowBtn" class="btn-secondary text-xs">Neu starten</button>
                        <% } %>
                    </div>
                    <div class="card-body" id="workflowBody">
                        <p class="text-sm text-gray-500">Lade Workflow…</p>
                    </div>
                </div>
            </div>

            <!-- Right Column: Sidebar -->
            <div class="space-y-4">
                <% if (canManageTickets) { %>
                <!-- Actions -->
                <div class="card">
                    <div class="card-header py-3 px-5">
                        <h3 class="text-sm font-semibold text-gray-900 uppercase tracking-wide">Aktionen</h3>
                    </div>
                    <div class="card-body py-3 px-5 space-y-3">
                        <div>
                            <label class="block text-xs font-medium text-gray-500 mb-1.5">Status</label>
                            <form method="post" action="/ticket/<%= ticket.id %>/status">
                                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                <select name="status" class="form-select text-sm" onchange="this.form.submit()">
                                    <option value="offen" <%= ticket.status === 'offen' ? 'selected' : '' %>>Offen</option>
                                    <option value="in_bearbeitung" <%= ticket.status === 'in_bearbeitung' ? 'selected' : '' %>>In Bearbeitung</option>
                                    <option value="wartend" <%= ticket.status === 'wartend' ? 'selected' : '' %>>Wartend</option>
                                    <option value="geschlossen" <%= ticket.status === 'geschlossen' ? 'selected' : '' %>>Geschlossen</option>
                                </select>
                            </form>
                        </div>
                        <form method="post" action="/ticket/<%= ticket.id %>/assign" class="space-y-3">
                            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                            <div>
                                <label class="block text-xs font-medium text-gray-500 mb-1">System</label>
                                <select name="system_id" class="form-select text-sm">
                                    <option value="">Kein System</option>
                                    <% systems.forEach(sys => { %><option value="<%= sys.id %>" <%= ticket.system_id == sys.id ? 'selected' : '' %>><%= sys.name %></option><% }); %>
                                </select>
                            </div>
                            <div>
                                <label class="block text-xs font-medium text-gray-500 mb-1">Referenz-Repository (optional)</label>
                                <input type="text" name="reference_repo" class="form-input text-sm" list="reference-repos" value="<%= ticket.reference_repo_owner && ticket.reference_repo_name ? ticket.reference_repo_owner + '/' + ticket.reference_repo_name : '' %>" placeholder="owner/repo oder GitHub-URL">
                                <datalist id="reference-repos">
                                    <% systems.filter(sys => sys.repo_owner && sys.repo_name).forEach(sys => { %>
                                    <option value="<%= sys.repo_owner %>/<%= sys.repo_name %>"><%= sys.name %></option>
                                    <% }); %>
                                </datalist>
                                <p class="text-xs text-gray-500 mt-1">Nur Lesekontext/Vorlage; Ziel bleibt das System-Repository.</p>
                            </div>
                            <div>
                                <label class="block text-xs font-medium text-gray-500 mb-1">Zugewiesen an</label>
                                <select name="assigned_to" class="form-select text-sm">
                                    <option value="">Nicht zugewiesen</option>
                                    <% staffList.forEach(s => { %><option value="<%= s.id %>" <%= ticket.assigned_to == s.id ? 'selected' : '' %>><%= s.name %></option><% }); %>
                                </select>
                            </div>
                            <button type="submit" class="btn-primary w-full text-sm">Zuweisung speichern</button>
                        </form>
                    </div>
                </div>
                <% } %>

                <!-- Ticket Info -->
                <div class="card">
                    <div class="card-header">
                        <h3 class="text-lg font-semibold text-gray-900">Ticket-Informationen</h3>
                    </div>
                    <div class="card-body">
                        <dl class="space-y-3">
                            <div>
                                <dt class="text-sm font-medium text-gray-500">Typ</dt>
                                <dd class="mt-1 text-sm text-gray-900"><%= ticket.type.toUpperCase() %></dd>
                            </div>
                            <div>
                                <dt class="text-sm font-medium text-gray-500">Priorität</dt>
                                <dd class="mt-1 text-sm text-gray-900"><%= toTitle(ticket.priority) %></dd>
                            </div>
                            <div>
                                <dt class="text-sm font-medium text-gray-500">Dringlichkeit</dt>
                                <dd class="mt-1 text-sm text-gray-900">
                                    <% if (ticket.urgency === 'emergency') { %>
                                        <span class="text-red-600 font-medium">Notfall</span>
                                    <% } else if (ticket.urgency === 'safety') { %>
                                        <span class="text-orange-600 font-medium">Sicherheitsrelevant</span>
                                    <% } else { %>
                                        Normal
                                    <% } %>
                                </dd>
                            </div>
                            <div>
                                <dt class="text-sm font-medium text-gray-500">Standort</dt>
                                <dd class="mt-1 text-sm text-gray-900"><%= ticket.location || '-' %></dd>
                            </div>
                            <div>
                                <dt class="text-sm font-medium text-gray-500">Kontakt</dt>
                                <dd class="mt-1 text-sm text-gray-900">
                                    <% if (ticket.contact_email) { %>
                                    <a href="mailto:<%= ticket.contact_email %>?subject=Ticket%20%23<%= ticket.id %>%20-%20<%= encodeURIComponent(ticket.title) %>" class="text-primary-600 hover:text-primary-800"><%= ticket.contact_email %></a>
                                    <% } else { %>-<% } %>
                                </dd>
                            </div>
                            <div>
                                <dt class="text-sm font-medium text-gray-500">Erstellt von</dt>
                                <dd class="mt-1 text-sm text-gray-900"><%= ticket.username || '-' %></dd>
                            </div>
                            <div>
                                <dt class="text-sm font-medium text-gray-500">Referenz-Repository</dt>
                                <dd class="mt-1 text-sm text-gray-900">
                                    <% if (ticket.reference_repo_owner && ticket.reference_repo_name) { %>
                                    <a href="https://github.com/<%= ticket.reference_repo_owner %>/<%= ticket.reference_repo_name %>" target="_blank" class="text-primary-600 hover:text-primary-800"><%= ticket.reference_repo_owner %>/<%= ticket.reference_repo_name %></a>
                                    <% } else { %>-<% } %>
                                </dd>
                            </div>
                            <div>
                                <dt class="text-sm font-medium text-gray-500">Deadline</dt>
                                <dd class="mt-1 text-sm text-gray-900">
                                    <% if (canManageTickets) { %>
                                    <form method="post" action="/ticket/<%= ticket.id %>/deadline" class="flex gap-2">
                                        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                        <input type="datetime-local" name="deadline" 
                                            value="<%= ticket.deadline ? new Date(ticket.deadline).toISOString().slice(0,16) : '' %>"
                                            class="form-input text-sm flex-1">
                                        <button type="submit" class="btn-secondary text-sm">💾</button>
                                    </form>
                                    <% } else { %>
                                    <%= ticket.deadline ? formatDateTime(ticket.deadline) : '-' %>
                                    <% } %>
                                </dd>
                            </div>
                        </dl>
                    </div>
                </div>

                <!-- Feedback -->
                <% if (ticket.status === 'geschlossen' && !feedback) { %>
                <div class="card border-primary-200">
                    <div class="card-header bg-primary-50 border-primary-200">
                        <h3 class="text-lg font-semibold text-primary-900">Feedback abgeben</h3>
                    </div>
                    <div class="card-body">
                        <form id="feedback-form" class="space-y-4">
                            <div>
                                <label class="block text-sm font-medium text-gray-700 mb-2">Bewertung</label>
                                <div class="flex gap-2">
                                    <% for(let i = 1; i <= 5; i++) { %>
                                    <button type="button" class="feedback-star text-2xl text-gray-300 hover:text-yellow-400 transition-colors" data-rating="<%= i %>">★</button>
                                    <% } %>
                                </div>
                                <input type="hidden" name="rating" id="rating-input">
                            </div>
                            <div>
                                <label class="block text-sm font-medium text-gray-700 mb-1">Kommentar (optional)</label>
                                <textarea name="comment" rows="3" class="form-textarea text-sm" placeholder="Ihr Feedback..."></textarea>
                            </div>
                            <button type="submit" class="btn-primary w-full">Feedback senden</button>
                        </form>
                    </div>
                </div>
                <% } else if (feedback) { %>
                <div class="card">
                    <div class="card-header">
                        <h3 class="text-lg font-semibold text-gray-900">Feedback</h3>
                    </div>
                    <div class="card-body">
                        <div class="flex items-center gap-1 mb-2">
                            <% for(let i = 1; i <= 5; i++) { %>
                            <svg class="w-5 h-5 <%= i <= feedback.rating ? 'text-yellow-400' : 'text-gray-300' %>" fill="currentColor" viewBox="0 0 20 20">
                                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                            </svg>
                            <% } %>
                        </div>
                        <% if (feedback.comment) { %>
                        <p class="text-sm text-gray-600"><%= feedback.comment %></p>
                        <% } %>
                        <p class="text-xs text-gray-400 mt-2"><%= formatDateTime(feedback.created_at) %></p>
                    </div>
                </div>
                <% } %>
            </div>
        </div>
    </main>

    <script>
        // Socket.io für Echtzeit-Updates
        const socket = io();
        const ticketId = '<%= ticket.id %>';
        const csrfToken = '<%= csrfToken %>';
        const canManageTickets = <%= canManageTickets ? 'true' : 'false' %>;
        
        socket.emit('join-ticket', ticketId);
        
        socket.on('new-note', (data) => {
            // Seite neu laden um neuen Kommentar anzuzeigen
            location.reload();
        });
        
        socket.on('ticket-updated', (data) => {
            if (data && Number(data.ticketId) === Number(ticketId)) {
                location.reload();
            }
        });
        
        // Feedback Form
        const feedbackForm = document.getElementById('feedback-form');
        if (feedbackForm) {
            const stars = document.querySelectorAll('.feedback-star');
            const ratingInput = document.getElementById('rating-input');
            
            stars.forEach(star => {
                star.addEventListener('click', () => {
                    const rating = star.dataset.rating;
                    ratingInput.value = rating;
                    stars.forEach((s, i) => {
                        s.classList.toggle('text-yellow-400', i < rating);
                        s.classList.toggle('text-gray-300', i >= rating);
                    });
                });
            });
            
            feedbackForm.addEventListener('submit', async (e) => {
                e.preventDefault();
                const formData = new FormData(feedbackForm);
                const rating = formData.get('rating');
                const comment = formData.get('comment');
                
                if (!rating) {
                    alert('Bitte geben Sie eine Bewertung ab.');
                    return;
                }
                
                try {
                    const response = await fetch(`/api/tickets/${ticketId}/feedback`, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ rating: parseInt(rating), comment })
                    });
                    
                    if (response.ok) {
                        location.reload();
                    } else {
                        alert('Fehler beim Speichern des Feedbacks.');
                    }
                } catch (err) {
                    alert('Fehler beim Speichern des Feedbacks.');
                }
            });
        }

        // --- KI-Workflow ---
        const STAGE_LABELS = {
            triage: 'Triage Reviewer',
            security: 'Security & Privacy Reviewer',
            planning: 'Solution Architect (Planner)',
            integration: 'Integration / Architecture Reviewer',
            code_review: 'Code Review & Deployment Reviewer',
            approval: 'Final Approver',
            coding: 'Coding Bot'
        };
        const STATUS_BADGE = {
            pending: 'bg-gray-100 text-gray-700',
            in_progress: 'bg-blue-100 text-blue-700',
            waiting_human: 'bg-amber-100 text-amber-800',
            done: 'bg-emerald-100 text-emerald-700',
            skipped: 'bg-slate-100 text-slate-500',
            failed: 'bg-red-100 text-red-700',
            rejected: 'bg-red-100 text-red-700'
        };

        function escapeHtml(s) {
            return String(s ?? '').replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));
        }

        function renderOutput(step) {
            if (!step.output) return '';
            const o = step.output;
            const parts = [];
            if (o.summary) parts.push(`<p class="text-sm text-gray-700">${escapeHtml(o.summary)}</p>`);
            if (o.decision) parts.push(`<p class="text-xs"><span class="font-semibold">Entscheidung:</span> ${escapeHtml(o.decision)}${o.coding_level ? ` <span class="badge bg-indigo-100 text-indigo-700">Level: ${escapeHtml(o.coding_level)}</span>` : ''}</p>`);
            if (o.reason) parts.push(`<p class="text-xs text-gray-600">${escapeHtml(o.reason)}</p>`);
            if (o.suggested_action) parts.push(`<p class="text-xs"><span class="font-semibold">Naechste Handlung:</span> ${escapeHtml(o.suggested_action)}</p>`);
            if (o.split_reason) parts.push(`<p class="text-xs"><span class="font-semibold">Split-Vorschlag:</span> ${escapeHtml(o.split_reason)}</p>`);
            if (Array.isArray(o.split_tickets) && o.split_tickets.length) {
                const items = o.split_tickets.map((t, idx) => `<li class="text-xs text-gray-700"><span class="font-semibold">${idx + 1}. ${escapeHtml(t.title || '')}</span>${t.system_id ? ` · System ${escapeHtml(String(t.system_id))}` : ''}<br>${escapeHtml(t.description || '')}</li>`).join('');
                parts.push(`<details class="mt-2"><summary class="cursor-pointer text-xs text-primary-700">Vorgeschlagene Teiltickets (${o.split_tickets.length})</summary><ol class="mt-2 space-y-2 list-decimal list-inside">${items}</ol></details>`);
            }
            if (Array.isArray(o.created_ticket_ids) && o.created_ticket_ids.length) {
                const links = o.created_ticket_ids.map(id => `<a href="/ticket/${encodeURIComponent(id)}" class="text-primary-700 hover:underline">#${escapeHtml(String(id))}</a>`).join(', ');
                parts.push(`<p class="text-xs"><span class="font-semibold">Erzeugte Tickets:</span> ${links}</p>`);
            }
            if (o.verdict) parts.push(`<p class="text-xs"><span class="font-semibold">Verdikt:</span> ${escapeHtml(o.verdict)}${o.recommended_complexity ? ` · <span class="badge bg-indigo-100 text-indigo-700">Empf. Level: ${escapeHtml(o.recommended_complexity)}</span>` : ''}</p>`);
            if (o.rationale) parts.push(`<p class="text-xs text-gray-600">${escapeHtml(o.rationale)}</p>`);
            if (Array.isArray(o.findings) && o.findings.length) {
                parts.push(`<p class="text-xs mt-1"><span class="font-semibold">Funde:</span> ${o.findings.length}</p>`);
            }
            if (step.stage === 'coding') {
                if (o.pr_url) {
                    parts.push(`<p class="text-xs mt-1"><span class="font-semibold">Pull Request:</span> <a href="${escapeHtml(o.pr_url)}" target="_blank" class="text-primary-700 hover:underline">#${escapeHtml(String(o.pr_number || ''))} (${escapeHtml(o.branch || '')})</a></p>`);
                } else if (o.pr_error) {
                    parts.push(`<p class="text-xs text-red-700 mt-1">PR-Erstellung fehlgeschlagen: ${escapeHtml(o.pr_error)}</p>`);
                }
                if (Array.isArray(o.files) && o.files.length) {
                    parts.push(`<p class="text-xs mt-1"><span class="font-semibold">Geaenderte Dateien:</span> ${o.files.length}</p>`);
                }
            }
            if (o.note) parts.push(`<p class="text-xs"><span class="font-semibold">Notiz:</span> ${escapeHtml(o.note)}</p>`);
            if (step.output_html) {
                parts.push(`<details class="mt-2" open><summary class="cursor-pointer text-xs font-semibold text-primary-700">Vollständige Ausgabe</summary><div class="prose prose-sm max-w-none mt-2 p-3 bg-gray-50 rounded border border-gray-200">${step.output_html}</div></details>`);
            } else if (o.coding_prompt) {
                parts.push(`<details class="mt-2"><summary class="cursor-pointer text-xs text-primary-700">Coding-Prompt</summary><pre class="mt-1 whitespace-pre-wrap text-xs bg-gray-50 p-2 rounded">${escapeHtml(o.coding_prompt)}</pre></details>`);
            }
            return parts.join('');
        }

        function renderArtifacts(stepId, artifacts) {
            const items = (artifacts || []).filter(a => a.step_id === stepId);
            if (!items.length) return '';
            const links = items.map(a => {
                const sizeKb = a.size ? (a.size / 1024).toFixed(1) + ' KB' : '';
                const inlineable = a.mime_type && (a.mime_type.startsWith('text/') || a.mime_type === 'application/json');
                const view = inlineable ? `<a href="/api/tickets/${ticketId}/workflow/artifacts/${a.id}?inline=1" target="_blank" class="text-primary-700 hover:underline">Ansehen</a>` : '';
                const dl = `<a href="/api/tickets/${ticketId}/workflow/artifacts/${a.id}" class="text-primary-700 hover:underline">Download</a>`;
                return `<li class="text-xs flex items-center gap-2"><span class="text-gray-700">📄 ${escapeHtml(a.filename)}</span><span class="text-gray-400">${escapeHtml(sizeKb)}</span>${view ? '· ' + view : ''} · ${dl}</li>`;
            }).join('');
            return `<div class="mt-2 border-t border-dashed border-gray-200 pt-2"><p class="text-xs font-semibold text-gray-600 mb-1">Artefakte</p><ul class="space-y-1">${links}</ul></div>`;
        }

        function renderBriefing(briefing, artifacts) {
            if (!briefing) return '';
            const blocks = [];
            if (briefing.coding_prompt) {
                blocks.push(`<details open class="mb-3"><summary class="cursor-pointer text-sm font-semibold text-gray-800">🧾 Coding-Prompt (Security-bereinigt)</summary><pre class="mt-2 whitespace-pre-wrap text-xs bg-gray-50 p-3 rounded border border-gray-200">${escapeHtml(briefing.coding_prompt)}</pre></details>`);
            }
            if (briefing.implementation_plan_html) {
                blocks.push(`<details open class="mb-3"><summary class="cursor-pointer text-sm font-semibold text-gray-800">🏗️ Architect Plan</summary><div class="prose prose-sm max-w-none mt-2 p-3 bg-emerald-50 rounded border border-emerald-200">${briefing.implementation_plan_html}</div></details>`);
            }
            if (briefing.integration_assessment_html) {
                blocks.push(`<details open class="mb-3"><summary class="cursor-pointer text-sm font-semibold text-gray-800">🔗 Integration / Architecture Review (vor Coding)</summary><div class="prose prose-sm max-w-none mt-2 p-3 bg-amber-50 rounded border border-amber-200">${briefing.integration_assessment_html}</div></details>`);
            }
            if (briefing.merge_review_html) {
                blocks.push(`<details open class="mb-3"><summary class="cursor-pointer text-sm font-semibold text-gray-800">🚀 Code Review & Deployment-Check (nach Coding)</summary><div class="prose prose-sm max-w-none mt-2 p-3 bg-rose-50 rounded border border-rose-200">${briefing.merge_review_html}</div></details>`);
            }
            const allArt = (artifacts || []).map(a => {
                const inlineable = a.mime_type && (a.mime_type.startsWith('text/') || a.mime_type === 'application/json');
                const view = inlineable ? `<a href="/api/tickets/${ticketId}/workflow/artifacts/${a.id}?inline=1" target="_blank" class="text-primary-700 hover:underline">Ansehen</a>` : '';
                const dl = `<a href="/api/tickets/${ticketId}/workflow/artifacts/${a.id}" class="text-primary-700 hover:underline">Download</a>`;
                return `<li class="text-xs flex items-center gap-2"><span class="text-gray-700">📄 ${escapeHtml(a.filename)}</span><span class="text-gray-400">${escapeHtml(a.stage || '')}</span>${view ? '· ' + view : ''} · ${dl}</li>`;
            }).join('');
            if (allArt) {
                blocks.push(`<details class="mb-1"><summary class="cursor-pointer text-sm font-semibold text-gray-800">📎 Alle Artefakte (${(artifacts || []).length})</summary><ul class="mt-2 space-y-1">${allArt}</ul></details>`);
            }
            if (!blocks.length) return '';
            return `<div class="mt-3 border-t-2 border-primary-300 pt-3"><p class="text-sm font-bold text-primary-800 mb-2">📋 Approver-Briefing</p>${blocks.join('')}</div>`;
        }

        function renderApprover(step, runId, allSteps, codingBotChoices) {
            if (!canManageTickets) return '';
            codingBotChoices = codingBotChoices || {};
            // Phase ermitteln: Dispatch (kein Coding done) oder Final (Coding done existiert)
            const codingDone = (allSteps || []).some(s => s.stage === 'coding' && s.status === 'done');
            const isDispatch = !codingDone;
            const triage = (allSteps || []).find(s => s.stage === 'triage' && s.output && s.output.decision === 'split');
            // Wenn ein vorheriger Approval-Step den Split bereits abgelehnt hat,
            // ist die aktuelle Approval-Phase die normale Dispatch-Entscheidung.
            const splitAlreadyRejected = (allSteps || []).some(s =>
                s.stage === 'approval' && s.status === 'done'
                && s.output && s.output.decision === 'reject_split'
            );
            const splitReview = isDispatch && triage && !splitAlreadyRejected
                && Array.isArray(triage.output.split_tickets) && triage.output.split_tickets.length;
            // Empfohlene Komplexitaet aus Integration-Step lesen
            let recommended = null;
            if (isDispatch && !splitReview) {
                const integ = (allSteps || []).find(s => s.stage === 'integration' && s.output && s.output.recommended_complexity);
                if (integ) recommended = integ.output.recommended_complexity;
            }
            const recHint = recommended
                ? `<p class="text-xs text-primary-700 mb-2">Empfehlung Integration-Reviewer: <strong>${escapeHtml(recommended)}</strong></p>`
                : '';
            const splitProposal = splitReview ? JSON.stringify(triage.output.split_tickets, null, 2) : '';
            const renderDispatchChoice = (level, label, emphasized) => {
                const choices = Array.isArray(codingBotChoices[level]) ? codingBotChoices[level] : [];
                const selectId = `dispatch-bot-${level}-${step.id}`;
                const select = choices.length > 1
                    ? `<select id="${selectId}" class="form-input text-xs min-w-56">
                        <option value="">Konkreten Bot waehlen...</option>
                        ${choices.map(bot => `<option value="${escapeHtml(String(bot.id))}">${escapeHtml(bot.name)}</option>`).join('')}
                    </select>`
                    : '';
                const hint = choices.length > 1
                    ? `<p class="text-xs text-amber-700">Mehrere ${escapeHtml(level)}-Bots verfuegbar. Auswahl ist erforderlich.</p>`
                    : '';
                return `<div class="space-y-1">
                    <div class="flex flex-wrap items-center gap-2">
                        <button data-decision="dispatch_${level}" data-level="${level}" class="dec-btn ${emphasized ? 'btn-primary' : 'btn-secondary'} text-xs">${label}</button>
                        ${select}
                    </div>
                    ${hint}
                </div>`;
            };
            const buttons = splitReview ? `
                    <button data-decision="approve_split" class="dec-btn btn-primary text-xs">Split anwenden</button>
                    <button data-decision="reject_split" class="dec-btn btn-secondary text-xs">Ohne Split weiter</button>
            ` : isDispatch ? `
                    ${renderDispatchChoice('medium', 'Dispatch → Medium-Coder', recommended === 'medium')}
                    ${renderDispatchChoice('high', 'Dispatch → High-Coder', recommended === 'high')}
                    <button data-decision="rejected" class="dec-btn btn-secondary text-xs">Reject</button>
                    <button data-decision="unclear" class="dec-btn btn-secondary text-xs">Rueckfrage / unklar</button>
                    <button data-decision="handoff" class="dec-btn btn-secondary text-xs">Handoff</button>
            ` : `
                    <button data-decision="approved" class="dec-btn btn-primary text-xs">Approve (Merge)</button>
                    <button data-decision="rework" class="dec-btn btn-secondary text-xs">Rework / Re-Dispatch</button>
                    <button data-decision="rejected" class="dec-btn btn-secondary text-xs">Reject</button>
            `;
            const title = splitReview ? 'Split-Entscheidung' : (isDispatch ? 'Dispatch-Entscheidung' : 'Finale Entscheidung (nach Coding-Bot)');
            return `
            <div class="mt-3 border-t border-gray-200 pt-3">
                <p class="text-xs font-semibold text-gray-700 mb-2">${title}</p>
                ${splitReview ? `<p class="text-xs text-amber-700 mb-2">Triage empfiehlt, das Ticket in mehrere Einzeltickets aufzuteilen. Du kannst den JSON-Vorschlag vor dem Anwenden anpassen.</p>
                <textarea id="split-proposal-${step.id}" rows="10" class="form-input font-mono text-xs w-full">${escapeHtml(splitProposal)}</textarea>` : ''}
                ${recHint}
                <textarea id="dec-note-${step.id}" rows="2" class="form-input text-xs w-full" placeholder="Notiz (optional)"></textarea>
                <div class="mt-2 flex flex-wrap gap-2">
                    ${buttons}
                </div>
            </div>`;
        }

        let lastWorkflowHash = '';

        function snapshotInputs(body) {
            const snap = {};
            body.querySelectorAll('textarea[id], input[type="text"][id]').forEach(el => {
                snap[el.id] = el.value;
            });
            // Aktiv fokussiertes Element merken
            const active = document.activeElement;
            if (active && active.id && body.contains(active)) {
                snap.__focus = active.id;
                snap.__selStart = active.selectionStart;
                snap.__selEnd = active.selectionEnd;
            }
            return snap;
        }

        function restoreInputs(body, snap) {
            if (!snap) return;
            Object.keys(snap).forEach(id => {
                if (id.startsWith('__')) return;
                const el = body.querySelector('#' + CSS.escape(id));
                if (el && !el.value) el.value = snap[id];
                else if (el && snap[id]) el.value = snap[id];
            });
            if (snap.__focus) {
                const el = body.querySelector('#' + CSS.escape(snap.__focus));
                if (el) {
                    el.focus();
                    if (typeof snap.__selStart === 'number') {
                        try { el.setSelectionRange(snap.__selStart, snap.__selEnd); } catch(_) {}
                    }
                }
            }
        }

        function loadWorkflow(force) {
            const body = document.getElementById('workflowBody');
            fetch(`/api/tickets/${ticketId}/workflow`).then(r => r.json()).then(data => {
                if (!data.run) {
                    body.innerHTML = '<p class="text-sm text-gray-500">Kein KI-Workflow gestartet.</p>';
                    return;
                }
                // Hash der relevanten Daten -> nur bei echter Aenderung neu rendern
                const hashSrc = JSON.stringify({
                    s: data.run.status,
                    st: data.steps.map(s => [s.id, s.status, s.finished_at]),
                    a: (data.artifacts || []).map(a => a.id)
                });
                if (!force && hashSrc === lastWorkflowHash) return;
                lastWorkflowHash = hashSrc;

                const inputSnap = snapshotInputs(body);

                const run = data.run;
                let html = `<div class="mb-3 flex items-center justify-between">
                    <div class="text-xs text-gray-500">Run #${run.id} · gestartet ${new Date(run.started_at + 'Z').toLocaleString('de-DE')}</div>
                    <span class="badge ${STATUS_BADGE[run.status] || 'bg-gray-100 text-gray-700'}">${run.status}</span>
                </div>`;
                html += '<ol class="space-y-3">';
                const artifacts = data.artifacts || [];
                data.steps.forEach(step => {
                    const badge = STATUS_BADGE[step.status] || 'bg-gray-100 text-gray-700';
                    const isApproverWaiting = step.stage === 'approval' && step.status === 'waiting_human';
                    const canRerun = canManageTickets && step.status === 'done' && ['triage','security','planning','integration'].includes(step.stage);
                    html += `<li class="rounded border border-gray-200 p-3" data-step-id="${step.id}">
                        <div class="flex items-center justify-between">
                            <div>
                                <div class="text-sm font-medium text-gray-900">${escapeHtml(STAGE_LABELS[step.stage] || step.stage)}</div>
                                <div class="text-xs text-gray-500">${escapeHtml(step.staff_name || '–')} ${step.executor_kind ? `· ${escapeHtml(step.executor_kind)}` : ''} ${step.provider ? `· ${escapeHtml(step.provider)}` : ''}</div>
                            </div>
                            <span class="badge ${badge}">${step.status}</span>
                        </div>
                        ${step.error ? `<p class="mt-2 text-xs text-red-700">${escapeHtml(step.error)}</p>` : ''}
                        <div class="mt-2">${renderOutput(step)}</div>
                        ${renderArtifacts(step.id, artifacts)}
                        ${isApproverWaiting ? renderBriefing(data.ticket_briefing, artifacts) : ''}
                        ${step.status === 'waiting_human' ? renderApprover(step, run.id, data.steps, data.coding_bot_choices) : ''}
                        ${canRerun ? renderRerun(step) : ''}
                    </li>`;
                });
                html += '</ol>';
                body.innerHTML = html;
                restoreInputs(body, inputSnap);

                body.querySelectorAll('.dec-btn').forEach(btn => {
                    btn.addEventListener('click', async (ev) => {
                        const li = ev.target.closest('li');
                        const stepId = li.dataset.stepId;
                        const decision = ev.target.dataset.decision;
                        const note = document.getElementById('dec-note-' + stepId)?.value || '';
                        let selected_staff_id = null;
                        const dispatchLevel = ev.target.dataset.level;
                        if (dispatchLevel) {
                            const select = document.getElementById(`dispatch-bot-${dispatchLevel}-${stepId}`);
                            if (select) {
                                if (!select.value) {
                                    alert('Bitte einen konkreten Coding-Bot auswaehlen.');
                                    return;
                                }
                                selected_staff_id = Number(select.value);
                            }
                        }
                        let split_tickets = null;
                        if (decision === 'approve_split') {
                            const raw = document.getElementById('split-proposal-' + stepId)?.value || '[]';
                            try {
                                split_tickets = JSON.parse(raw);
                            } catch (e) {
                                alert('Split-Vorschlag ist kein gueltiges JSON-Array.');
                                return;
                            }
                            if (!Array.isArray(split_tickets)) {
                                alert('Split-Vorschlag muss ein JSON-Array sein.');
                                return;
                            }
                        }
                        ev.target.disabled = true;
                        try {
                            const resp = await fetch(`/api/tickets/${ticketId}/workflow/steps/${stepId}/decision`, {
                                method: 'POST',
                                headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': csrfToken },
                                body: JSON.stringify({ decision, note, split_tickets, selected_staff_id })
                            });
                            const json = await resp.json();
                            if (!resp.ok) { alert('Fehler: ' + (json.error || resp.status)); ev.target.disabled = false; return; }
                            loadWorkflow(true);
                        } catch (err) {
                            alert('Fehler: ' + err.message);
                            ev.target.disabled = false;
                        }
                    });
                });

                body.querySelectorAll('.rerun-btn').forEach(btn => {
                    btn.addEventListener('click', async (ev) => {
                        const li = ev.target.closest('li');
                        const stepId = li.dataset.stepId;
                        const stage = ev.target.dataset.stage;
                        const extraInfo = document.getElementById('rerun-info-' + stepId)?.value || '';
                        if (!extraInfo.trim()) {
                            alert('Bitte Zusatzinformation eingeben (was soll der Bot zusaetzlich beruecksichtigen?).');
                            return;
                        }
                        if (!confirm('Stage "' + stage + '" mit Zusatzinfo erneut ausfuehren?')) return;
                        ev.target.disabled = true;
                        try {
                            const resp = await fetch(`/api/tickets/${ticketId}/workflow/steps/${stepId}/rerun`, {
                                method: 'POST',
                                headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': csrfToken },
                                body: JSON.stringify({ extra_info: extraInfo })
                            });
                            const json = await resp.json();
                            if (!resp.ok) { alert('Fehler: ' + (json.error || resp.status)); ev.target.disabled = false; return; }
                            loadWorkflow(true);
                        } catch (err) {
                            alert('Fehler: ' + err.message);
                            ev.target.disabled = false;
                        }
                    });
                });
            }).catch(() => {
                body.innerHTML = '<p class="text-sm text-red-600">Workflow konnte nicht geladen werden.</p>';
            });
        }

        function renderRerun(step) {
            return `
            <details class="mt-3 border-t border-gray-200 pt-3">
                <summary class="cursor-pointer text-xs font-semibold text-gray-700">🔄 Erneut prüfen mit Zusatzinfo</summary>
                <p class="text-xs text-gray-500 mt-2">Hier Zusatzinformation eingeben (z. B. „Bot hat das DLP-Risiko in Feld X übersehen"). Die Stage wird mit dieser Info erneut ausgeführt; nachfolgende Stages laufen automatisch neu.</p>
                <textarea id="rerun-info-${step.id}" rows="3" class="form-input text-xs w-full mt-2" placeholder="Was soll der Bot zusaetzlich beruecksichtigen?"></textarea>
                <div class="mt-2">
                    <button data-stage="${escapeHtml(step.stage)}" class="rerun-btn btn-secondary text-xs">Stage neu ausführen</button>
                </div>
            </details>`;
        }

        const restartBtn = document.getElementById('restartWorkflowBtn');
        if (restartBtn) {
            restartBtn.addEventListener('click', async () => {
                if (!confirm('Workflow neu starten?')) return;
                restartBtn.disabled = true;
                try {
                    const resp = await fetch(`/api/tickets/${ticketId}/workflow/restart`, {
                        method: 'POST',
                        headers: { 'X-CSRF-Token': csrfToken }
                    });
                    if (!resp.ok) {
                        const json = await resp.json().catch(() => ({}));
                        alert('Fehler: ' + (json.error || resp.status));
                    }
                    loadWorkflow();
                } finally {
                    restartBtn.disabled = false;
                }
            });
        }

        ['workflow:started','workflow:step','workflow:waiting_human','workflow:completed','workflow:failed','workflow:no_staff'].forEach(ev => {
            socket.on(ev, (payload) => {
                if (payload && payload.ticketId && Number(payload.ticketId) === Number(ticketId)) loadWorkflow();
            });
        });

        loadWorkflow();
        setInterval(loadWorkflow, 15000);
    </script>
</body>
</html>
