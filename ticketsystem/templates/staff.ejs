<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mitarbeiter | Ticketsystem</title>
    <link rel="stylesheet" href="/style.css?v=2">
</head>
<body class="bg-gray-50 min-h-screen">
    <!-- Navigation -->
    <nav class="bg-white border-b border-gray-200 sticky top-0 z-50">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between h-16">
                <div class="flex items-center">
                    <div class="flex-shrink-0 flex items-center gap-2">
                        <div class="w-8 h-8 bg-primary-600 rounded-lg flex items-center justify-center">
                            <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 5v2m0 4v2m0 4v2M5 5a2 2 0 00-2 2v3a2 2 0 110 4v3a2 2 0 002 2h14a2 2 0 002-2v-3a2 2 0 110-4V7a2 2 0 00-2-2H5z"/>
                            </svg>
                        </div>
                        <a href="/" class="text-xl font-bold text-gray-900 hover:text-primary-600">Ticketsystem</a>
                    </div>
                    <div class="hidden md:ml-8 md:flex md:space-x-1">
                        <a href="/" class="nav-link">Dashboard</a>
                        <% if (role === 'admin' || role === 'root') { %>
                        <a href="/stats" class="nav-link">Statistiken</a>
                        <% } %>
                        <a href="/projects" class="nav-link">Projekte</a>
                        <a href="/admin/systems" class="nav-link">Systeme</a>
                        <a href="/admin/staff" class="nav-link active">Mitarbeiter</a>
                        <% if (role === 'root') { %>
                        <a href="/admin/users" class="nav-link">Benutzer</a>
                        <% } %>
                    </div>
                </div>
                <div class="flex items-center gap-4">
                    <span class="text-sm text-gray-600"><%= user %> <span class="badge bg-gray-100 text-gray-700"><%= role %></span></span>
                    <a href="/account" class="btn-secondary text-sm">Account</a>
                    <a href="/logout" class="btn-secondary text-sm">Abmelden</a>
                </div>
            </div>
        </div>
    </nav>

    <main class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        <nav class="flex mb-6" aria-label="Breadcrumb">
            <ol class="flex items-center space-x-4">
                <li><a href="/" class="text-gray-500 hover:text-gray-700">Dashboard</a></li>
                <li class="text-gray-400">/</li>
                <li class="text-gray-900 font-medium">Mitarbeiter</li>
            </ol>
        </nav>

        <div class="card mb-8">
            <div class="card-header flex items-center justify-between">
                <h2 class="text-lg font-semibold text-gray-900">Mitarbeiter und KI-Bots</h2>
                <button type="button" id="newStaffBtn" class="btn-primary text-sm">+ Mitarbeiter / KI-Bot</button>
            </div>
            <div class="card-body text-sm text-slate-600">
                Mitarbeiter können <strong>Menschen</strong> oder <strong>KI-Bots</strong> sein. Jeder kann eine oder
                mehrere Workflow-Rollen übernehmen (Triage, Security &amp; Privacy, Planning, Integration, Final Approval).
                Bei mehreren Kandidaten pro Rolle wird per Round-Robin zugewiesen.
            </div>
        </div>

        <div class="card">
            <div class="card-header">
                <h2 class="text-lg font-semibold text-gray-900">Übersicht</h2>
            </div>
            <div class="card-body p-0">
                <div class="overflow-x-auto">
                    <table class="min-w-full divide-y divide-gray-200">
                        <thead class="bg-gray-50">
                            <tr>
                                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">ID</th>
                                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Name</th>
                                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Typ</th>
                                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Rollen</th>
                                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Systeme</th>
                                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">E-Mail</th>
                                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">KI-Provider</th>
                                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Aktionen</th>
                            </tr>
                        </thead>
                        <tbody class="bg-white divide-y divide-gray-200">
                            <% staff.forEach((s, index) => { %>
                            <tr>
                                <td class="px-4 py-3 whitespace-nowrap text-sm text-gray-900">#<%= s.id %></td>
                                <td class="px-4 py-3 whitespace-nowrap text-sm font-medium text-gray-900"><%= s.name %></td>
                                <td class="px-4 py-3 whitespace-nowrap text-sm">
                                    <% if (s.kind === 'ai') { %>
                                        <span class="badge bg-purple-100 text-purple-800">KI-Bot</span>
                                    <% } else { %>
                                        <span class="badge bg-emerald-100 text-emerald-800">Mensch</span>
                                    <% } %>
                                </td>
                                <td class="px-4 py-3 text-sm text-gray-700">
                                    <% if (!s.roles || s.roles.length === 0) { %>
                                        <span class="text-gray-400">–</span>
                                    <% } else { %>
                                        <div class="flex flex-wrap gap-1">
                                            <% s.roles.forEach(r => { %>
                                                <span class="badge bg-blue-50 text-blue-700" title="<%= workflowRoleLabels[r] || r %>"><%= r %></span>
                                            <% }); %>
                                        </div>
                                    <% } %>
                                </td>
                                <td class="px-4 py-3 text-sm text-gray-700">
                                    <% if (!s.system_assignments || s.system_assignments.length === 0) { %>
                                        <span class="text-gray-400">–</span>
                                    <% } else { %>
                                        <div class="flex flex-wrap gap-1">
                                            <% s.system_assignments.forEach(a => { %>
                                                <span class="badge <%= a.is_primary ? 'bg-amber-100 text-amber-800' : 'bg-slate-100 text-slate-700' %>">
                                                    <%= a.system_name %><%= a.is_primary ? ' · primär' : '' %>
                                                </span>
                                            <% }); %>
                                        </div>
                                    <% } %>
                                </td>
                                <td class="px-4 py-3 whitespace-nowrap text-sm text-gray-500"><%= s.email %></td>
                                <td class="px-4 py-3 whitespace-nowrap text-sm text-gray-500">
                                    <% if (s.kind === 'ai' && s.ai_provider) { %>
                                        <%= s.ai_provider %><% if (s.ai_model) { %> · <span class="text-gray-400"><%= s.ai_model %></span><% } %>
                                    <% } else { %>
                                        <span class="text-gray-400">–</span>
                                    <% } %>
                                </td>
                                <td class="px-4 py-3 whitespace-nowrap text-sm">
                                    <button type="button" class="mr-3 text-primary-600 hover:text-primary-800 edit-staff-btn" data-index="<%= index %>">Bearbeiten</button>
                                    <form method="post" action="/admin/staff/<%= s.id %>/delete" style="display:inline;" onsubmit="return confirm('Mitarbeiter <%= s.name %> wirklich löschen?');">
                                        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                        <button type="submit" class="text-red-600 hover:text-red-900">Löschen</button>
                                    </form>
                                </td>
                            </tr>
                            <% }); %>
                            <% if (staff.length === 0) { %>
                            <tr>
                                <td colspan="8" class="px-6 py-4 text-center text-gray-500">Keine Mitarbeiter vorhanden.</td>
                            </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </main>

    <div id="staffModal" class="fixed inset-0 z-50 hidden items-center justify-center bg-slate-950/50 p-4 backdrop-blur-sm" role="dialog" aria-modal="true" aria-labelledby="staffModalTitle" aria-hidden="true">
        <div class="w-full max-w-3xl max-h-[90vh] overflow-y-auto rounded-2xl bg-white shadow-2xl ring-1 ring-slate-200">
            <div class="border-b border-slate-200 px-6 py-4">
                <div class="flex items-start justify-between gap-4">
                    <div>
                        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-primary-600">Mitarbeiter</p>
                        <h3 id="staffModalTitle" class="mt-1 text-xl font-semibold text-slate-900">Neuer Mitarbeiter</h3>
                        <p class="mt-1 text-sm text-slate-500">Mensch oder KI-Bot mit einem oder mehreren Workflow-Profilen.</p>
                    </div>
                    <button type="button" id="closeModalHeaderBtn" class="rounded-full p-2 text-slate-400 transition hover:bg-slate-100 hover:text-slate-700" aria-label="Dialog schließen">
                        <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                        </svg>
                    </button>
                </div>
            </div>
            <form method="post" id="staffEditForm" class="space-y-6 px-6 py-6">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">

                <fieldset>
                    <legend class="text-sm font-semibold text-slate-700">Stammdaten</legend>
                    <div class="grid gap-4 md:grid-cols-2 mt-2">
                        <div class="md:col-span-2">
                            <label class="mb-1 block text-sm font-medium text-slate-700">Name</label>
                            <input id="staff_name" name="name" required class="form-input w-full">
                        </div>
                        <div>
                            <label class="mb-1 block text-sm font-medium text-slate-700">E-Mail</label>
                            <input id="staff_email" name="email" type="email" class="form-input w-full">
                        </div>
                        <div>
                            <label class="mb-1 block text-sm font-medium text-slate-700">Telefon</label>
                            <input id="staff_phone" name="phone" class="form-input w-full" placeholder="Optional">
                        </div>
                    </div>
                </fieldset>

                <fieldset>
                    <legend class="text-sm font-semibold text-slate-700">Typ</legend>
                    <div class="mt-2 flex gap-4">
                        <label class="inline-flex items-center gap-2"><input type="radio" name="kind" value="human" id="staff_kind_human" checked> <span>Mensch</span></label>
                        <label class="inline-flex items-center gap-2"><input type="radio" name="kind" value="ai" id="staff_kind_ai"> <span>KI-Bot</span></label>
                    </div>
                </fieldset>

                <fieldset id="aiBlock" class="rounded-lg border border-slate-200 p-4 hidden">
                    <legend class="text-sm font-semibold text-slate-700 px-1">KI-Konfiguration</legend>
                    <div class="grid gap-4 md:grid-cols-2 mt-2">
                        <div>
                            <label class="mb-1 block text-sm font-medium text-slate-700">Provider</label>
                            <select id="staff_ai_provider" name="ai_provider" class="form-input w-full">
                                <option value="">– wählen –</option>
                                <% aiProviders.forEach(p => { %>
                                    <option value="<%= p %>"><%= p %></option>
                                <% }); %>
                            </select>
                        </div>
                        <div>
                            <label class="mb-1 block text-sm font-medium text-slate-700">Modell</label>
                            <input id="staff_ai_model" name="ai_model" class="form-input w-full" placeholder="z. B. deepseek-chat / llama3.1">
                        </div>
                        <div>
                            <label class="mb-1 block text-sm font-medium text-slate-700">Temperatur</label>
                            <input id="staff_ai_temperature" name="ai_temperature" type="number" step="0.05" min="0" max="2" class="form-input w-full" placeholder="0.2">
                        </div>
                        <div>
                            <label class="mb-1 block text-sm font-medium text-slate-700">Max Tokens (optional)</label>
                            <input id="staff_ai_max_tokens" name="ai_max_tokens" type="number" min="0" class="form-input w-full">
                        </div>
                        <div class="md:col-span-2">
                            <label class="mb-1 block text-sm font-medium text-slate-700">System-Prompt-Override (optional)</label>
                            <textarea id="staff_ai_system_prompt" name="ai_system_prompt" rows="3" class="form-input w-full" placeholder="Wenn leer, wird der Standard-Prompt der jeweiligen Rolle verwendet."></textarea>
                        </div>
                        <div class="md:col-span-2">
                            <label class="mb-1 block text-sm font-medium text-slate-700">Extra-Config (JSON, optional)</label>
                            <textarea id="staff_ai_extra_config" name="ai_extra_config" rows="2" class="form-input w-full font-mono text-xs" placeholder='{"top_p": 0.9}'></textarea>
                        </div>
                        <div>
                            <label class="mb-1 block text-sm font-medium text-slate-700">Coding-Level (nur fuer Coding Bot)</label>
                            <select id="staff_coding_level" name="coding_level" class="form-input w-full">
                                <option value="">– kein Coding Bot –</option>
                                <% codingLevels.forEach(l => { %>
                                    <option value="<%= l %>"><%= codingLevelLabels[l] %></option>
                                <% }); %>
                            </select>
                            <p class="text-xs text-slate-500 mt-1">Approver wählt anhand der Empfehlung aus dem Integration-Review.</p>
                        </div>
                        <div class="flex items-center pt-6">
                            <label class="inline-flex items-center gap-2">
                                <input type="checkbox" id="staff_auto_commit_enabled" name="auto_commit_enabled" value="1">
                                <span class="text-sm text-slate-700">Auto-Commit / PR im verknüpften Repository erlauben</span>
                            </label>
                        </div>
                    </div>
                </fieldset>

                <fieldset>
                    <legend class="text-sm font-semibold text-slate-700">Workflow-Rollen</legend>
                    <p class="text-xs text-slate-500 mt-1 mb-2">Welche Stages des Standard-Workflows darf dieser Mitarbeiter bearbeiten?</p>
                    <div class="grid gap-2 sm:grid-cols-2">
                        <% workflowRoles.forEach(r => { %>
                            <label class="inline-flex items-start gap-2 rounded border border-slate-200 px-3 py-2 hover:bg-slate-50">
                                <input type="checkbox" name="roles" value="<%= r %>" class="role-checkbox mt-1" data-role="<%= r %>">
                                <span>
                                    <span class="block text-sm font-medium text-slate-800"><%= workflowRoleLabels[r] %></span>
                                    <span class="block text-xs text-slate-500"><%= r %></span>
                                </span>
                            </label>
                        <% }); %>
                    </div>
                </fieldset>

                <fieldset id="systemAssignmentsBlock">
                    <legend class="text-sm font-semibold text-slate-700">System-Zuständigkeit</legend>
                    <p class="text-xs text-slate-500 mt-1 mb-2">Bei Workflow-Start werden offene Tickets eines Systems per Round-Robin an einen zugeordneten Menschen verteilt. Primäre Zuständige werden bevorzugt.</p>
                    <div class="grid gap-2 sm:grid-cols-2">
                        <% systems.forEach(sys => { %>
                            <label class="rounded border border-slate-200 px-3 py-2 hover:bg-slate-50">
                                <span class="flex items-start gap-3">
                                    <input type="checkbox" name="system_ids" value="<%= sys.id %>" class="system-checkbox mt-1" data-system-id="<%= sys.id %>">
                                    <span class="flex-1">
                                        <span class="block text-sm font-medium text-slate-800"><%= sys.name %></span>
                                        <span class="mt-1 inline-flex items-center gap-2 text-xs text-slate-500">
                                            <input type="checkbox" name="primary_system_ids" value="<%= sys.id %>" class="primary-system-checkbox" data-system-id="<%= sys.id %>">
                                            <span>primär zuständig</span>
                                        </span>
                                    </span>
                                </span>
                            </label>
                        <% }); %>
                    </div>
                </fieldset>

                <div class="flex justify-end gap-3 border-t border-slate-200 pt-5">
                    <button type="button" id="cancelModalBtn" class="btn-secondary">Abbrechen</button>
                    <button type="submit" class="btn-primary">Speichern</button>
                </div>
            </form>
        </div>
    </div>

    <script>
    const staffList = <%- JSON.stringify(staff) %>;
    const staffModal = document.getElementById('staffModal');

    function onKindChange() {
        const aiSelected = document.getElementById('staff_kind_ai').checked;
        document.getElementById('aiBlock').classList.toggle('hidden', !aiSelected);
        document.getElementById('systemAssignmentsBlock').classList.toggle('hidden', aiSelected);
        // Handle email field for Bot
        const emailField = document.getElementById('staff_email');
        if (aiSelected) {
            emailField.required = false;
            emailField.readOnly = true;
            emailField.placeholder = 'Bot erhält automatisch E-Mail-Adresse';
            if (!emailField.value || emailField.value === '') {
                emailField.value = 'bot@ticketsystem.local';
            }
        } else {
            emailField.required = true;
            emailField.readOnly = false;
            emailField.placeholder = '';
            if (emailField.value === 'bot@ticketsystem.local') {
                emailField.value = '';
            }
        }
    }

    function setRoleCheckboxes(roles) {
        const set = new Set(roles || []);
        document.querySelectorAll('.role-checkbox').forEach(cb => {
            cb.checked = set.has(cb.dataset.role);
        });
    }

    function setSystemCheckboxes(assignments) {
        const assigned = new Set((assignments || []).map(a => String(a.system_id)));
        const primary = new Set((assignments || []).filter(a => a.is_primary).map(a => String(a.system_id)));
        document.querySelectorAll('.system-checkbox').forEach(cb => {
            cb.checked = assigned.has(cb.dataset.systemId);
        });
        document.querySelectorAll('.primary-system-checkbox').forEach(cb => {
            cb.checked = primary.has(cb.dataset.systemId);
            cb.disabled = !assigned.has(cb.dataset.systemId);
        });
    }

    document.querySelectorAll('.system-checkbox').forEach(cb => {
        cb.addEventListener('change', function() {
            const primary = document.querySelector('.primary-system-checkbox[data-system-id="' + this.dataset.systemId + '"]');
            if (!primary) return;
            primary.disabled = !this.checked;
            if (!this.checked) primary.checked = false;
        });
    });

    function openStaffModal(staff) {
        const isNew = !staff;
        document.getElementById('staffModalTitle').textContent = isNew ? 'Neuer Mitarbeiter' : staff.name;
        document.getElementById('staff_name').value = isNew ? '' : (staff.name || '');
        document.getElementById('staff_email').value = isNew ? '' : (staff.email || '');
        document.getElementById('staff_phone').value = isNew ? '' : (staff.phone || '');
        document.getElementById('staff_ai_provider').value = isNew ? '' : (staff.ai_provider || '');
        document.getElementById('staff_ai_model').value = isNew ? '' : (staff.ai_model || '');
        document.getElementById('staff_ai_temperature').value = isNew ? '' : (staff.ai_temperature ?? '');
        document.getElementById('staff_ai_max_tokens').value = isNew ? '' : (staff.ai_max_tokens ?? '');
        document.getElementById('staff_ai_system_prompt').value = isNew ? '' : (staff.ai_system_prompt || '');
        document.getElementById('staff_ai_extra_config').value = isNew ? '' : (staff.ai_extra_config || '');
        document.getElementById('staff_coding_level').value = isNew ? '' : (staff.coding_level || '');
        document.getElementById('staff_auto_commit_enabled').checked = isNew ? false : !!staff.auto_commit_enabled;
        const kind = isNew ? 'human' : (staff.kind || 'human');
        document.getElementById('staff_kind_human').checked = kind === 'human';
        document.getElementById('staff_kind_ai').checked = kind === 'ai';
        onKindChange();
        setRoleCheckboxes(isNew ? [] : staff.roles);
        setSystemCheckboxes(isNew ? [] : (staff.system_assignments || []));
        document.getElementById('staffEditForm').action = isNew ? '/admin/staff' : ('/admin/staff/' + staff.id + '/update');
        staffModal.classList.remove('hidden');
        staffModal.classList.add('flex');
        staffModal.setAttribute('aria-hidden', 'false');
        document.body.classList.add('overflow-hidden');
        document.getElementById('staff_name').focus();
    }

    function closeStaffModal() {
        staffModal.classList.add('hidden');
        staffModal.classList.remove('flex');
        staffModal.setAttribute('aria-hidden', 'true');
        document.body.classList.remove('overflow-hidden');
    }

    // Event listeners to replace inline handlers
    document.getElementById('newStaffBtn').addEventListener('click', () => openStaffModal(null));

    document.querySelectorAll('.edit-staff-btn').forEach(btn => {
        btn.addEventListener('click', function() {
            const index = parseInt(this.dataset.index);
            openStaffModal(staffList[index]);
        });
    });

    document.getElementById('closeModalHeaderBtn').addEventListener('click', closeStaffModal);
    document.getElementById('cancelModalBtn').addEventListener('click', closeStaffModal);

    document.getElementById('staff_kind_human').addEventListener('change', onKindChange);
    document.getElementById('staff_kind_ai').addEventListener('change', onKindChange);

    staffModal.addEventListener('click', function(event) {
        if (event.target === staffModal) closeStaffModal();
    });

    document.addEventListener('keydown', function(event) {
        if (event.key === 'Escape' && !staffModal.classList.contains('hidden')) {
            closeStaffModal();
        }
    });

    // Focus trap
    staffModal.addEventListener('keydown', function(e) {
        if (e.key === 'Tab') {
            const focusable = staffModal.querySelectorAll('button, [href], input, select, textarea, [tabindex]:not([tabindex="-1"])');
            const first = focusable[0];
            const last = focusable[focusable.length - 1];
            if (e.shiftKey) {
                if (document.activeElement === first) {
                    e.preventDefault();
                    last.focus();
                }
            } else {
                if (document.activeElement === last) {
                    e.preventDefault();
                    first.focus();
                }
            }
        }
    });
    </script>
</body>
</html>
