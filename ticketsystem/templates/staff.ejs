<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mitarbeiter | Ticketsystem</title>
    <link rel="stylesheet" href="/style.css?v=2">
</head>
<body class="bg-gray-50 min-h-screen">
    <!-- Navigation -->
    <nav class="bg-white border-b border-gray-200 sticky top-0 z-50">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between h-16">
                <div class="flex items-center">
                    <div class="flex-shrink-0 flex items-center gap-2">
                        <div class="w-8 h-8 bg-primary-600 rounded-lg flex items-center justify-center">
                            <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 5v2m0 4v2m0 4v2M5 5a2 2 0 00-2 2v3a2 2 0 110 4v3a2 2 0 002 2h14a2 2 0 002-2v-3a2 2 0 110-4V7a2 2 0 00-2-2H5z"/>
                            </svg>
                        </div>
                        <a href="/" class="text-xl font-bold text-gray-900 hover:text-primary-600">Ticketsystem</a>
                    </div>
                    <div class="hidden md:ml-8 md:flex md:space-x-1">
                        <a href="/" class="nav-link">Dashboard</a>
                        <% if (role === 'admin' || role === 'root') { %>
                        <a href="/stats" class="nav-link">Statistiken</a>
                        <% } %>
                        <a href="/admin/systems" class="nav-link">Systeme</a>
                        <a href="/admin/staff" class="nav-link active">Mitarbeiter</a>
                        <% if (role === 'root') { %>
                        <a href="/admin/users" class="nav-link">Benutzer</a>
                        <% } %>
                    </div>
                </div>
                <div class="flex items-center gap-4">
                    <span class="text-sm text-gray-600"><%= user %> <span class="badge bg-gray-100 text-gray-700"><%= role %></span></span>
                    <a href="/account" class="btn-secondary text-sm">Account</a>
                    <a href="/logout" class="btn-secondary text-sm">Abmelden</a>
                </div>
            </div>
        </div>
    </nav>

    <!-- Main Content -->
    <main class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        <!-- Breadcrumbs -->
        <nav class="flex mb-6" aria-label="Breadcrumb">
            <ol class="flex items-center space-x-4">
                <li><a href="/" class="text-gray-500 hover:text-gray-700">Dashboard</a></li>
                <li class="text-gray-400">/</li>
                <li class="text-gray-900 font-medium">Mitarbeiter</li>
            </ol>
        </nav>

        <div class="card mb-8">
            <div class="card-header">
                <h2 class="text-lg font-semibold text-gray-900">Neuen Mitarbeiter hinzufügen</h2>
            </div>
            <div class="card-body">
                <form method="post" action="/admin/staff" class="flex flex-col md:flex-row gap-4">
                    <input name="name" placeholder="Name" required class="form-input flex-1">
                    <input name="email" type="email" placeholder="E-Mail" required class="form-input flex-1">
                    <input name="phone" placeholder="Telefon" class="form-input flex-1">
                    <button type="submit" class="btn-primary">Hinzufügen</button>
                </form>
            </div>
        </div>

        <div class="card">
            <div class="card-header">
                <h2 class="text-lg font-semibold text-gray-900">Mitarbeiter</h2>
            </div>
            <div class="card-body p-0">
                <div class="overflow-x-auto">
                    <table class="min-w-full divide-y divide-gray-200">
                        <thead class="bg-gray-50">
                            <tr>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">ID</th>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Name</th>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">E-Mail</th>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Telefon</th>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Aktionen</th>
                            </tr>
                        </thead>
                        <tbody class="bg-white divide-y divide-gray-200">
                            <% staff.forEach(s => { %>
                            <tr>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">#<%= s.id %></td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900"><%= s.name %></td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500"><%= s.email %></td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500"><%= s.phone || '-' %></td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm">
                                    <button
                                        type="button"
                                        class="mr-4 text-primary-600 hover:text-primary-800"
                                        onclick='openStaffModal(<%- JSON.stringify(s) %>)'>Bearbeiten</button>
                                    <form method="post" action="/admin/staff/<%= s.id %>/delete" style="display:inline;" onsubmit="return confirm('Mitarbeiter <%= s.name %> wirklich löschen?');">
                                        <button type="submit" class="text-red-600 hover:text-red-900">Löschen</button>
                                    </form>
                                </td>
                            </tr>
                            <% }); %>
                            <% if (staff.length === 0) { %>
                            <tr>
                                <td colspan="5" class="px-6 py-4 text-center text-gray-500">Keine Mitarbeiter vorhanden.</td>
                            </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </main>

    <div id="staffModal" class="fixed inset-0 z-50 hidden items-center justify-center bg-slate-950/50 p-4 backdrop-blur-sm">
        <div class="w-full max-w-xl overflow-hidden rounded-2xl bg-white shadow-2xl ring-1 ring-slate-200">
            <div class="border-b border-slate-200 px-6 py-4">
                <div class="flex items-start justify-between gap-4">
                    <div>
                        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-primary-600">Mitarbeiter bearbeiten</p>
                        <h3 id="staffModalTitle" class="mt-1 text-xl font-semibold text-slate-900">Datensatz aktualisieren</h3>
                        <p class="mt-1 text-sm text-slate-500">Name, Mailadresse und Telefonnummer werden direkt im Mitarbeiterstamm gespeichert.</p>
                    </div>
                    <button type="button" class="rounded-full p-2 text-slate-400 transition hover:bg-slate-100 hover:text-slate-700" onclick="closeStaffModal()" aria-label="Dialog schließen">
                        <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                        </svg>
                    </button>
                </div>
            </div>
            <form method="post" id="staffEditForm" class="space-y-5 px-6 py-6">
                <div class="grid gap-5 md:grid-cols-2">
                    <div class="md:col-span-2">
                        <label class="mb-1 block text-sm font-medium text-slate-700">Name</label>
                        <input id="staff_name" name="name" required class="form-input w-full">
                    </div>
                    <div>
                        <label class="mb-1 block text-sm font-medium text-slate-700">E-Mail</label>
                        <input id="staff_email" name="email" type="email" required class="form-input w-full">
                    </div>
                    <div>
                        <label class="mb-1 block text-sm font-medium text-slate-700">Telefon</label>
                        <input id="staff_phone" name="phone" class="form-input w-full" placeholder="Optional">
                    </div>
                </div>
                <div class="flex justify-end gap-3 border-t border-slate-200 pt-5">
                    <button type="button" onclick="closeStaffModal()" class="btn-secondary">Abbrechen</button>
                    <button type="submit" class="btn-primary">Änderungen speichern</button>
                </div>
            </form>
        </div>
    </div>

    <script>
    const staffModal = document.getElementById('staffModal');

    function openStaffModal(staff) {
        document.getElementById('staffModalTitle').textContent = staff.name;
        document.getElementById('staff_name').value = staff.name || '';
        document.getElementById('staff_email').value = staff.email || '';
        document.getElementById('staff_phone').value = staff.phone || '';
        document.getElementById('staffEditForm').action = '/admin/staff/' + staff.id + '/update';
        staffModal.classList.remove('hidden');
        staffModal.classList.add('flex');
        document.body.classList.add('overflow-hidden');
    }

    function closeStaffModal() {
        staffModal.classList.add('hidden');
        staffModal.classList.remove('flex');
        document.body.classList.remove('overflow-hidden');
    }

    staffModal.addEventListener('click', function(event) {
        if (event.target === staffModal) closeStaffModal();
    });

    document.addEventListener('keydown', function(event) {
        if (event.key === 'Escape' && !staffModal.classList.contains('hidden')) {
            closeStaffModal();
        }
    });
    </script>
</body>
</html>
